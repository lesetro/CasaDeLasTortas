    },
    {
      "name": "3. Validation",
      "item": [
        {
          "name": "3.1 Check Email Availability",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/account/check-email?email=test@example.com",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "check-email"],
              "query": [
                {
                  "key": "email",
                  "value": "test@example.com",
                  "description": "Email a verificar"
                }
              ]
            },
            "description": "Verificar si un email está disponible para registro"
          },
          "response": []
        },
        {
          "name": "3.2 Check Nombre Comercial",
          "request": {
            "method": "GET",
            "header": [],
