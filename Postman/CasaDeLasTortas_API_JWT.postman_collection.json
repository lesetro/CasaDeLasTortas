            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/account/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "forgot-password"]
            },
            "description": "Solicitar reseteo de contraseña.\n\nNota: Por seguridad, siempre retorna el mismo mensaje sin revelar si el email existe."
          },
          "response": []
        }
      ],
      "description": "Endpoints para recuperación de contraseña"
    },
    {
      "name": "5. Testing Examples",
      "item": [
        {
          "name": "5.1 Test - Login Vendedor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.token).to.exist;",
                  "    pm.expect(jsonData.user.rol).to.eql('Vendedor');",
                  "    ",
                  "    // Guardar token",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendedor@test.com\",\n  \"password\": \"Vendedor123!\"\n}"
            },
            "url": "{{baseUrl}}/api/account/login",
            "description": "Test completo de login con verificaciones automáticas"
          },
          "response": []
        },
        {
          "name": "5.2 Test - Get Profile After Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Profile contains rolData', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.profile.rolData).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/account/profile"
          },
          "response": []
        },
        {
          "name": "5.3 Test - Invalid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Error message present', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.false;",
                  "    pm.expect(jsonData.message).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"wrong@test.com\",\n  \"password\": \"WrongPassword123!\"\n}"
            },
            "url": "{{baseUrl}}/api/account/login"
          },
          "response": []
        },
        {
          "name": "5.4 Test - Unauthorized Access",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/account/me",
            "description": "Intentar acceder sin token - debe fallar"
          },
          "response": []
        }
      ],
      "description": "Ejemplos de testing con validaciones automáticas"
    }
