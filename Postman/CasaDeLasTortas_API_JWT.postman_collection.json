            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/account/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "me"]
            },
            "description": "Obtener información básica del usuario autenticado"
          },
          "response": []
        },
        {
