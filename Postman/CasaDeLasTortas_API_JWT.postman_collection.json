              "raw": "{{baseUrl}}/api/account/check-nombre-comercial?nombreComercial=La%20Delicia",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "check-nombre-comercial"],
              "query": [
                {
                  "key": "nombreComercial",
