{
  "info": {
    "_postman_id": "casa-tortas-api-jwt",
    "name": "Casa de las Tortas - API JWT",
    "description": "Colección completa de endpoints para el API de Casa de las Tortas con autenticación JWT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "1.1 Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Guardar token automáticamente si el login es exitoso",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.success && jsonData.token) {",
                  "        pm.collectionVariables.set('token', jsonData.token);",
                  "        console.log('Token guardado exitosamente');",
                  "        console.log('Usuario:', jsonData.user.nombre);",
                  "        console.log('Rol:', jsonData.user.rol);",
                  "    }",
                  "} else {",
                  "    console.log('Login fallido');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendedor@test.com\",\n  \"password\": \"Vendedor123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/account/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "login"]
            },
            "description": "Autenticación de usuario. Retorna JWT token.\n\n**Roles disponibles:**\n- Vendedor\n- Comprador\n\n**Credenciales de prueba:**\n- Vendedor: vendedor@test.com / Vendedor123!\n- Comprador: comprador@test.com / Comprador123!"
          },
          "response": []
        },
        {
          "name": "1.2 Register - Vendedor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.success && jsonData.token) {",
                  "        pm.collectionVariables.set('token', jsonData.token);",
                  "        console.log('Registro exitoso - Token guardado');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "Nombre",
                  "value": "Pastelería La Delicia",
                  "type": "text",
                  "description": "Nombre completo del vendedor"
                },
                {
                  "key": "Email",
                  "value": "ladelicia@example.com",
                  "type": "text",
                  "description": "Email único"
                },
                {
                  "key": "Password",
                  "value": "Password123!",
                  "type": "text",
                  "description": "Mínimo 8 caracteres, 1 mayúscula, 1 número"
                },
                {
                  "key": "ConfirmPassword",
                  "value": "Password123!",
                  "type": "text"
                },
                {
                  "key": "Telefono",
                  "value": "2664123456",
                  "type": "text"
                },
                {
                  "key": "Rol",
                  "value": "Vendedor",
                  "type": "text",
                  "description": "Vendedor o Comprador"
                },
                {
                  "key": "NombreComercial",
                  "value": "La Delicia",
                  "type": "text",
                  "description": "Requerido para Vendedor"
                },
                {
                  "key": "Descripcion",
                  "value": "Las mejores tortas artesanales de Villa Mercedes",
                  "type": "text",
                  "description": "Opcional para Vendedor"
                },
                {
                  "key": "AvatarFile",
                  "type": "file",
                  "src": [],
                  "description": "Imagen opcional (jpg, png, gif - máx 5MB)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/account/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "register"]
            },
            "description": "Registro de nuevo vendedor con nombre comercial"
          },
          "response": []
        },
        {
          "name": "1.3 Register - Comprador",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.success && jsonData.token) {",
                  "        pm.collectionVariables.set('token', jsonData.token);",
                  "        console.log('Registro exitoso - Token guardado');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "Nombre",
                  "value": "María González",
                  "type": "text"
                },
                {
                  "key": "Email",
                  "value": "maria.gonzalez@example.com",
                  "type": "text"
                },
                {
                  "key": "Password",
                  "value": "Password123!",
                  "type": "text"
                },
                {
                  "key": "ConfirmPassword",
                  "value": "Password123!",
                  "type": "text"
                },
                {
                  "key": "Telefono",
                  "value": "2664789012",
                  "type": "text"
                },
                {
                  "key": "Rol",
                  "value": "Comprador",
                  "type": "text"
                },
                {
                  "key": "Direccion",
                  "value": "Av. Mitre 456, Villa Mercedes",
                  "type": "text",
                  "description": "Requerido para Comprador"
                },
                {
                  "key": "AvatarFile",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/account/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "register"]
            },
            "description": "Registro de nuevo comprador con dirección"
          },
          "response": []
        },
        {
          "name": "1.4 Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.success && jsonData.token) {",
                  "        pm.collectionVariables.set('token', jsonData.token);",
                  "        console.log('Token renovado exitosamente');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/account/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "refresh-token"]
            },
            "description": "Renovar token JWT sin hacer login nuevamente.\nÚtil para mantener la sesión activa."
          },
          "response": []
        }
      ],
      "description": "Endpoints de autenticación y registro"
    },
    {
