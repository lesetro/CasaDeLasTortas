@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center
                            rounded-circle bg-danger bg-opacity-10 mb-3"
                     style="width:80px;height:80px">
                    <i class="fas fa-exclamation-triangle fa-3x text-danger"></i>
                </div>
                <h2 class="fw-bold">Acceso Denegado</h2>
                <p class="text-muted">No tenés permisos para acceder a esta página.</p>
            </div>

            <div class="alert alert-warning small">
                <i class="fas fa-info-circle me-2"></i>
                <strong>¿Por qué estoy viendo esto?</strong><br>
                Esta página requiere permisos especiales o un tipo de cuenta específica
                que tu usuario actual no posee.
            </div>

            <div class="d-grid gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-warning fw-semibold">
                    <i class="fas fa-home me-2"></i>Volver al Inicio
                </a>
                <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-secondary">
                    <i class="fas fa-envelope me-2"></i>Contactar Soporte
                </a>
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary">
                        <i class="fas fa-sign-out-alt me-2"></i>Cerrar Sesión
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">
                        <i class="fas fa-sign-in-alt me-2"></i>Iniciar Sesión
                    </a>
                }
            </div>

        </div>
    </div>
</div>
