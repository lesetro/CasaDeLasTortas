@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "_Layout";
}

<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="text-center">
            <!-- Icono -->
            <div class="mx-auto flex items-center justify-center h-24 w-24 rounded-full bg-red-100">
                <i class="fas fa-exclamation-triangle text-4xl text-red-600"></i>
            </div>
            
            <!-- Título -->
            <h2 class="mt-6 text-3xl font-extrabold text-gray-900">
                Acceso Denegado
            </h2>
            
            <!-- Descripción -->
            <p class="mt-4 text-lg text-gray-600">
                No tienes permisos para acceder a esta página.
            </p>
            
            <!-- Información adicional -->
            <div class="mt-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-info-circle text-yellow-400"></i>
                    </div>
                    <div class="ml-3">
                        <h3 class="text-sm font-medium text-yellow-800">
                            ¿Por qué estoy viendo esto?
                        </h3>
                        <div class="mt-2 text-sm text-yellow-700">
                            <p>
                                Esta página requiere permisos especiales o un tipo de cuenta específica 
                                que tu usuario actual no posee.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Acciones -->
        <div class="mt-8 space-y-4">
            <!-- Volver al inicio -->
            <a asp-controller="Home" asp-action="Index" 
               class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition">
                <i class="fas fa-home mr-2"></i>
                Volver al Inicio
            </a>

            <!-- Contactar soporte -->
            <a asp-controller="Home" asp-action="Contact" 
               class="w-full flex justify-center py-3 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition">
                <i class="fas fa-envelope mr-2"></i>
                Contactar Soporte
            </a>

            <!-- Si está autenticado, mostrar opción de perfil -->
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-controller="Account" asp-action="Profile" 
                   class="w-full flex justify-center py-3 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition">
                    <i class="fas fa-user mr-2"></i>
                    Mi Perfil
                </a>
            }
            else
            {
                <!-- Si no está autenticado, mostrar opción de login -->
                <a asp-controller="Account" asp-action="Login" 
                   class="w-full flex justify-center py-3 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition">
                    <i class="fas fa-sign-in-alt mr-2"></i>
                    Iniciar Sesión
                </a>
            }
        </div>

        <!-- Información de debug (solo en desarrollo) -->
        @if (Context.RequestServices.GetService<IWebHostEnvironment>().IsDevelopment())
        {
            <div class="mt-8 p-4 bg-gray-100 rounded-lg">
                <h4 class="text-sm font-medium text-gray-900 mb-2">Información de Debug:</h4>
                <div class="text-xs text-gray-600 space-y-1">
                    <div><strong>Usuario:</strong> @User.Identity.Name</div>
                    <div><strong>Autenticado:</strong> @User.Identity.IsAuthenticated</div>
                    <div><strong>Roles:</strong> 
                        @foreach (var claim in User.Claims.Where(c => c.Type == ClaimTypes.Role))
                        {
                            <span class="bg-gray-200 px-2 py-1 rounded mr-1">@claim.Value</span>
                        }
                    </div>
                    <div><strong>URL solicitada:</strong> @Context.Request.Path</div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .min-h-screen {
        min-height: 100vh;
    }
</style>