@{
    ViewData["Title"] = "Registrarse";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <!-- Header -->
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center
                            rounded-circle bg-warning bg-opacity-25 mb-3"
                     style="width:64px;height:64px">
                    <i class="fas fa-birthday-cake fa-2x text-warning"></i>
                </div>
                <h2 class="fw-bold">Crear Cuenta</h2>
                <p class="text-muted small">
                    Únete a Casa de las Tortas y descubrí un mundo de sabores
                </p>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-semibold">Información Personal</h5>
                </div>
                <div class="card-body p-4">
                    <form id="registerForm" novalidate>

                        <!-- Nombre + Email -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="nombre" class="form-label fw-semibold">Nombre Completo *</label>
                                <input type="text" id="nombre" name="nombre" class="form-control"
                                       placeholder="Juan Pérez" required>
                                <div id="nombreError" class="text-danger small mt-1 d-none"></div>
                            </div>
                            <div class="col-md-6">
                                <label for="email" class="form-label fw-semibold">Email *</label>
                                <input type="email" id="email" name="email" class="form-control"
                                       placeholder="tu@@email.com" required>
                                <div id="emailError" class="text-danger small mt-1 d-none"></div>
                            </div>
                        </div>

                        <!-- Teléfono + Rol -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="telefono" class="form-label fw-semibold">Teléfono</label>
                                <input type="tel" id="telefono" name="telefono" class="form-control"
                                       placeholder="+54 266 123-4567">
                            </div>
                            <div class="col-md-6">
                                <label for="rol" class="form-label fw-semibold">Tipo de Cuenta *</label>
                                <select id="rol" name="rol" class="form-select" required>
                                    <option value="">Seleccioná un tipo</option>
                                    <option value="Vendedor">Vendedor</option>
                                    <option value="Comprador">Comprador</option>
                                </select>
                                <div id="rolError" class="text-danger small mt-1 d-none"></div>
                            </div>
                        </div>

                        <!-- Contraseñas -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="password" class="form-label fw-semibold">Contraseña *</label>
                                <div class="input-group">
                                    <input type="password" id="password" name="password" class="form-control"
                                           placeholder="Mínimo 6 caracteres" required>
                                    <button class="btn btn-outline-secondary" type="button"
                                            onclick="togglePwd('password','pwdIcon1')">
                                        <i id="pwdIcon1" class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <div id="passwordError" class="text-danger small mt-1 d-none"></div>
                            </div>
                            <div class="col-md-6">
                                <label for="confirmPassword" class="form-label fw-semibold">Confirmar Contraseña *</label>
                                <div class="input-group">
                                    <input type="password" id="confirmPassword" name="confirmPassword" class="form-control"
                                           placeholder="Repetí tu contraseña" required>
                                    <button class="btn btn-outline-secondary" type="button"
                                            onclick="togglePwd('confirmPassword','pwdIcon2')">
                                        <i id="pwdIcon2" class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <div id="confirmPasswordError" class="text-danger small mt-1 d-none"></div>
                            </div>
                        </div>

                        <!-- Campos Vendedor -->
                        <div id="vendedorFields" class="d-none mb-3">
                            <div class="card bg-warning bg-opacity-10 border-warning">
                                <div class="card-body">
                                    <h6 class="fw-bold text-warning mb-3">
                                        <i class="fas fa-store me-2"></i>Información del Vendedor
                                    </h6>
                                    <div class="mb-3">
                                        <label for="nombreComercial" class="form-label fw-semibold">Nombre Comercial *</label>
                                        <input type="text" id="nombreComercial" name="nombreComercial" class="form-control"
                                               placeholder="Mi Tortería Artesanal">
                                        <div id="nombreComercialError" class="text-danger small mt-1 d-none"></div>
                                    </div>
                                    <div>
                                        <label for="descripcion" class="form-label fw-semibold">Descripción</label>
                                        <textarea id="descripcion" name="descripcion" rows="3" class="form-control"
                                                  placeholder="Contanos sobre tu negocio..."></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Campos Comprador -->
                        <div id="compradorFields" class="d-none mb-3">
                            <div class="card bg-primary bg-opacity-10 border-primary">
                                <div class="card-body">
                                    <h6 class="fw-bold text-primary mb-3">
                                        <i class="fas fa-map-marker-alt me-2"></i>Información de Entrega
                                    </h6>
                                    <div>
                                        <label for="direccion" class="form-label fw-semibold">Dirección *</label>
                                        <input type="text" id="direccion" name="direccion" class="form-control"
                                               placeholder="Calle Principal 123">
                                        <div id="direccionError" class="text-danger small mt-1 d-none"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Términos -->
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="acceptTerms" required>
                            <label class="form-check-label small" for="acceptTerms">
                                Acepto los
                                <a asp-controller="Home" asp-action="Terms" target="_blank" class="text-warning fw-semibold">Términos y Condiciones</a>
                                y la
                                <a asp-controller="Home" asp-action="Privacy" target="_blank" class="text-warning fw-semibold">Política de Privacidad</a>
                            </label>
                            <div id="termsError" class="text-danger small mt-1 d-none"></div>
                        </div>

                        <!-- Error general -->
                        <div id="formError" class="alert alert-danger d-none py-2 small mb-3">
                            <i class="fas fa-exclamation-circle me-2"></i><span id="errorMessage"></span>
                        </div>

                        <!-- Botones -->
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Login" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i>Volver al Login
                            </a>
                            <button type="submit" id="registerButton" class="btn btn-warning fw-semibold px-4">
                                <span id="registerButtonText">Crear Cuenta</span>
                                <span id="registerSpinner" class="spinner-border spinner-border-sm ms-2 d-none"></span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function togglePwd(inputId, iconId) {
        var input = document.getElementById(inputId);
        var icon = document.getElementById(iconId);
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }

    // Mostrar campos según rol
    document.getElementById('rol').addEventListener('change', function() {
        document.getElementById('vendedorFields').classList.add('d-none');
        document.getElementById('compradorFields').classList.add('d-none');
        if (this.value === 'Vendedor') document.getElementById('vendedorFields').classList.remove('d-none');
        if (this.value === 'Comprador') document.getElementById('compradorFields').classList.remove('d-none');
    });

    function clearErrors() {
        document.querySelectorAll('[id$="Error"]').forEach(function(el) { el.classList.add('d-none'); });
    }
    function showError(field, msg) {
        var el = document.getElementById(field + 'Error');
        if (el) { el.textContent = msg; el.classList.remove('d-none'); }
    }
    function showFormError(msg) {
        document.getElementById('errorMessage').textContent = msg;
        document.getElementById('formError').classList.remove('d-none');
    }

    document.getElementById('registerForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        clearErrors();

        var formData = new FormData(this);
        var isValid = true;

        // Validaciones
        if (!formData.get('nombre')) { showError('nombre', 'El nombre es requerido'); isValid = false; }
        if (!formData.get('email')) { showError('email', 'El email es requerido'); isValid = false; }
        if (!formData.get('rol')) { showError('rol', 'Seleccioná un tipo de cuenta'); isValid = false; }

        var email = formData.get('email');
        if (email && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
            showError('email', 'Formato de email inválido'); isValid = false;
        }

        var password = formData.get('password');
        var confirmPassword = formData.get('confirmPassword');
        if (!password || password.length < 6) { showError('password', 'Mínimo 6 caracteres'); isValid = false; }
        if (password !== confirmPassword) { showError('confirmPassword', 'Las contraseñas no coinciden'); isValid = false; }

        if (formData.get('rol') === 'Vendedor' && !formData.get('nombreComercial')) {
            showError('nombreComercial', 'El nombre comercial es requerido'); isValid = false;
        }
        if (formData.get('rol') === 'Comprador' && !formData.get('direccion')) {
            showError('direccion', 'La dirección es requerida'); isValid = false;
        }
        if (!document.getElementById('acceptTerms').checked) {
            showError('terms', 'Debés aceptar los términos'); isValid = false;
        }

        if (!isValid) return;

        var btn = document.getElementById('registerButton');
        var txt = document.getElementById('registerButtonText');
        var spin = document.getElementById('registerSpinner');
        btn.disabled = true;
        txt.textContent = 'Creando cuenta...';
        spin.classList.remove('d-none');

        try {
            var resp = await fetch('/api/AuthApi/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    nombre: formData.get('nombre'),
                    email: formData.get('email'),
                    telefono: formData.get('telefono'),
                    password: formData.get('password'),
                    rol: formData.get('rol'),
                    nombreComercial: formData.get('nombreComercial'),
                    descripcion: formData.get('descripcion'),
                    direccion: formData.get('direccion')
                })
            });

            var contentType = resp.headers.get('content-type') || '';
            if (!contentType.includes('application/json')) {
                throw new Error('Error del servidor. Status: ' + resp.status);
            }

            var data = await resp.json();

            if (resp.ok && data.success) {
                localStorage.setItem('authToken', data.token);
                localStorage.setItem('user', JSON.stringify(data.user));

                await fetch('/Account/SetCookieSession', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: data.token })
                });

                txt.textContent = '¡Cuenta creada! Redirigiendo...';

                setTimeout(function() {
                    window.location.href = formData.get('rol') === 'Vendedor'
                        ? '/Vendedor/DashboardVue'
                        : '/Comprador/DashboardVue';
                }, 1500);
            } else {
                throw new Error(data.message || 'Error al crear la cuenta');
            }
        } catch (err) {
            showFormError(err.message || 'Error de conexión. Intentá nuevamente.');
            btn.disabled = false;
            txt.textContent = 'Crear Cuenta';
            spin.classList.add('d-none');
        }
    });

    document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('nombre').focus();
    });
</script>
}
