@{
    ViewData["Title"] = "Mi Perfil";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Header -->
            <div class="mb-4">
                <h2 class="fw-bold">Mi Perfil</h2>
                <p class="text-muted">Gestioná tu información personal y configuración de cuenta</p>
            </div>

            <div class="row g-4">

                <!-- Columna izquierda — Info personal -->
                <div class="col-lg-8">

                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white py-3">
                            <h5 class="mb-0 fw-semibold">Información Personal</h5>
                        </div>
                        <div class="card-body p-4">
                            <form id="profileForm">
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label for="nombre" class="form-label fw-semibold">Nombre Completo</label>
                                        <input type="text" id="nombre" name="nombre" class="form-control">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="email" class="form-label fw-semibold">Email</label>
                                        <input type="email" id="email" name="email" class="form-control">
                                    </div>
                                </div>
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label for="telefono" class="form-label fw-semibold">Teléfono</label>
                                        <input type="tel" id="telefono" name="telefono" class="form-control">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold">Tipo de Cuenta</label>
                                        <div id="rolDisplay" class="form-control bg-light text-muted">Cargando...</div>
                                    </div>
                                </div>

                                <!-- Info específica del rol -->
                                <div id="rolSpecificInfo" class="bg-light rounded-3 p-3 mb-3"></div>

                                <!-- Alerta -->
                                <div id="profileAlert" class="d-none mb-3"></div>

                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" id="cancelBtn" class="btn btn-outline-secondary">Cancelar</button>
                                    <button type="submit" class="btn btn-warning fw-semibold">
                                        <i class="fas fa-save me-1"></i>Guardar Cambios
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Seguridad -->
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white py-3">
                            <h5 class="mb-0 fw-semibold">Seguridad</h5>
                        </div>
                        <div class="card-body p-4">
                            <p class="text-muted small mb-3">Actualizá tu contraseña periódicamente para mantener tu cuenta segura.</p>
                            <form id="changePasswordForm">
                                <div class="row g-3 mb-3">
                                    <div class="col-md-4">
                                        <label for="currentPassword" class="form-label fw-semibold small">Contraseña Actual</label>
                                        <input type="password" id="currentPassword" class="form-control form-control-sm">
                                    </div>
                                    <div class="col-md-4">
                                        <label for="newPassword" class="form-label fw-semibold small">Nueva Contraseña</label>
                                        <input type="password" id="newPassword" class="form-control form-control-sm">
                                    </div>
                                    <div class="col-md-4">
                                        <label for="confirmNewPassword" class="form-label fw-semibold small">Confirmar Nueva</label>
                                        <input type="password" id="confirmNewPassword" class="form-control form-control-sm">
                                    </div>
                                </div>
                                <div id="passwordAlert" class="d-none mb-3"></div>
                                <button type="submit" class="btn btn-outline-warning btn-sm fw-semibold">
                                    <i class="fas fa-key me-1"></i>Cambiar Contraseña
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Columna derecha — Avatar + Stats -->
                <div class="col-lg-4">

                    <!-- Avatar -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body p-4 text-center">
                            <div class="position-relative d-inline-block mb-3">
                                <img id="avatarImage"
                                     class="rounded-circle border border-3 border-light shadow-sm"
                                     style="width:120px;height:120px;object-fit:cover"
                                     src="/images/default-avatar.png"
                                     alt="Avatar">
                                <button id="changeAvatarBtn" type="button"
                                        class="btn btn-warning btn-sm rounded-circle position-absolute bottom-0 end-0 shadow"
                                        style="width:36px;height:36px">
                                    <i class="fas fa-camera" style="font-size:.75rem"></i>
                                </button>
                                <input type="file" id="avatarFile" class="d-none" accept="image/*">
                            </div>
                            <h5 id="userName" class="fw-bold mb-1">Cargando...</h5>
                            <p id="userEmail" class="text-muted small mb-0">Cargando...</p>
                        </div>
                    </div>

                    <!-- Estadísticas -->
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-3">Estadísticas</h6>
                            <div class="d-flex justify-content-between small mb-2">
                                <span class="text-muted">Miembro desde</span>
                                <span id="memberSince" class="fw-semibold">—</span>
                            </div>
                            <div class="d-flex justify-content-between small mb-2">
                                <span class="text-muted">Último acceso</span>
                                <span id="lastAccess" class="fw-semibold">—</span>
                            </div>
                            <div id="vendedorStats" class="d-none">
                                <div class="d-flex justify-content-between small mb-2">
                                    <span class="text-muted">Tortas activas</span>
                                    <span class="fw-semibold text-success">—</span>
                                </div>
                                <div class="d-flex justify-content-between small">
                                    <span class="text-muted">Ventas totales</span>
                                    <span class="fw-semibold text-success">—</span>
                                </div>
                            </div>
                            <div id="compradorStats" class="d-none">
                                <div class="d-flex justify-content-between small mb-2">
                                    <span class="text-muted">Compras realizadas</span>
                                    <span class="fw-semibold text-primary">—</span>
                                </div>
                                <div class="d-flex justify-content-between small">
                                    <span class="text-muted">Pedidos activos</span>
                                    <span class="fw-semibold text-primary">—</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var userData = {};
    var originalData = {};

    async function loadUserData() {
        try {
            var token = localStorage.getItem('authToken');
            if (!token) { window.location.href = '/Account/Login'; return; }

            var resp = await fetch('/api/AuthApi/me', {
                headers: { 'Authorization': 'Bearer ' + token }
            });

            if (!resp.ok) throw new Error('Error al cargar datos');

            var result = await resp.json();
            userData = result.user || result;
            originalData = JSON.parse(JSON.stringify(userData));
            displayUserData();
        } catch (err) {
            console.error('Error:', err);
            showAlert('profileAlert', 'danger', 'Error al cargar los datos del perfil');
        }
    }

    function displayUserData() {
        document.getElementById('nombre').value = userData.nombre || '';
        document.getElementById('email').value = userData.email || '';
        document.getElementById('telefono').value = userData.telefono || '';
        document.getElementById('rolDisplay').textContent = getRolName(userData.rol);

        var img = document.getElementById('avatarImage');
        img.src = userData.avatar || '/images/default-avatar.png';

        document.getElementById('userName').textContent = userData.nombre || 'Usuario';
        document.getElementById('userEmail').textContent = userData.email || '';
        document.getElementById('memberSince').textContent = userData.fechaRegistro
            ? new Date(userData.fechaRegistro).toLocaleDateString() : '—';
        document.getElementById('lastAccess').textContent = userData.ultimoAcceso
            ? new Date(userData.ultimoAcceso).toLocaleDateString() : '—';

        displayRolInfo();
    }

    function displayRolInfo() {
        var container = document.getElementById('rolSpecificInfo');
        document.getElementById('vendedorStats').classList.add('d-none');
        document.getElementById('compradorStats').classList.add('d-none');

        if (userData.rol === 'Vendedor' && userData.rolData) {
            container.innerHTML =
                '<h6 class="fw-bold mb-2">Info del Vendedor</h6>' +
                '<div class="row g-2">' +
                '  <div class="col-md-6"><label class="form-label small fw-semibold">Nombre Comercial</label>' +
                '  <input type="text" name="nombreComercial" value="' + (userData.rolData.nombreComercial || '') + '" class="form-control form-control-sm"></div>' +
                '  <div class="col-md-6"><label class="form-label small fw-semibold">Especialidad</label>' +
                '  <input type="text" name="especialidad" value="' + (userData.rolData.especialidad || '') + '" class="form-control form-control-sm"></div>' +
                '</div>';
            document.getElementById('vendedorStats').classList.remove('d-none');
        } else if (userData.rol === 'Comprador' && userData.rolData) {
            container.innerHTML =
                '<h6 class="fw-bold mb-2">Info de Entrega</h6>' +
                '<div class="row g-2">' +
                '  <div class="col-md-6"><label class="form-label small fw-semibold">Dirección</label>' +
                '  <input type="text" name="direccion" value="' + (userData.rolData.direccion || '') + '" class="form-control form-control-sm"></div>' +
                '  <div class="col-md-3"><label class="form-label small fw-semibold">Ciudad</label>' +
                '  <input type="text" name="ciudad" value="' + (userData.rolData.ciudad || '') + '" class="form-control form-control-sm"></div>' +
                '  <div class="col-md-3"><label class="form-label small fw-semibold">C.P.</label>' +
                '  <input type="text" name="codigoPostal" value="' + (userData.rolData.codigoPostal || '') + '" class="form-control form-control-sm"></div>' +
                '</div>';
            document.getElementById('compradorStats').classList.remove('d-none');
        } else {
            container.innerHTML = '<p class="text-muted small mb-0">No hay información adicional.</p>';
        }
    }

    function getRolName(rol) {
        var roles = { 'Vendedor': '👨‍🍳 Vendedor', 'Comprador': '🛒 Comprador', 'Admin': '⚙️ Admin' };
        return roles[rol] || rol || '—';
    }

    function showAlert(containerId, type, msg) {
        var el = document.getElementById(containerId);
        el.className = 'alert alert-' + type + ' py-2 small';
        el.textContent = msg;
        el.classList.remove('d-none');
        setTimeout(function() { el.classList.add('d-none'); }, 5000);
    }

    // Guardar perfil
    document.getElementById('profileForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        try {
            var token = localStorage.getItem('authToken');
            var formDataObj = new FormData(this);

            var resp = await fetch('/api/AuthApi/me', {
                method: 'PUT',
                headers: { 'Authorization': 'Bearer ' + token },
                body: formDataObj
            });

            if (resp.ok) {
                showAlert('profileAlert', 'success', 'Perfil actualizado exitosamente');
                await loadUserData();
            } else {
                var err = await resp.json();
                showAlert('profileAlert', 'danger', err.message || 'Error al actualizar');
            }
        } catch (err) {
            showAlert('profileAlert', 'danger', 'Error al guardar los cambios');
        }
    });

    // Cambiar contraseña
    document.getElementById('changePasswordForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        var newPwd = document.getElementById('newPassword').value;
        var confirmPwd = document.getElementById('confirmNewPassword').value;

        if (newPwd !== confirmPwd) {
            showAlert('passwordAlert', 'danger', 'Las contraseñas no coinciden');
            return;
        }
        if (newPwd.length < 6) {
            showAlert('passwordAlert', 'danger', 'Mínimo 6 caracteres');
            return;
        }

        try {
            var token = localStorage.getItem('authToken');
            var resp = await fetch('/api/AuthApi/change-password', {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    currentPassword: document.getElementById('currentPassword').value,
                    newPassword: newPwd
                })
            });

            if (resp.ok) {
                showAlert('passwordAlert', 'success', 'Contraseña actualizada');
                this.reset();
            } else {
                var err = await resp.json();
                showAlert('passwordAlert', 'danger', err.message || 'Error al cambiar contraseña');
            }
        } catch (err) {
            showAlert('passwordAlert', 'danger', 'Error de conexión');
        }
    });

    // Cancelar
    document.getElementById('cancelBtn').addEventListener('click', function() {
        userData = JSON.parse(JSON.stringify(originalData));
        displayUserData();
    });

    // Avatar
    document.getElementById('changeAvatarBtn').addEventListener('click', function() {
        document.getElementById('avatarFile').click();
    });
    document.getElementById('avatarFile').addEventListener('change', async function(e) {
        if (!e.target.files.length) return;
        try {
            var token = localStorage.getItem('authToken');
            var fd = new FormData();
            fd.append('AvatarFile', e.target.files[0]);
            var resp = await fetch('/api/AuthApi/me', {
                method: 'PUT',
                headers: { 'Authorization': 'Bearer ' + token },
                body: fd
            });
            if (resp.ok) {
                showAlert('profileAlert', 'success', 'Avatar actualizado');
                await loadUserData();
            }
        } catch (err) {
            showAlert('profileAlert', 'danger', 'Error al subir avatar');
        }
    });

    document.addEventListener('DOMContentLoaded', loadUserData);
</script>
}
