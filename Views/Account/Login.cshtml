@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_Layout";
}

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-sm-10 col-md-7 col-lg-5">

      <!-- Logo + título -->
      <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center
                    rounded-circle bg-warning bg-opacity-25 mb-3"
             style="width:64px;height:64px">
          <i class="fas fa-birthday-cake fa-2x text-warning"></i>
        </div>
        <h2 class="fw-bold">Iniciar Sesión</h2>
        <p class="text-muted small">
          ¿No tenés cuenta?
          <a asp-action="Register" class="text-warning fw-semibold">Crear una nueva</a>
        </p>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-body p-4">

          <form id="loginForm" novalidate>

            <!-- Email -->
            <div class="mb-3">
              <label for="email" class="form-label fw-semibold">Email</label>
              <input id="email" name="email" type="email"
                     class="form-control" placeholder="tu@@email.com" required>
              <div id="emailError" class="text-danger small mt-1 d-none"></div>
            </div>

            <!-- Contraseña -->
            <div class="mb-3">
              <label for="password" class="form-label fw-semibold">Contraseña</label>
              <div class="input-group">
                <input id="password" name="password" type="password"
                       class="form-control" placeholder="Tu contraseña" required>
                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword()">
                  <i id="eyeIcon" class="fas fa-eye"></i>
                </button>
              </div>
              <div id="passwordError" class="text-danger small mt-1 d-none"></div>
            </div>

            <!-- Recordar + Olvidé -->
            <div class="d-flex justify-content-between align-items-center mb-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="rememberMe">
                <label class="form-check-label small" for="rememberMe">Recordar sesión</label>
              </div>
              <a asp-action="ForgotPassword" class="small text-warning fw-semibold">
                ¿Olvidaste tu contraseña?
              </a>
            </div>

            <!-- Alertas -->
            <div id="formError" class="alert alert-danger d-none py-2 small">
              <i class="fas fa-exclamation-circle me-2"></i><span id="errorMessage"></span>
            </div>
            <div id="formSuccess" class="alert alert-success d-none py-2 small">
              <i class="fas fa-check-circle me-2"></i><span id="successMessage"></span>
            </div>

            <!-- Botón -->
            <button type="submit" id="loginButton" class="btn btn-warning w-100 fw-semibold">
              <span id="loginButtonText">Iniciar Sesión</span>
              <span id="loginSpinner" class="spinner-border spinner-border-sm ms-2 d-none"></span>
            </button>
          </form>

          <hr class="my-4">
          <div class="text-center">
            <p class="text-muted small mb-2">¿No tenés cuenta todavía?</p>
            <a asp-action="Register" class="btn btn-outline-secondary w-100">
              <i class="fas fa-user-plus me-2"></i>Crear Cuenta
            </a>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
    function togglePassword() {
        var input = document.getElementById('password');
        var icon  = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }

    function clearErrors() {
        document.getElementById('emailError').classList.add('d-none');
        document.getElementById('passwordError').classList.add('d-none');
        document.getElementById('formError').classList.add('d-none');
        document.getElementById('formSuccess').classList.add('d-none');
    }

    function showFieldError(field, msg) {
        var el = document.getElementById(field + 'Error');
        el.textContent = msg;
        el.classList.remove('d-none');
    }

    function showFormError(msg) {
        document.getElementById('errorMessage').textContent = msg;
        document.getElementById('formError').classList.remove('d-none');
    }

    function showSuccess(msg) {
        document.getElementById('successMessage').textContent = msg;
        document.getElementById('formSuccess').classList.remove('d-none');
    }

    function setLoading(loading) {
        var btn  = document.getElementById('loginButton');
        var txt  = document.getElementById('loginButtonText');
        var spin = document.getElementById('loginSpinner');
        btn.disabled = loading;
        txt.textContent = loading ? 'Iniciando sesión...' : 'Iniciar Sesión';
        spin.classList.toggle('d-none', !loading);
    }

    document.getElementById('loginForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        clearErrors();

        var email    = document.getElementById('email').value.trim();
        var password = document.getElementById('password').value;

        // Validaciones
        if (!email) { showFieldError('email', 'El email es requerido'); return; }
        if (!password) { showFieldError('password', 'La contraseña es requerida'); return; }
        if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
            showFieldError('email', 'Ingresá un email válido');
            return;
        }

        setLoading(true);

        try {
            var resp = await fetch('/api/AuthApi/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: email, password: password })
            });

            // Si la respuesta no es JSON, algo salió mal
            var contentType = resp.headers.get('content-type') || '';
            if (!contentType.includes('application/json')) {
                throw new Error('El servidor no respondió correctamente. Status: ' + resp.status);
            }

            var data = await resp.json();

            if (!resp.ok) {
                throw new Error(data.message || 'Error ' + resp.status);
            }

            if (data.success) {
                // Guardar token y usuario
                localStorage.setItem('authToken', data.token);
                localStorage.setItem('user', JSON.stringify(data.user));

                // Guardar token en cookie para que JwtMiddleware lo lea
                
                document.cookie = 'authToken=' + data.token + '; path=/; SameSite=Strict; max-age=86400';

                showSuccess('¡Inicio de sesión exitoso! Redirigiendo...');

                setTimeout(function() {
                    // Verificar si venía de una página específica
                    var params = new URLSearchParams(window.location.search);
                    var returnUrl = params.get('returnUrl') || params.get('ReturnUrl') || '';
                    var tortaMatch = returnUrl.match(/\/Torta\/Details\/(\d+)/);

                    if (tortaMatch && data.user.rol === 'Comprador') {
                        window.location.href = '/Comprador/DashboardVue?verTorta=' + tortaMatch[1];
                    } else if (returnUrl && returnUrl.indexOf('Login') === -1) {
                        window.location.href = returnUrl;
                    } else if (data.user.rol === 'Vendedor') {
                        window.location.href = '/Vendedor/DashboardVue';
                    } else if (data.user.rol === 'Comprador') {
                        window.location.href = '/Comprador/DashboardVue';
                    } else if (data.user.rol === 'Admin') {
                        window.location.href = '/Admin';
                    } else {
                        window.location.href = '/';
                    }
                }, 1500);
            } else {
                throw new Error(data.message || 'Error al iniciar sesión');
            }

        } catch (err) {
            var msg = err.message;
            if (msg.indexOf('401') !== -1) msg = 'Email o contraseña incorrectos.';
            else if (msg.indexOf('500') !== -1) msg = 'Error del servidor. Intentá más tarde.';
            else if (msg.indexOf('fetch') !== -1) msg = 'Sin conexión. Verificá tu red.';
            showFormError(msg);
            setLoading(false);
        }
    });

    document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('email').focus();
    });
</script>
}
