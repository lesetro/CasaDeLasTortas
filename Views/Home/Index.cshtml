@model CasaDeLasTortas.Models.ViewModels.HomeViewModel
@{
    ViewData["Title"] = ViewBag.Title ?? "Casa de las Tortas";
    var tortas          = Model.Tortas;
    var tortasDestacadas = Model.TortasDestacadas;
    var paginacion      = Model.Paginacion;
    var filtros         = Model.Filtros;
    var estadisticas    = Model.Estadisticas;
}

<!-- ═══ HERO ═══ -->
<div class="py-5 text-white text-center"
     style="background: linear-gradient(135deg, #ec4899, #f97316)">
    <div class="container">
        <h1 class="display-4 fw-bold mb-2">🎂 Casa de las Tortas</h1>
        <p class="lead mb-4">Descubrí las mejores tortas artesanales de vendedores locales</p>

        <!-- Estadísticas -->
        <div class="row g-3 justify-content-center mb-4">
            <div class="col-6 col-md-3">
                <div class="bg-white bg-opacity-25 rounded-3 py-3">
                    <div class="h3 fw-bold mb-0">@estadisticas.TotalTortas</div>
                    <div class="small">Tortas Disponibles</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="bg-white bg-opacity-25 rounded-3 py-3">
                    <div class="h3 fw-bold mb-0">@estadisticas.TotalVendedores</div>
                    <div class="small">Vendedores</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="bg-white bg-opacity-25 rounded-3 py-3">
                    <div class="h3 fw-bold mb-0">@estadisticas.VentasHoy</div>
                    <div class="small">Ventas Hoy</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="bg-white bg-opacity-25 rounded-3 py-3">
                    <div class="h3 fw-bold mb-0">@estadisticas.TortasNuevas</div>
                    <div class="small">Tortas Nuevas</div>
                </div>
            </div>
        </div>

        <!-- Barra de búsqueda -->
        <div class="mx-auto" style="max-width:600px">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <div class="flex-grow-1 position-relative">
                    <input type="text" name="busqueda" id="searchInput"
                           value="@filtros.Busqueda"
                           placeholder="Buscar tortas, vendedores, categorías..."
                           class="form-control form-control-lg rounded-pill ps-4">
                    <div id="searchResults"
                         class="position-absolute start-0 end-0 mt-1 bg-white rounded-3 shadow d-none"
                         style="z-index:1000"></div>
                </div>
                <button type="submit"
                        class="btn btn-light fw-semibold rounded-pill px-4">
                    🔍 Buscar
                </button>
            </form>
        </div>
    </div>
</div>

<!-- ═══ TORTAS DESTACADAS ═══ -->
@if (tortasDestacadas != null && tortasDestacadas.Any())
{
    <div class="container py-5">
        <h2 class="fw-bold mb-4">⭐ Tortas Más Populares</h2>
        <div class="row g-3">
            @foreach (var torta in tortasDestacadas)
            {
                <div class="col-6 col-md-4 col-lg-2">
                    <a asp-controller="Torta" asp-action="Details" asp-route-id="@torta.Id"
                       class="text-decoration-none">
                        <div class="card h-100 shadow-sm border-0">
                            <img src="@(torta.ImagenPrincipal ?? "/images/default-cake.jpg")"
                                 class="card-img-top" style="height:140px;object-fit:cover"
                                 alt="@torta.Nombre">
                            <div class="card-body p-2">
                                <div class="small fw-bold text-truncate text-dark">@torta.Nombre</div>
                                <div class="small text-muted text-truncate">@torta.NombreVendedor</div>
                                <div class="fw-bold text-warning small">$@torta.Precio.ToString("N2")</div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
}

<!-- ═══ FILTROS + CATÁLOGO ═══ -->
<div class="container pb-5">
    <div class="row g-4">

        <!-- Sidebar filtros -->
        <div class="col-lg-3">
            <div class="card shadow-sm border-0 sticky-top" style="top:80px">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">🔍 Filtros</h5>
                    <form asp-action="Index" method="get" id="filterForm">
                        <input type="hidden" name="busqueda" value="@filtros.Busqueda">

                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Categoría</label>
                            <select name="categoria" class="form-select form-select-sm"
                                    onchange="this.form.submit()">
                                <option value="">Todas las categorías</option>
                                @foreach (var cat in filtros.CategoriasDisponibles)
                                {
                                    <option value="@cat" selected="@(cat == filtros.Categoria)">@cat</option>
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold small">Ordenar por</label>
                            <select name="ordenarPor" class="form-select form-select-sm"
                                    onchange="this.form.submit()">
                                <option value="Populares" selected="@(filtros.OrdenarPor == "Populares")">Más populares</option>
                                <option value="Nuevas" selected="@(filtros.OrdenarPor == "Nuevas")">Más recientes</option>
                                <option value="PrecioMenor" selected="@(filtros.OrdenarPor == "PrecioMenor")">Menor precio</option>
                                <option value="PrecioMayor" selected="@(filtros.OrdenarPor == "PrecioMayor")">Mayor precio</option>
                                <option value="Calificacion" selected="@(filtros.OrdenarPor == "Calificacion")">Mejor calificación</option>
                                <option value="Nombre" selected="@(filtros.OrdenarPor == "Nombre")">Nombre A-Z</option>
                            </select>
                        </div>

                        <a asp-action="Index" class="btn btn-outline-secondary w-100 btn-sm">
                            <i class="fas fa-times me-1"></i>Limpiar filtros
                        </a>
                    </form>
                </div>
            </div>
        </div>

        <!-- Grid de tortas -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">
                    @if (!string.IsNullOrEmpty(filtros.Busqueda))
                    { <span>Resultados para "@filtros.Busqueda"</span> }
                    else if (!string.IsNullOrEmpty(filtros.Categoria))
                    { <span>Categoría: @filtros.Categoria</span> }
                    else
                    { <span>Todas las Tortas</span> }
                </h4>
                <span class="badge bg-secondary">@paginacion.TotalItems tortas</span>
            </div>

            @if (tortas.Any())
            {
                <div class="row g-3">
                    @foreach (var torta in tortas)
                    {
                        <div class="col-sm-6 col-xl-4">
                            <a asp-controller="Torta" asp-action="Details"
                               asp-route-id="@torta.Id" class="text-decoration-none">
                                <div class="card h-100 shadow-sm border-0 @(!torta.Disponible ? "opacity-75" : "")">
                                    <div class="position-relative">
                                        <img src="@(torta.ImagenPrincipal ?? "/images/default-cake.jpg")"
                                             class="card-img-top"
                                             style="height:200px;object-fit:cover"
                                             alt="@torta.Nombre">
                                        @if (torta.EsNuevo)
                                        {
                                            <span class="position-absolute top-0 start-0 m-2 badge bg-success">✨ Nuevo</span>
                                        }
                                        @if (torta.EsPopular)
                                        {
                                            <span class="position-absolute top-0 end-0 m-2 badge bg-warning text-dark">🔥 Popular</span>
                                        }
                                        @if (!torta.Disponible)
                                        {
                                            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
                                                 style="background:rgba(0,0,0,.5)">
                                                <span class="badge bg-dark fs-6">No disponible</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="card-body">
                                        <h6 class="fw-bold text-dark text-truncate">@torta.Nombre</h6>
                                        <p class="text-muted small mb-2" style="height:38px;overflow:hidden">
                                            @torta.DescripcionCorta
                                        </p>
                                        @if (!string.IsNullOrEmpty(torta.Categoria))
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary mb-2">@torta.Categoria</span>
                                        }
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="h5 fw-bold text-warning mb-0">$@torta.Precio.ToString("N2")</span>
                                            <span class="small text-muted">⭐ @torta.Calificacion.ToString("F1")</span>
                                        </div>
                                        <div class="small text-muted mt-1">@torta.NombreVendedor</div>
                                    </div>
                                    @if (torta.Disponible)
                                    {
                                        <div class="card-footer bg-transparent border-0 pb-3 px-3">
                                            <div class="btn btn-warning w-100 btn-sm fw-semibold">
                                                Ver detalles
                                            </div>
                                        </div>
                                    }
                                </div>
                            </a>
                        </div>
                    }
                </div>

                <!-- Paginación -->
                <partial name="_PaginacionPartial" model="paginacion" />
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <div class="fs-1 mb-3">😕</div>
                    <h4>No se encontraron tortas</h4>
                    <p>Intentá con otros filtros o términos de búsqueda</p>
                    <a asp-action="Index" class="btn btn-warning px-4">Ver todas las tortas</a>
                </div>
            }
        </div>
    </div>
</div>

<!-- ═══ CTA REGISTRO ═══ -->
<div class="py-5 text-white text-center"
     style="background: linear-gradient(135deg, #f97316, #ec4899)">
    <div class="container">
        <h2 class="fw-bold mb-3">¿Sos vendedor de tortas?</h2>
        <p class="lead mb-4">Únete a nuestra plataforma y vendé tus tortas artesanales</p>
        <a asp-controller="Account" asp-action="Register"
           class="btn btn-light fw-semibold px-5 me-2">
            Registrarse como Vendedor
        </a>
        <a asp-controller="Account" asp-action="Register"
           class="btn btn-outline-light fw-semibold px-5">
            Registrarse como Comprador
        </a>
    </div>
</div>

@section Scripts {
<script>
    const searchInput   = document.getElementById('searchInput')
    const searchResults = document.getElementById('searchResults')
    let searchTimeout

    searchInput?.addEventListener('input', function () {
        clearTimeout(searchTimeout)
        const term = this.value.trim()
        if (term.length < 2) { searchResults.classList.add('d-none'); return }

        searchTimeout = setTimeout(() => {
            fetch(`/Home/BusquedaRapida?termino=${encodeURIComponent(term)}`)
                .then(r => r.json())
                .then(data => {
                    if (!data.length) { searchResults.classList.add('d-none'); return }
                    searchResults.innerHTML = data.map(t => `
                        <a href="${t.url}"
                           class="d-flex align-items-center gap-3 p-3 text-decoration-none text-dark border-bottom hover-bg">
                            <img src="${t.imagen || '/images/default-cake.jpg'}"
                                 class="rounded" style="width:44px;height:44px;object-fit:cover">
                            <div class="flex-grow-1">
                                <div class="fw-semibold small">${t.nombre}</div>
                                <div class="text-muted small">${t.vendedor}</div>
                            </div>
                            <span class="fw-bold text-warning small">$${t.precio.toFixed(2)}</span>
                        </a>`).join('')
                    searchResults.classList.remove('d-none')
                })
                .catch(() => {})
        }, 300)
    })

    document.addEventListener('click', e => {
        if (!searchInput?.contains(e.target)) searchResults?.classList.add('d-none')
    })
</script>
}
