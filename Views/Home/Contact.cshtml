@{
    ViewData["Title"] = "Contacto";
}

<!-- Hero -->
<div class="py-5 text-white text-center"
     style="background: linear-gradient(135deg, #3b82f6, #7c3aed)">
    <div class="container">
        <h1 class="display-5 fw-bold mb-2">📧 Contáctanos</h1>
        <p class="lead mb-0">Estamos aquí para ayudarte</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4">

        <!-- Formulario -->
        <div class="col-lg-6">
            <div class="card shadow border-0 h-100">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Envíanos un Mensaje</h4>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">✅ @TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">❌ @TempData["Error"]</div>
                    }

                    <form method="post" asp-controller="Home" asp-action="SendContact">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nombre Completo *</label>
                            <input type="text" name="nombre" class="form-control"
                                   placeholder="Tu nombre completo" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Correo Electrónico *</label>
                            <input type="email" name="email" class="form-control"
                                   placeholder="tu@email.com" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Teléfono</label>
                            <input type="tel" name="telefono" class="form-control"
                                   placeholder="+54 266 123-4567">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Asunto *</label>
                            <select name="asunto" class="form-select" required>
                                <option value="">Selecciona un asunto</option>
                                <option value="soporte-tecnico">Soporte Técnico</option>
                                <option value="consulta-venta">Consulta sobre Venta</option>
                                <option value="consulta-compra">Consulta sobre Compra</option>
                                <option value="sugerencia">Sugerencia</option>
                                <option value="reclamo">Reclamo</option>
                                <option value="otro">Otro</option>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Mensaje *</label>
                            <textarea name="mensaje" class="form-control" rows="5"
                                      placeholder="Describe tu consulta o comentario..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 fw-semibold">
                            <i class="fas fa-paper-plane me-2"></i>Enviar Mensaje
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Info de contacto -->
        <div class="col-lg-6 d-flex flex-column gap-4">

            <div class="card shadow border-0">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Información de Contacto</h4>
                    <div class="d-flex gap-3 mb-3">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:48px;height:48px">
                            <span class="fs-4">📍</span>
                        </div>
                        <div>
                            <div class="fw-semibold">Dirección</div>
                            <div class="text-muted small">
                                Av. Principal 123<br>Villa Mercedes, San Luis, Argentina (5730)
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 mb-3">
                        <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:48px;height:48px">
                            <span class="fs-4">📞</span>
                        </div>
                        <div>
                            <div class="fw-semibold">Teléfono</div>
                            <div class="text-muted small">
                                +54 266 123-4567<br>Lun - Vie: 9:00 AM - 6:00 PM
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-3">
                        <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:48px;height:48px">
                            <span class="fs-4">📧</span>
                        </div>
                        <div>
                            <div class="fw-semibold">Email</div>
                            <div class="text-muted small">
                                info@casadelastortas.com<br>soporte@casadelastortas.com
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow border-0" style="border-left:4px solid #f97316 !important">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">⏰ Horarios de Atención</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-semibold">Lunes - Viernes:</span>
                        <span class="text-muted">9:00 AM - 6:00 PM</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-semibold">Sábado:</span>
                        <span class="text-muted">10:00 AM - 2:00 PM</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">Domingo:</span>
                        <span class="text-muted">Cerrado</span>
                    </div>
                </div>
            </div>

            <div class="alert alert-info border-0 shadow-sm">
                <h6 class="fw-bold">⚡ Tiempo de Respuesta</h6>
                <p class="mb-0 small">
                    Respondemos todos los mensajes en un plazo máximo de
                    <strong>24 horas hábiles</strong>.
                </p>
            </div>
        </div>
    </div>
</div>

<!-- FAQ -->
<div class="bg-light py-5">
    <div class="container" style="max-width:800px">
        <h3 class="fw-bold text-center mb-4">❓ Preguntas Frecuentes</h3>
        <div class="accordion" id="faqAccordion">
            @{
                var faqs = new[] {
                    ("¿Cómo puedo registrarme como vendedor?",
                     "Hacé clic en \"Registrarse\" en el menú superior, seleccioná \"Vendedor\" y completá el formulario. Verificaremos tu cuenta en 24-48 horas."),
                    ("¿Es seguro comprar en la plataforma?",
                     "Sí, utilizamos encriptación SSL y todos los vendedores son verificados. Además, ofrecemos garantía en todas las transacciones."),
                    ("¿Cuáles son las formas de pago aceptadas?",
                     "Aceptamos transferencias bancarias, tarjetas de crédito/débito y billeteras virtuales. Los métodos específicos varían según el vendedor."),
                    ("¿Hacen entregas a domicilio?",
                     "La entrega depende de cada vendedor. Algunos ofrecen entrega a domicilio, otros requieren retiro en su local."),
                };
                int fi = 0;
            }
            @foreach (var faq in faqs)
            {
                fi++;
                <div class="accordion-item border-0 shadow-sm mb-2 rounded">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-semibold rounded"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#faq@(fi)">
                            @faq.Item1
                        </button>
                    </h2>
                    <div id="faq@(fi)" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-secondary">@faq.Item2</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
