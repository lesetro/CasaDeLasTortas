@{
    ViewData["Title"] = "Contacto";
}

<!-- Header -->
<section class="bg-gradient-to-r from-blue-500 to-purple-600 text-white py-16">
    <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl font-bold mb-4">📧 Contáctanos</h1>
        <p class="text-xl">Estamos aquí para ayudarte</p>
    </div>
</section>

<!-- Contenido Principal -->
<section class="container mx-auto px-4 py-16">
    <div class="grid md:grid-cols-2 gap-12 max-w-6xl mx-auto">
        
        <!-- Formulario de Contacto -->
        <div class="bg-white rounded-lg shadow-lg p-8">
            <h2 class="text-2xl font-bold text-gray-800 mb-6">Envíanos un Mensaje</h2>
            
            @if (TempData["Success"] != null)
            {
                <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
                    <p class="text-green-800">✅ @TempData["Success"]</p>
                </div>
            }
            
            @if (TempData["Error"] != null)
            {
                <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
                    <p class="text-red-800">❌ @TempData["Error"]</p>
                </div>
            }
            
            <form method="post" asp-controller="Home" asp-action="SendContact">
                <!-- Nombre -->
                <div class="mb-4">
                    <label for="nombre" class="block text-gray-700 font-semibold mb-2">
                        Nombre Completo *
                    </label>
                    <input type="text" 
                           id="nombre" 
                           name="nombre" 
                           required
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                           placeholder="Tu nombre completo" />
                </div>
                
                <!-- Email -->
                <div class="mb-4">
                    <label for="email" class="block text-gray-700 font-semibold mb-2">
                        Correo Electrónico *
                    </label>
                    <input type="email" 
                           id="email" 
                           name="email" 
                           required
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                           placeholder="tu@@email.com" />
                </div>
                
                <!-- Teléfono -->
                <div class="mb-4">
                    <label for="telefono" class="block text-gray-700 font-semibold mb-2">
                        Teléfono
                    </label>
                    <input type="tel" 
                           id="telefono" 
                           name="telefono"
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                           placeholder="+54 266 123-4567" />
                </div>
                
                <!-- Asunto -->
                <div class="mb-4">
                    <label for="asunto" class="block text-gray-700 font-semibold mb-2">
                        Asunto *
                    </label>
                    <select id="asunto" 
                            name="asunto" 
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                        <option value="">Selecciona un asunto</option>
                        <option value="soporte-tecnico">Soporte Técnico</option>
                        <option value="consulta-venta">Consulta sobre Venta</option>
                        <option value="consulta-compra">Consulta sobre Compra</option>
                        <option value="sugerencia">Sugerencia</option>
                        <option value="reclamo">Reclamo</option>
                        <option value="otro">Otro</option>
                    </select>
                </div>
                
                <!-- Mensaje -->
                <div class="mb-6">
                    <label for="mensaje" class="block text-gray-700 font-semibold mb-2">
                        Mensaje *
                    </label>
                    <textarea id="mensaje" 
                              name="mensaje" 
                              required
                              rows="6"
                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                              placeholder="Describe tu consulta o comentario..."></textarea>
                </div>
                
                <!-- Botón Enviar -->
                <button type="submit" 
                        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-300">
                    📤 Enviar Mensaje
                </button>
            </form>
        </div>
        
        <!-- Información de Contacto -->
        <div class="space-y-8">
            
            <!-- Info general -->
            <div class="bg-white rounded-lg shadow-lg p-8">
                <h2 class="text-2xl font-bold text-gray-800 mb-6">Información de Contacto</h2>
                
                <div class="space-y-6">
                    
                    <!-- Dirección -->
                    <div class="flex items-start gap-4">
                        <div class="bg-blue-100 rounded-full p-3 flex-shrink-0">
                            <span class="text-2xl">📍</span>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-800 mb-1">Dirección</h3>
                            <p class="text-gray-600">
                                Av. Principal 123<br />
                                Villa Mercedes, San Luis<br />
                                Argentina (5730)
                            </p>
                        </div>
                    </div>
                    
                    <!-- Teléfono -->
                    <div class="flex items-start gap-4">
                        <div class="bg-green-100 rounded-full p-3 flex-shrink-0">
                            <span class="text-2xl">📞</span>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-800 mb-1">Teléfono</h3>
                            <p class="text-gray-600">
                                +54 266 123-4567<br />
                                Lun - Vie: 9:00 AM - 6:00 PM
                            </p>
                        </div>
                    </div>
                    
                    <!-- Email -->
                    <div class="flex items-start gap-4">
                        <div class="bg-purple-100 rounded-full p-3 flex-shrink-0">
                            <span class="text-2xl">📧</span>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-800 mb-1">Email</h3>
                            <p class="text-gray-600">
                                info@@casadelastortas.com<br />
                                soporte@@casadelastortas.com
                            </p>
                        </div>
                    </div>
                    
                    <!-- Redes Sociales -->
                    <div class="flex items-start gap-4">
                        <div class="bg-pink-100 rounded-full p-3 flex-shrink-0">
                            <span class="text-2xl">💬</span>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-800 mb-2">Redes Sociales</h3>
                            <div class="flex gap-3">
                                <a href="#" class="bg-blue-600 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-blue-700 transition">
                                    f
                                </a>
                                <a href="#" class="bg-pink-600 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-pink-700 transition">
                                    📷
                                </a>
                                <a href="#" class="bg-blue-400 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-blue-500 transition">
                                    🐦
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Horarios de Atención -->
            <div class="bg-gradient-to-br from-orange-50 to-pink-50 rounded-lg shadow-lg p-8 border border-orange-200">
                <h3 class="text-xl font-bold text-gray-800 mb-4">⏰ Horarios de Atención</h3>
                <div class="space-y-2 text-gray-700">
                    <div class="flex justify-between">
                        <span class="font-semibold">Lunes - Viernes:</span>
                        <span>9:00 AM - 6:00 PM</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="font-semibold">Sábado:</span>
                        <span>10:00 AM - 2:00 PM</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="font-semibold">Domingo:</span>
                        <span>Cerrado</span>
                    </div>
                </div>
            </div>
            
            <!-- Tiempo de Respuesta -->
            <div class="bg-blue-50 rounded-lg shadow-lg p-8 border border-blue-200">
                <h3 class="text-xl font-bold text-gray-800 mb-4">⚡ Tiempo de Respuesta</h3>
                <p class="text-gray-700">
                    Nos esforzamos por responder todos los mensajes en un plazo máximo de 
                    <strong>24 horas hábiles</strong>. Para consultas urgentes, llámanos 
                    directamente.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Preguntas Frecuentes -->
<section class="bg-gray-100 py-16">
    <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold text-gray-800 text-center mb-8">❓ Preguntas Frecuentes</h2>
        
        <div class="space-y-4">
            
            <details class="bg-white rounded-lg shadow-md p-6">
                <summary class="font-semibold text-gray-800 cursor-pointer">
                    ¿Cómo puedo registrarme como vendedor?
                </summary>
                <p class="text-gray-600 mt-4">
                    Haz clic en "Registrarse" en el menú superior, selecciona "Vendedor" y 
                    completa el formulario con tu información. Verificaremos tu cuenta en 24-48 horas.
                </p>
            </details>
            
            <details class="bg-white rounded-lg shadow-md p-6">
                <summary class="font-semibold text-gray-800 cursor-pointer">
                    ¿Es seguro comprar en la plataforma?
                </summary>
                <p class="text-gray-600 mt-4">
                    Sí, utilizamos encriptación SSL y todos los vendedores son verificados. 
                    Además, ofrecemos garantía en todas las transacciones.
                </p>
            </details>
            
            <details class="bg-white rounded-lg shadow-md p-6">
                <summary class="font-semibold text-gray-800 cursor-pointer">
                    ¿Cuáles son las formas de pago aceptadas?
                </summary>
                <p class="text-gray-600 mt-4">
                    Aceptamos transferencias bancarias, tarjetas de crédito/débito y billeteras 
                    virtuales. Los métodos específicos varían según el vendedor.
                </p>
            </details>
            
            <details class="bg-white rounded-lg shadow-md p-6">
                <summary class="font-semibold text-gray-800 cursor-pointer">
                    ¿Hacen entregas a domicilio?
                </summary>
                <p class="text-gray-600 mt-4">
                    La entrega depende de cada vendedor. Algunos ofrecen entrega a domicilio, 
                    otros requieren retiro en su local. Revisa los detalles en cada publicación.
                </p>
            </details>
        </div>
    </div>
</section>

<!-- Mapa (Placeholder) -->
<section class="py-16">
    <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-800 text-center mb-8">📍 Encuéntranos</h2>
        <div class="max-w-4xl mx-auto bg-gray-200 rounded-lg h-96 flex items-center justify-center">
            <p class="text-gray-600">[ Aquí iría un mapa de Google Maps ]</p>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Validación adicional del formulario
        document.querySelector('form').addEventListener('submit', function(e) {
            const email = document.getElementById('email').value;
            const mensaje = document.getElementById('mensaje').value;
            
            if (!email.includes('@@')) {
                e.preventDefault();
                alert('Por favor, ingresa un email válido');
                return;
            }
            
            if (mensaje.length < 10) {
                e.preventDefault();
                alert('El mensaje debe tener al menos 10 caracteres');
                return;
            }
        });
    </script>
}
