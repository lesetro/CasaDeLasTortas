@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="min-h-screen flex items-center justify-center bg-gray-100 px-4">
    <div class="max-w-2xl w-full bg-white rounded-lg shadow-xl p-8 text-center">
        <!-- Emoji de error -->
        <div class="text-8xl mb-6">😕</div>
        
        <!-- Título -->
        <h1 class="text-4xl font-bold text-gray-800 mb-4">
            ¡Oops! Algo salió mal
        </h1>
        
        <!-- Mensaje -->
        <p class="text-xl text-gray-600 mb-8">
            Lo sentimos, ha ocurrido un error inesperado. Nuestro equipo ha sido notificado.
        </p>
        
        <!-- Detalles del error (solo en desarrollo) -->
        @if (Model?.ShowRequestId ?? false)
        {
            <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-left">
                <h3 class="font-semibold text-red-800 mb-2">Detalles técnicos:</h3>
                <p class="text-sm text-red-700 font-mono">
                    <strong>Request ID:</strong> @Model.RequestId
                </p>
            </div>
        }
        
        <!-- Mensaje de TempData si existe -->
        @if (TempData["Error"] != null)
        {
            <div class="bg-orange-50 border border-orange-200 rounded-lg p-4 mb-6">
                <p class="text-orange-800">@TempData["Error"]</p>
            </div>
        }
        
        <!-- Acciones -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a asp-controller="Home" asp-action="Index" 
               class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-3 rounded-lg font-semibold transition">
                🏠 Volver al inicio
            </a>
            
            <button onclick="window.history.back()" 
                    class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-8 py-3 rounded-lg font-semibold transition">
                ← Página anterior
            </button>
        </div>
        
        <!-- Información adicional -->
        <div class="mt-8 pt-8 border-t border-gray-200">
            <p class="text-sm text-gray-500 mb-4">
                Si el problema persiste, puedes:
            </p>
            <div class="flex flex-wrap gap-4 justify-center text-sm">
                <a asp-controller="Home" asp-action="Contact" class="text-orange-600 hover:underline">
                    📧 Contactar soporte
                </a>
                <span class="text-gray-300">|</span>
                <a href="javascript:location.reload()" class="text-orange-600 hover:underline">
                    🔄 Recargar página
                </a>
                <span class="text-gray-300">|</span>
                <a asp-controller="Home" asp-action="About" class="text-orange-600 hover:underline">
                    ℹ️ Más información
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Log del error al servidor (opcional)
        console.error('Error page loaded:', '@Model?.RequestId');
    </script>
}
