@model IEnumerable<dynamic>
@{
    var titulo = ViewBag.TituloSeccion ?? "⭐ Tortas Más Populares";
    var subtitulo = ViewBag.Subtitulo ?? "";
    var mostrarTodas = ViewBag.MostrarLinkTodas ?? true;
    var cantidad = Model?.Count() ?? 0;
}

@if (cantidad > 0)
{
    <section class="container mx-auto px-4 mb-12">
        
        <!-- Header de la Sección -->
        <div class="flex justify-between items-center mb-6">
            <div>
                <h2 class="text-3xl font-bold text-gray-800 flex items-center gap-2">
                    @titulo
                </h2>
                @if (!string.IsNullOrEmpty(subtitulo))
                {
                    <p class="text-gray-600 mt-2">@subtitulo</p>
                }
            </div>
            
            @if (mostrarTodas)
            {
                <a asp-controller="Home" asp-action="Index" 
                   class="text-orange-600 hover:text-orange-700 font-semibold flex items-center gap-2 group">
                    Ver todas
                    <span class="transform group-hover:translate-x-1 transition">→</span>
                </a>
            }
        </div>
        
        <!-- Grid de Tortas Destacadas -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4">
            @foreach (var torta in Model)
            {
                <div class="bg-white rounded-lg shadow-md hover:shadow-xl transition duration-300 transform hover:-translate-y-2 group">
                    <a asp-controller="Torta" asp-action="Details" asp-route-id="@torta.Id" class="block">
                        
                        <!-- Imagen -->
                        <div class="relative overflow-hidden rounded-t-lg">
                            <img src="@(torta.ImagenPrincipal ?? "/images/default-cake.jpg")" 
                                 alt="@torta.Nombre" 
                                 class="w-full h-40 object-cover transition duration-300 group-hover:scale-110" 
                                 onerror="this.src='/images/default-cake.jpg'" />
                            
                            <!-- Overlay sutil en hover -->
                            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition duration-300"></div>
                            
                            <!-- Badge de posición (opcional) -->
                            @if (ViewBag.MostrarRanking == true)
                            {
                                var index = Model.ToList().IndexOf(torta) + 1;
                                var badgeColor = index == 1 ? "bg-yellow-500" : index == 2 ? "bg-gray-400" : index == 3 ? "bg-orange-600" : "bg-blue-500";
                                
                                <div class="absolute top-2 left-2 @badgeColor text-white rounded-full w-8 h-8 flex items-center justify-center font-bold text-sm shadow-lg">
                                    #@index
                                </div>
                            }
                            
                            <!-- Badge de popular -->
                            <div class="absolute top-2 right-2 bg-orange-500 text-white text-xs px-2 py-1 rounded-full shadow-md">
                                🔥
                            </div>
                        </div>
                        
                        <!-- Contenido -->
                        <div class="p-3">
                            <!-- Nombre -->
                            <h3 class="font-semibold text-sm truncate mb-2 group-hover:text-orange-600 transition" title="@torta.Nombre">
                                @torta.Nombre
                            </h3>
                            
                            <!-- Rating y Vendedor -->
                            <div class="flex items-center gap-1 text-xs text-gray-600 mb-2">
                                <span class="flex items-center gap-1">
                                    <span class="text-yellow-500">⭐</span>
                                    <span class="font-semibold">@torta.Calificacion.ToString("F1")</span>
                                </span>
                                <span class="text-gray-400">•</span>
                                <span class="truncate" title="@torta.NombreVendedor">
                                    @torta.NombreVendedor
                                </span>
                            </div>
                            
                            <!-- Precio -->
                            <div class="flex justify-between items-center">
                                <p class="text-orange-600 font-bold text-lg">
                                    $@torta.Precio.ToString("N2")
                                </p>
                                
                                <!-- Mini botón -->
                                <div class="bg-orange-500 text-white rounded-full w-8 h-8 flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                                    <span class="text-xs">→</span>
                                </div>
                            </div>
                            
                            <!-- Veces vendida (opcional) -->
                            @if (torta.VecesVendida != null && torta.VecesVendida > 0)
                            {
                                <div class="mt-2 text-xs text-gray-500 flex items-center gap-1">
                                    <span>📦</span>
                                    <span>@torta.VecesVendida vendidas</span>
                                </div>
                            }
                        </div>
                    </a>
                </div>
            }
        </div>
        
        <!-- Controles de Navegación (Carrusel opcional) -->
        @if (ViewBag.MostrarControlesCarrusel == true && cantidad > 6)
        {
            <div class="flex justify-center gap-4 mt-6">
                <button id="destacadas-prev" 
                        class="bg-white hover:bg-gray-100 text-gray-800 rounded-full p-3 shadow-md transition">
                    ← Anterior
                </button>
                <button id="destacadas-next" 
                        class="bg-white hover:bg-gray-100 text-gray-800 rounded-full p-3 shadow-md transition">
                    Siguiente →
                </button>
            </div>
        }
    </section>
}
else
{
    <!-- Sin tortas destacadas -->
    <section class="container mx-auto px-4 mb-12">
        <div class="bg-gray-100 rounded-lg p-8 text-center">
            <div class="text-5xl mb-4">🎂</div>
            <h3 class="text-xl font-semibold text-gray-700 mb-2">
                No hay tortas destacadas disponibles
            </h3>
            <p class="text-gray-600">
                Pronto tendremos nuevas tortas para ti
            </p>
        </div>
    </section>
}

@section Scripts {
    @if (ViewBag.MostrarControlesCarrusel == true && cantidad > 6)
    {
        <script>
            // Script simple de carrusel (opcional - se puede mejorar con Swiper.js)
            document.addEventListener('DOMContentLoaded', function() {
                const container = document.querySelector('.grid');
                const prevBtn = document.getElementById('destacadas-prev');
                const nextBtn = document.getElementById('destacadas-next');
                
                if (container && prevBtn && nextBtn) {
                    let scrollAmount = 0;
                    const scrollStep = 300;
                    
                    prevBtn.addEventListener('click', function() {
                        scrollAmount = Math.max(0, scrollAmount - scrollStep);
                        container.scrollTo({
                            left: scrollAmount,
                            behavior: 'smooth'
                        });
                    });
                    
                    nextBtn.addEventListener('click', function() {
                        scrollAmount = Math.min(container.scrollWidth, scrollAmount + scrollStep);
                        container.scrollTo({
                            left: scrollAmount,
                            behavior: 'smooth'
                        });
                    });
                }
            });
        </script>
    }
}
