@model dynamic
@{
    var filtros = Model.Filtros ?? Model;
    var busqueda = filtros.Busqueda ?? "";
    var categoria = filtros.Categoria ?? "";
    var ordenarPor = filtros.OrdenarPor ?? "Populares";
    var categoriasDisponibles = filtros.CategoriasDisponibles ?? new List<string>();
    
    // Filtros adicionales opcionales
    var precioMinimo = filtros.PrecioMinimo ?? null;
    var precioMaximo = filtros.PrecioMaximo ?? null;
    var soloDisponibles = filtros.SoloDisponibles ?? true;
    var calificacionMinima = filtros.CalificacionMinima ?? null;
    
    var mostrarFiltrosAvanzados = ViewBag.MostrarFiltrosAvanzados ?? false;
}

<aside class="lg:w-64 flex-shrink-0">
    <div class="bg-white rounded-lg shadow-md p-6 sticky top-4">
        
        <!-- Header del Panel -->
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                🔍 Filtros
            </h3>
            
            <!-- Botón limpiar filtros (solo si hay filtros activos) -->
            @if (!string.IsNullOrEmpty(busqueda) || !string.IsNullOrEmpty(categoria) || ordenarPor != "Populares")
            {
                <a asp-action="Index" 
                   class="text-xs text-orange-600 hover:text-orange-700 font-semibold"
                   title="Limpiar todos los filtros">
                    Limpiar
                </a>
            }
        </div>
        
        <form asp-action="Index" method="get" id="filterForm" class="space-y-6">
            
            <!-- Mantener búsqueda actual -->
            @if (!string.IsNullOrEmpty(busqueda))
            {
                <input type="hidden" name="busqueda" value="@busqueda" />
            }
            
            <!-- Filtro: Categorías -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">
                    📂 Categoría
                </label>
                <select name="categoria" 
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent text-sm"
                        onchange="this.form.submit()">
                    <option value="">Todas las categorías</option>
                    @foreach (var cat in categoriasDisponibles)
                    {
                        <option value="@cat" selected="@(cat == categoria)">
                            @cat
                        </option>
                    }
                </select>
            </div>
            
            <!-- Filtro: Ordenar por -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">
                    📊 Ordenar por
                </label>
                <select name="ordenarPor" 
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent text-sm"
                        onchange="this.form.submit()">
                    <option value="Populares" selected="@(ordenarPor == "Populares")">
                        🔥 Más populares
                    </option>
                    <option value="Nuevas" selected="@(ordenarPor == "Nuevas")">
                        ✨ Más recientes
                    </option>
                    <option value="PrecioMenor" selected="@(ordenarPor == "PrecioMenor")">
                        💵 Menor precio
                    </option>
                    <option value="PrecioMayor" selected="@(ordenarPor == "PrecioMayor")">
                        💰 Mayor precio
                    </option>
                    <option value="Calificacion" selected="@(ordenarPor == "Calificacion")">
                        ⭐ Mejor calificación
                    </option>
                    <option value="Nombre" selected="@(ordenarPor == "Nombre")">
                        🔤 Nombre A-Z
                    </option>
                </select>
            </div>
            
            @if (mostrarFiltrosAvanzados)
            {
                <!-- Divisor -->
                <div class="border-t border-gray-200 my-4"></div>
                
                <!-- Filtros Avanzados -->
                <div class="space-y-4">
                    <div class="text-sm font-semibold text-gray-700 mb-3">
                        Filtros Avanzados
                    </div>
                    
                    <!-- Rango de Precio -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-600 mb-2">
                            💵 Rango de Precio
                        </label>
                        <div class="flex gap-2 items-center">
                            <input type="number" 
                                   name="precioMinimo" 
                                   value="@precioMinimo"
                                   placeholder="Min"
                                   min="0"
                                   step="100"
                                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-orange-500" />
                            <span class="text-gray-500">-</span>
                            <input type="number" 
                                   name="precioMaximo" 
                                   value="@precioMaximo"
                                   placeholder="Max"
                                   min="0"
                                   step="100"
                                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-orange-500" />
                        </div>
                    </div>
                    
                    <!-- Calificación Mínima -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-600 mb-2">
                            ⭐ Calificación mínima
                        </label>
                        <div class="flex gap-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var isSelected = calificacionMinima != null && calificacionMinima == i;
                                <button type="button" 
                                        class="star-filter @(isSelected ? "bg-yellow-500 text-white" : "bg-gray-200 text-gray-600") hover:bg-yellow-400 hover:text-white px-2 py-1 rounded text-xs transition"
                                        onclick="setCalificacion(@i)">
                                    @i★
                                </button>
                            }
                        </div>
                        <input type="hidden" name="calificacionMinima" id="calificacionMinima" value="@calificacionMinima" />
                    </div>
                    
                    <!-- Checkbox: Solo Disponibles -->
                    <div class="flex items-center gap-2">
                        <input type="checkbox" 
                               name="soloDisponibles" 
                               id="soloDisponibles"
                               checked="@soloDisponibles"
                               class="w-4 h-4 text-orange-600 border-gray-300 rounded focus:ring-orange-500" 
                               onchange="this.form.submit()" />
                        <label for="soloDisponibles" class="text-sm text-gray-700 cursor-pointer">
                            Solo productos disponibles
                        </label>
                    </div>
                </div>
                
                <!-- Botón Aplicar Filtros Avanzados -->
                <button type="submit" 
                        class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2 rounded-lg transition mt-4">
                    Aplicar filtros
                </button>
            }
            
            <!-- Divisor -->
            <div class="border-t border-gray-200"></div>
            
            <!-- Botón Limpiar Filtros -->
            <a asp-action="Index" 
               class="block w-full text-center bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 rounded-lg transition">
                🔄 Limpiar todos los filtros
            </a>
        </form>
        
        <!-- Información adicional -->
        <div class="mt-6 p-4 bg-orange-50 rounded-lg border border-orange-200">
            <div class="text-xs font-semibold text-orange-800 mb-2">
                💡 Consejo
            </div>
            <p class="text-xs text-orange-700">
                Usa los filtros para encontrar exactamente lo que buscas. 
                Las tortas más populares son las que más han vendido.
            </p>
        </div>
        
        <!-- Filtros aplicados -->
        @if (!string.IsNullOrEmpty(categoria) || ordenarPor != "Populares" || precioMinimo != null || precioMaximo != null || calificacionMinima != null)
        {
            <div class="mt-6">
                <div class="text-xs font-semibold text-gray-700 mb-2">
                    Filtros activos:
                </div>
                <div class="flex flex-wrap gap-2">
                    @if (!string.IsNullOrEmpty(categoria))
                    {
                        <span class="inline-flex items-center gap-1 bg-purple-100 text-purple-800 text-xs px-2 py-1 rounded-full">
                            @categoria
                            <a href="@Url.Action("Index", new { busqueda, ordenarPor })" class="hover:text-purple-900">✕</a>
                        </span>
                    }
                    
                    @if (ordenarPor != "Populares")
                    {
                        <span class="inline-flex items-center gap-1 bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full">
                            @ordenarPor
                            <a href="@Url.Action("Index", new { busqueda, categoria })" class="hover:text-blue-900">✕</a>
                        </span>
                    }
                    
                    @if (precioMinimo != null || precioMaximo != null)
                    {
                        <span class="inline-flex items-center gap-1 bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full">
                            $@(precioMinimo ?? 0) - $@(precioMaximo ?? "∞")
                            <a href="@Url.Action("Index", new { busqueda, categoria, ordenarPor })" class="hover:text-green-900">✕</a>
                        </span>
                    }
                    
                    @if (calificacionMinima != null)
                    {
                        <span class="inline-flex items-center gap-1 bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded-full">
                            @calificacionMinima★+
                            <a href="@Url.Action("Index", new { busqueda, categoria, ordenarPor })" class="hover:text-yellow-900">✕</a>
                        </span>
                    }
                </div>
            </div>
        }
    </div>
</aside>

@section Scripts {
    @if (mostrarFiltrosAvanzados)
    {
        <script>
            function setCalificacion(rating) {
                const input = document.getElementById('calificacionMinima');
                const currentValue = parseInt(input.value) || 0;
                
                // Toggle: si ya está seleccionada, desmarcar
                if (currentValue === rating) {
                    input.value = '';
                } else {
                    input.value = rating;
                }
                
                // Actualizar estilos de botones
                document.querySelectorAll('.star-filter').forEach((btn, index) => {
                    const btnRating = index + 1;
                    if (input.value && btnRating <= parseInt(input.value)) {
                        btn.classList.add('bg-yellow-500', 'text-white');
                        btn.classList.remove('bg-gray-200', 'text-gray-600');
                    } else {
                        btn.classList.remove('bg-yellow-500', 'text-white');
                        btn.classList.add('bg-gray-200', 'text-gray-600');
                    }
                });
                
                // Auto-submit
                document.getElementById('filterForm').submit();
            }
        </script>
    }
}
