@{
    ViewData["Title"] = "Acerca de Nosotros";
}

<!-- Hero Section -->
<section class="bg-gradient-to-r from-pink-500 to-orange-400 text-white py-20">
    <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-bold mb-4">🎂 Casa de las Tortas</h1>
        <p class="text-2xl">Conectando vendedores artesanales con amantes de las tortas</p>
    </div>
</section>

<!-- Nuestra Historia -->
<section class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-800 mb-4">Nuestra Historia</h2>
        <div class="w-20 h-1 bg-orange-500 mx-auto"></div>
    </div>
    
    <div class="bg-white rounded-lg shadow-lg p-8 mb-12">
        <p class="text-lg text-gray-700 leading-relaxed mb-4">
            Casa de las Tortas nació en 2024 con una misión simple pero poderosa: 
            <strong>conectar a talentosos vendedores artesanales de tortas con personas que buscan 
            productos únicos y de calidad.</strong>
        </p>
        
        <p class="text-lg text-gray-700 leading-relaxed mb-4">
            Comenzamos en Villa Mercedes, San Luis, Argentina, observando que muchos vendedores 
            artesanales con increíbles habilidades no tenían una plataforma adecuada para mostrar 
            sus creaciones. Al mismo tiempo, los compradores buscaban tortas especiales más allá 
            de las opciones comerciales tradicionales.
        </p>
        
        <p class="text-lg text-gray-700 leading-relaxed">
            Hoy, somos el puente que une estas necesidades, creando una comunidad vibrante donde 
            cada torta cuenta una historia y cada compra apoya a un emprendedor local.
        </p>
    </div>
</section>

<!-- Nuestra Misión y Visión -->
<section class="bg-gray-100 py-16">
    <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
            
            <!-- Misión -->
            <div class="bg-white rounded-lg shadow-lg p-8">
                <div class="text-5xl text-center mb-4">🎯</div>
                <h3 class="text-2xl font-bold text-gray-800 text-center mb-4">Nuestra Misión</h3>
                <p class="text-gray-700 leading-relaxed text-center">
                    Empoderar a los vendedores artesanales de tortas proporcionándoles una 
                    plataforma digital accesible, mientras ofrecemos a los compradores una 
                    experiencia única para descubrir y adquirir productos excepcionales.
                </p>
            </div>
            
            <!-- Visión -->
            <div class="bg-white rounded-lg shadow-lg p-8">
                <div class="text-5xl text-center mb-4">🌟</div>
                <h3 class="text-2xl font-bold text-gray-800 text-center mb-4">Nuestra Visión</h3>
                <p class="text-gray-700 leading-relaxed text-center">
                    Ser la plataforma líder en Argentina para la venta de tortas artesanales, 
                    reconocida por nuestra comunidad inclusiva, calidad excepcional y apoyo 
                    constante a los emprendedores locales.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Valores -->
<section class="container mx-auto px-4 py-16">
    <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-800 mb-4">Nuestros Valores</h2>
        <div class="w-20 h-1 bg-orange-500 mx-auto"></div>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        
        <div class="bg-white rounded-lg shadow-md p-6 text-center hover:shadow-xl transition">
            <div class="text-5xl mb-4">🤝</div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Comunidad</h3>
            <p class="text-gray-600">
                Fomentamos conexiones auténticas entre vendedores y compradores.
            </p>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-6 text-center hover:shadow-xl transition">
            <div class="text-5xl mb-4">✨</div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Calidad</h3>
            <p class="text-gray-600">
                Promovemos estándares altos en cada producto ofrecido.
            </p>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-6 text-center hover:shadow-xl transition">
            <div class="text-5xl mb-4">🚀</div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Innovación</h3>
            <p class="text-gray-600">
                Mejoramos constantemente nuestra plataforma y servicios.
            </p>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-6 text-center hover:shadow-xl transition">
            <div class="text-5xl mb-4">💚</div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Confianza</h3>
            <p class="text-gray-600">
                Garantizamos transparencia y seguridad en cada transacción.
            </p>
        </div>
    </div>
</section>

<!-- ¿Por qué elegirnos? -->
<section class="bg-gradient-to-r from-orange-400 to-pink-500 text-white py-16">
    <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-12">
            <h2 class="text-4xl font-bold mb-4">¿Por Qué Elegirnos?</h2>
        </div>
        
        <div class="grid md:grid-cols-3 gap-8">
            
            <div class="text-center">
                <div class="bg-white bg-opacity-20 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4 backdrop-blur-sm">
                    <span class="text-4xl">👨‍🍳</span>
                </div>
                <h3 class="text-xl font-bold mb-2">Vendedores Verificados</h3>
                <p class="opacity-90">
                    Todos nuestros vendedores pasan por un proceso de verificación para garantizar calidad.
                </p>
            </div>
            
            <div class="text-center">
                <div class="bg-white bg-opacity-20 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4 backdrop-blur-sm">
                    <span class="text-4xl">🔒</span>
                </div>
                <h3 class="text-xl font-bold mb-2">Pagos Seguros</h3>
                <p class="opacity-90">
                    Sistema de pagos encriptado que protege tu información financiera.
                </p>
            </div>
            
            <div class="text-center">
                <div class="bg-white bg-opacity-20 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4 backdrop-blur-sm">
                    <span class="text-4xl">💬</span>
                </div>
                <h3 class="text-xl font-bold mb-2">Soporte Dedicado</h3>
                <p class="opacity-90">
                    Equipo de atención al cliente disponible para ayudarte en cada paso.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Estadísticas -->
<section class="container mx-auto px-4 py-16">
    <div class="bg-white rounded-lg shadow-xl p-8 max-w-5xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
            
            <div>
                <div class="text-4xl font-bold text-orange-600 mb-2">500+</div>
                <div class="text-gray-600">Tortas Vendidas</div>
            </div>
            
            <div>
                <div class="text-4xl font-bold text-pink-600 mb-2">50+</div>
                <div class="text-gray-600">Vendedores Activos</div>
            </div>
            
            <div>
                <div class="text-4xl font-bold text-purple-600 mb-2">1000+</div>
                <div class="text-gray-600">Clientes Satisfechos</div>
            </div>
            
            <div>
                <div class="text-4xl font-bold text-blue-600 mb-2">4.8★</div>
                <div class="text-gray-600">Calificación Promedio</div>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section class="container mx-auto px-4 py-16 text-center">
    <div class="max-w-3xl mx-auto">
        <h2 class="text-4xl font-bold text-gray-800 mb-6">
            ¿Listo para Empezar?
        </h2>
        <p class="text-xl text-gray-600 mb-8">
            Ya sea que quieras vender tus creaciones o encontrar la torta perfecta, 
            ¡únete a nuestra comunidad hoy!
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a asp-controller="Account" asp-action="Register" 
               class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-4 rounded-lg text-lg font-semibold transition">
                Registrarse como Vendedor
            </a>
            <a asp-controller="Home" asp-action="Index" 
               class="bg-pink-500 hover:bg-pink-600 text-white px-8 py-4 rounded-lg text-lg font-semibold transition">
                Explorar Tortas
            </a>
        </div>
    </div>
</section>

<!-- Contacto rápido -->
<section class="bg-gray-100 py-12">
    <div class="container mx-auto px-4 text-center">
        <p class="text-lg text-gray-700 mb-4">
            ¿Tienes alguna pregunta? Estamos aquí para ayudarte.
        </p>
        <a asp-controller="Home" asp-action="Contact" 
           class="inline-block bg-gray-800 hover:bg-gray-900 text-white px-8 py-3 rounded-lg font-semibold transition">
            Contáctanos
        </a>
    </div>
</section>
