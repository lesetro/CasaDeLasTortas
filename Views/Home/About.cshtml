@{
    ViewData["Title"] = "Acerca de Nosotros";
}

<!-- Hero -->
<div class="py-5 text-white text-center"
     style="background: linear-gradient(135deg, #ec4899, #f97316)">
    <div class="container">
        <h1 class="display-5 fw-bold mb-2">🎂 Casa de las Tortas</h1>
        <p class="lead mb-0">Conectando vendedores artesanales con amantes de las tortas</p>
    </div>
</div>

<!-- Nuestra Historia -->
<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold">Nuestra Historia</h2>
        <div class="mx-auto mt-2 rounded" style="width:60px;height:4px;background:#f97316"></div>
    </div>
    <div class="card shadow border-0 p-4 p-md-5 mx-auto" style="max-width:800px">
        <p class="lead text-secondary">
            Casa de las Tortas nació en 2024 con una misión simple pero poderosa:
            <strong>conectar a talentosos vendedores artesanales de tortas con personas
            que buscan productos únicos y de calidad.</strong>
        </p>
        <p class="text-secondary">
            Comenzamos en Villa Mercedes, San Luis, Argentina, observando que muchos vendedores
            artesanales con increíbles habilidades no tenían una plataforma adecuada para mostrar
            sus creaciones. Al mismo tiempo, los compradores buscaban tortas especiales más allá
            de las opciones comerciales tradicionales.
        </p>
        <p class="text-secondary mb-0">
            Hoy, somos el puente que une estas necesidades, creando una comunidad vibrante donde
            cada torta cuenta una historia y cada compra apoya a un emprendedor local.
        </p>
    </div>
</div>

<!-- Misión y Visión -->
<div class="bg-light py-5">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-5">
                <div class="card h-100 shadow border-0 text-center p-4">
                    <div class="fs-1 mb-3">🎯</div>
                    <h3 class="fw-bold h4">Nuestra Misión</h3>
                    <p class="text-secondary mb-0">
                        Empoderar a los vendedores artesanales de tortas proporcionándoles una
                        plataforma digital accesible, mientras ofrecemos a los compradores una
                        experiencia única para descubrir y adquirir productos excepcionales.
                    </p>
                </div>
            </div>
            <div class="col-md-5">
                <div class="card h-100 shadow border-0 text-center p-4">
                    <div class="fs-1 mb-3">🌟</div>
                    <h3 class="fw-bold h4">Nuestra Visión</h3>
                    <p class="text-secondary mb-0">
                        Ser la plataforma líder en Argentina para la venta de tortas artesanales,
                        reconocida por nuestra comunidad inclusiva, calidad excepcional y apoyo
                        constante a los emprendedores locales.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Valores -->
<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold">Nuestros Valores</h2>
        <div class="mx-auto mt-2 rounded" style="width:60px;height:4px;background:#f97316"></div>
    </div>
    <div class="row g-4 justify-content-center">
        @foreach (var val in new[] {
            ("🤝","Comunidad","Fomentamos conexiones auténticas entre vendedores y compradores."),
            ("✨","Calidad","Promovemos estándares altos en cada producto ofrecido."),
            ("🚀","Innovación","Mejoramos constantemente nuestra plataforma y servicios."),
            ("💚","Confianza","Garantizamos transparencia y seguridad en cada transacción."),
        })
        {
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100 shadow-sm border-0 text-center p-4">
                    <div class="fs-1 mb-3">@val.Item1</div>
                    <h5 class="fw-bold">@val.Item2</h5>
                    <p class="text-secondary small mb-0">@val.Item3</p>
                </div>
            </div>
        }
    </div>
</div>

<!-- Por qué elegirnos -->
<div class="py-5 text-white"
     style="background: linear-gradient(135deg, #f97316, #ec4899)">
    <div class="container text-center">
        <h2 class="fw-bold mb-5">¿Por Qué Elegirnos?</h2>
        <div class="row g-4 justify-content-center">
            @foreach (var item in new[] {
                ("👨‍🍳","Vendedores Verificados","Todos nuestros vendedores pasan por un proceso de verificación para garantizar calidad."),
                ("🔒","Pagos Seguros","Sistema de pagos encriptado que protege tu información financiera."),
                ("💬","Soporte Dedicado","Equipo de atención al cliente disponible para ayudarte en cada paso."),
            })
            {
                <div class="col-md-4">
                    <div class="bg-white bg-opacity-10 rounded-3 p-4">
                        <div class="fs-1 mb-3">@item.Item1</div>
                        <h5 class="fw-bold">@item.Item2</h5>
                        <p class="mb-0 opacity-90 small">@item.Item3</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Estadísticas -->
<div class="container py-5">
    <div class="card shadow border-0 p-4 p-md-5">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <div class="h2 fw-bold text-warning">500+</div>
                <div class="text-muted small">Tortas Vendidas</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="h2 fw-bold text-danger">50+</div>
                <div class="text-muted small">Vendedores Activos</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="h2 fw-bold text-primary">1000+</div>
                <div class="text-muted small">Clientes Satisfechos</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="h2 fw-bold text-success">4.8★</div>
                <div class="text-muted small">Calificación Promedio</div>
            </div>
        </div>
    </div>
</div>

<!-- CTA -->
<div class="bg-light py-5 text-center">
    <div class="container">
        <h2 class="fw-bold mb-3">¿Listo para Empezar?</h2>
        <p class="text-muted mb-4">
            Ya sea que quieras vender tus creaciones o encontrar la torta perfecta,
            ¡únete a nuestra comunidad hoy!
        </p>
        <a asp-controller="Account" asp-action="Register"
           class="btn btn-warning fw-semibold px-4 me-2">
            Registrarse como Vendedor
        </a>
        <a asp-controller="Home" asp-action="Index"
           class="btn btn-outline-warning fw-semibold px-4">
            Explorar Tortas
        </a>
    </div>
</div>
