@{
    ViewData["Title"] = "Dashboard Comprador";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Casa de las Tortas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
</head>
<body>
    <div id="app">
        <div class="d-flex justify-content-center align-items-center vh-100 bg-light">
            <div class="text-center">
                <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem"></div>
                <h5 class="text-muted">Iniciando Panel del Comprador...</h5>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        toastr.options = { closeButton: true, progressBar: true, positionClass: "toast-top-right", timeOut: "5000" };

        if (!localStorage.getItem('authToken')) {
            window.location.href = '/Account/Login';
        }
    </script>

    <!-- Bundle compilado por Vite - mismo patrón que vendedor.bundle.js -->
    <script type="module" src="~/js/dist/comprador.bundle.js"></script>
</body>
</html>
