@model CasaDeLasTortas.Models.ViewModels.AdminUsuariosViewModel
@{
    ViewData["Title"] = "Gestión de Usuarios - Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    body { background-color: #f1f5f9; }
    .admin-main { margin-left: 260px; padding: 2rem; }
    .filter-card { border: none; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .user-table th { font-size: .76rem; text-transform: uppercase; letter-spacing: .06em; color: #94a3b8; font-weight: 600; border: none; padding: .75rem 1rem; }
    .user-table td { vertical-align: middle; border-color: #f1f5f9; padding: .75rem 1rem; }
    .user-table tr:last-child td { border-bottom: none; }
    .user-table tbody tr:hover { background-color: #f8fafc; }
    .avatar-circle { width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: .88rem; flex-shrink: 0; }
    @@media (max-width: 991px) { .admin-main { margin-left: 0; padding: 1rem; } }
</style>
}

<partial name="_AdminSidebar" />

<div class="admin-main">

    <!-- Encabezado -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fw-bold mb-0" style="font-size:1.6rem;">
                <i class="fas fa-users text-primary me-2"></i>Gestión de Usuarios
            </h1>
            <p class="text-muted mb-0 small">Administrá compradores, vendedores y administradores</p>
        </div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Dashboard
        </a>
    </div>

    <!-- Alertas -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 rounded-3 shadow-sm p-3">
                <div class="text-muted small mb-1">👥 Total Usuarios</div>
                <div class="fs-2 fw-bold">@Model.Estadisticas.TotalUsuarios</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 rounded-3 shadow-sm p-3">
                <div class="text-muted small mb-1">🛒 Compradores</div>
                <div class="fs-2 fw-bold text-primary">@Model.Estadisticas.TotalCompradores</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 rounded-3 shadow-sm p-3">
                <div class="text-muted small mb-1">🏪 Vendedores</div>
                <div class="fs-2 fw-bold text-success">@Model.Estadisticas.TotalVendedores</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 rounded-3 shadow-sm p-3">
                <div class="text-muted small mb-1">🛡️ Admins</div>
                <div class="fs-2 fw-bold text-danger">@Model.Estadisticas.TotalAdmins</div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card filter-card mb-4">
        <div class="card-body p-3">
            <form method="get" asp-action="Usuarios" class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label small fw-semibold text-muted mb-1">Buscar</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fas fa-search text-muted small"></i>
                        </span>
                        <input type="text" name="busqueda" value="@Model.Busqueda"
                               placeholder="Nombre o email…"
                               class="form-control border-start-0 ps-0" />
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label small fw-semibold text-muted mb-1">Rol</label>
                    <select name="filtroRol" class="form-select">
                        <option value="">Todos</option>
                        <option value="Admin"     selected="@(Model.FiltroRol == "Admin")">Admin</option>
                        <option value="Vendedor"  selected="@(Model.FiltroRol == "Vendedor")">Vendedor</option>
                        <option value="Comprador" selected="@(Model.FiltroRol == "Comprador")">Comprador</option>
                        <option value="SinRol"    selected="@(Model.FiltroRol == "SinRol")">Sin rol</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label small fw-semibold text-muted mb-1">Estado</label>
                    <select name="activo" class="form-select">
                        <option value="">Todos</option>
                        <option value="true"  selected="@(Model.FiltroActivo == true)">Activos</option>
                        <option value="false" selected="@(Model.FiltroActivo == false)">Inactivos</option>
                    </select>
                </div>
                <div class="col-12 col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-filter me-1"></i> Filtrar
                    </button>
                    <a asp-action="Usuarios" class="btn btn-outline-secondary">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabla de usuarios -->
    <div class="card border-0 rounded-3 shadow-sm">
        @if (Model.Usuarios.Any())
        {
            <div class="table-responsive">
                <table class="table user-table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Usuario</th>
                            <th>Email</th>
                            <th class="text-center">Rol</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Registrado</th>
                            <th class="text-center">Último acceso</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var usuario in Model.Usuarios)
                        {
                            var avatarBg = usuario.Rol switch {
                                "Admin"     => "#fef2f2",
                                "Vendedor"  => "#f0fdf4",
                                "Comprador" => "#eff6ff",
                                _           => "#f8fafc"
                            };
                            var avatarColor = usuario.Rol switch {
                                "Admin"     => "#ef4444",
                                "Vendedor"  => "#22c55e",
                                "Comprador" => "#3b82f6",
                                _           => "#94a3b8"
                            };
                            var badgeClass = usuario.Rol switch {
                                "Admin"     => "bg-danger",
                                "Vendedor"  => "bg-success",
                                "Comprador" => "bg-primary",
                                _           => "bg-secondary"
                            };
                            var iconoRol = usuario.Rol switch {
                                "Admin"     => "fas fa-shield-alt",
                                "Vendedor"  => "fas fa-store",
                                "Comprador" => "fas fa-shopping-bag",
                                _           => "fas fa-user"
                            };

                            <tr>
                                <!-- Nombre -->
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(usuario.Avatar))
                                        {
                                            <img src="@usuario.Avatar" class="avatar-circle border" style="object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <div class="avatar-circle" style="background:@avatarBg;color:@avatarColor;">
                                                @usuario.Nombre.Substring(0, 1).ToUpper()
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-semibold small">@usuario.NombreCompleto</div>
                                            @if (!string.IsNullOrEmpty(usuario.NombreComercial))
                                            {
                                                <div class="text-muted" style="font-size:.7rem;">
                                                    <i class="fas fa-store me-1"></i>@usuario.NombreComercial
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <!-- Email -->
                                <td class="text-muted small">@usuario.Email</td>

                                <!-- Rol -->
                                <td class="text-center">
                                    <span class="badge @badgeClass rounded-pill px-3 py-2">
                                        <i class="@iconoRol me-1"></i>@usuario.Rol
                                    </span>
                                </td>

                                <!-- Estado -->
                                <td class="text-center">
                                    @if (usuario.Activo)
                                    {
                                        <span class="badge bg-success-subtle text-success rounded-pill px-3 border border-success-subtle">
                                            <i class="fas fa-circle me-1" style="font-size:.5rem;"></i>Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3 border border-secondary-subtle">
                                            <i class="fas fa-circle me-1" style="font-size:.5rem;"></i>Inactivo
                                        </span>
                                    }
                                </td>

                                <!-- Fechas -->
                                <td class="text-center text-muted small">
                                    @usuario.FechaRegistro.ToString("dd/MM/yy")
                                </td>
                                <td class="text-center text-muted small">
                                    @(usuario.UltimoAcceso.HasValue
                                        ? usuario.UltimoAcceso.Value.ToString("dd/MM/yy HH:mm")
                                        : "—")
                                </td>

                                <!-- Acciones -->
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <form asp-action="CambiarEstadoUsuario" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id"   value="@usuario.PersonaId" />
                                            <input type="hidden" name="tipo" value="@usuario.Rol" />
                                            <button type="submit"
                                                    class="btn btn-sm @(usuario.Activo ? "btn-outline-secondary" : "btn-outline-success")"
                                                    title="@(usuario.Activo ? "Desactivar" : "Activar")"
                                                    onclick="return confirm('@(usuario.Activo ? "¿Desactivar este usuario?" : "¿Activar este usuario?")')">
                                                <i class="fas @(usuario.Activo ? "fa-ban" : "fa-check")"></i>
                                            </button>
                                        </form>

                                        @if (usuario.Rol == "Vendedor" && usuario.VendedorId.HasValue)
                                        {
                                            <a asp-controller="Vendedor" asp-action="Index"
                                               asp-route-id="@usuario.VendedorId"
                                               class="btn btn-sm btn-outline-primary" title="Ver vendedor">
                                                <i class="fas fa-store"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Persona" asp-action="Details"
                                               asp-route-id="@usuario.PersonaId"
                                               class="btn btn-sm btn-outline-primary" title="Ver perfil">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Paginación -->
            @if (Model.TotalPaginas > 1)
            {
                <div class="card-footer bg-white border-0 px-4 py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-muted small">
                            Mostrando @((Model.PaginaActual - 1) * Model.TamanioPagina + 1)–
                            @(Math.Min(Model.PaginaActual * Model.TamanioPagina, Model.TotalRegistros))
                            de @Model.TotalRegistros usuarios
                        </div>
                        <nav>
                            <ul class="pagination pagination-sm mb-0 gap-1">
                                <li class="page-item @(Model.PaginaActual <= 1 ? "disabled" : "")">
                                    <a class="page-link rounded"
                                       asp-action="Usuarios"
                                       asp-route-pagina="@(Model.PaginaActual - 1)"
                                       asp-route-busqueda="@Model.Busqueda"
                                       asp-route-filtroRol="@Model.FiltroRol">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int pg = Math.Max(1, Model.PaginaActual - 2);
                                          pg <= Math.Min(Model.TotalPaginas, Model.PaginaActual + 2);
                                          pg++)
                                {
                                    <li class="page-item @(pg == Model.PaginaActual ? "active" : "")">
                                        <a class="page-link rounded"
                                           asp-action="Usuarios"
                                           asp-route-pagina="@pg"
                                           asp-route-busqueda="@Model.Busqueda"
                                           asp-route-filtroRol="@Model.FiltroRol">@pg</a>
                                    </li>
                                }
                                <li class="page-item @(Model.PaginaActual >= Model.TotalPaginas ? "disabled" : "")">
                                    <a class="page-link rounded"
                                       asp-action="Usuarios"
                                       asp-route-pagina="@(Model.PaginaActual + 1)"
                                       asp-route-busqueda="@Model.Busqueda"
                                       asp-route-filtroRol="@Model.FiltroRol">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-users-slash fa-3x text-muted mb-3 d-block"></i>
                <h6 class="fw-semibold text-muted">No se encontraron usuarios</h6>
                <p class="text-muted small">Probá con otros filtros</p>
                <a asp-action="Usuarios" class="btn btn-outline-primary btn-sm">Limpiar filtros</a>
            </div>
        }
    </div>

</div>
