@model IEnumerable<CasaDeLasTortas.Models.Entities.LiberacionFondos>
@using CasaDeLasTortas.Models.Entities
@inject CasaDeLasTortas.Services.IFileService FileService
@{
    ViewData["Title"] = "Liberar Fondos - Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var countPendiente  = (int)(ViewBag.CountPendiente  ?? 0);
    var totalPendiente  = (decimal)(ViewBag.TotalPendiente ?? 0m);
    var countLiberado   = (int)(ViewBag.CountLiberado   ?? 0);
    var totalLiberado   = (decimal)(ViewBag.TotalLiberado  ?? 0m);

    var ventasPendientesEntrega = ViewBag.VentasPendientesEntrega as IEnumerable<Venta>
                                  ?? Enumerable.Empty<Venta>();
    var ventasEntregadas        = ViewBag.VentasEntregadas as IEnumerable<Venta>
                                  ?? Enumerable.Empty<Venta>();
    var liberacionesListas      = ViewBag.LiberacionesListas
                                  as IEnumerable<CasaDeLasTortas.Models.Entities.LiberacionFondos>
                                  ?? Enumerable.Empty<CasaDeLasTortas.Models.Entities.LiberacionFondos>();
    var historial               = ViewBag.HistorialLiberaciones as IEnumerable<LiberacionFondos>
                                  ?? Enumerable.Empty<LiberacionFondos>();
}

@section Styles {
<style>
    body { background-color: #f1f5f9; }
    .admin-main  { margin-left: 260px; padding: 2rem; }
    .kpi-card    { border: none; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.07); }
    .step-card   { border: none; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.07); }
    .lib-table th { font-size:.75rem; text-transform:uppercase; letter-spacing:.07em; color:#94a3b8; font-weight:600; border:none; }
    .lib-table td { vertical-align:middle; border-color:#f1f5f9; font-size:.875rem; }
    .lib-table tr:last-child td { border-bottom:none; }
    .flujo-circle { width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;flex-shrink:0; }
    @@media (max-width:991px){ .admin-main{ margin-left:0;padding:1rem; } }
</style>
}

<partial name="_AdminSidebar" />

<div class="admin-main">

    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0" style="font-size:1.6rem;">
                <i class="fas fa-hand-holding-usd text-success me-2"></i>Liberar Fondos
            </h1>
            <p class="text-muted mb-0 small">
                Confirmá la entrega y luego transferí el dinero a cada vendedor
            </p>
        </div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Dashboard
        </a>
    </div>

    <!-- Alertas -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 rounded-3 shadow-sm mb-4 alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 rounded-3 shadow-sm mb-4 alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Diagrama del flujo -->
    <div class="card border-0 rounded-3 shadow-sm mb-4" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);">
        <div class="card-body py-3 px-4">
            <div class="d-flex flex-wrap align-items-center gap-3">
                <div class="d-flex align-items-center gap-2">
                    <div class="flujo-circle bg-success text-white">1</div>
                    <span class="small fw-semibold">Comprador pagó</span>
                </div>
                <i class="fas fa-chevron-right text-muted"></i>
                <div class="d-flex align-items-center gap-2">
                    <div class="flujo-circle bg-success text-white">2</div>
                    <span class="small fw-semibold">Admin verificó</span>
                </div>
                <i class="fas fa-chevron-right text-muted"></i>
                <div class="d-flex align-items-center gap-2">
                    <div class="flujo-circle bg-warning text-dark">3</div>
                    <span class="small fw-semibold text-warning">⬅ Confirmar entrega</span>
                </div>
                <i class="fas fa-chevron-right text-muted"></i>
                <div class="d-flex align-items-center gap-2">
                    <div class="flujo-circle bg-warning text-dark">4</div>
                    <span class="small fw-semibold text-warning">Liberar fondos</span>
                </div>
            </div>
        </div>
    </div>

    <!-- KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="kpi-card card p-3">
                <div class="text-muted small mb-1">⏳ Pendientes total</div>
                <div class="fs-2 fw-bold text-warning">@countPendiente</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card card p-3">
                <div class="text-muted small mb-1">💰 Monto a liberar</div>
                <div class="fs-2 fw-bold text-primary">$@totalPendiente.ToString("N0")</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card card p-3">
                <div class="text-muted small mb-1">✅ Liberadas</div>
                <div class="fs-2 fw-bold text-success">@countLiberado</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card card p-3">
                <div class="text-muted small mb-1">💸 Total liberado</div>
                <div class="fs-2 fw-bold text-success">$@totalLiberado.ToString("N0")</div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════
         PASO 3: CONFIRMAR ENTREGA
         Ventas con pago verificado esperando confirmación de entrega
    ═══════════════════════════════════════════════ -->
    <div class="step-card card mb-4">
        <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
            <div class="d-flex align-items-center gap-2">
                <div class="flujo-circle bg-warning text-dark" style="width:26px;height:26px;font-size:.75rem;">3</div>
                <h6 class="fw-bold mb-0">
                    Confirmar entrega al comprador
                    <span class="badge bg-warning text-dark ms-2">@ventasPendientesEntrega.Count()</span>
                </h6>
            </div>
            <p class="text-muted small mb-0 mt-1 ms-1">
                El botón se habilita automáticamente cuando el <strong>vendedor</strong> marca todos los productos como entregados.
                Las filas en amarillo están esperando confirmación del vendedor.
            </p>
        </div>
        <div class="card-body px-4 pb-4 pt-2">
            @if (ventasPendientesEntrega.Any())
            {
                <div class="table-responsive">
                    <table class="table lib-table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Orden</th>
                                <th>Comprador</th>
                                <th>Vendedor(es)</th>
                                <th class="text-end">Total</th>
                                <th class="text-center">Productos (estado vendedor)</th>
                                <th class="text-center">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in ventasPendientesEntrega)
                            {
                                var detalles = v.Detalles?.ToList() ?? new List<DetalleVenta>();
                                var todosEntregados = detalles.Any() && detalles.All(d => d.Estado == EstadoDetalleVenta.Entregado);
                                var vendedores = detalles
                                    .GroupBy(d => d.Vendedor?.NombreComercial ?? "N/A")
                                    .Select(g => g.Key)
                                    .ToList();

                                <tr class="@(todosEntregados ? "" : "table-warning")">
                                    <td class="ps-3">
                                        <div class="fw-semibold">#@v.NumeroOrden</div>
                                        <div class="text-muted" style="font-size:.72rem;">@v.FechaVenta.ToString("dd/MM/yy")</div>
                                    </td>
                                    <td>
                                        <div class="small">@(v.Comprador?.Persona?.Nombre ?? "—")</div>
                                        <div class="text-muted" style="font-size:.72rem;">@(v.Comprador?.Persona?.Email ?? "")</div>
                                    </td>
                                    <td>
                                        @foreach (var vend in vendedores)
                                        {
                                            <span class="badge bg-light text-dark me-1 mb-1" style="font-size:.72rem;">@vend</span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold text-success">$@v.Total.ToString("N0")</td>
                                    <td class="text-center">
                                        @if (!detalles.Any())
                                        {
                                            <span class="text-muted small">Sin productos</span>
                                        }
                                        else
                                        {
                                            @foreach (var det in detalles)
                                            {
                                                var (badgeClass, icono) = det.Estado switch
                                                {
                                                    EstadoDetalleVenta.Entregado     => ("bg-success",     "✅"),
                                                    EstadoDetalleVenta.Listo         => ("bg-info",        "📦"),
                                                    EstadoDetalleVenta.EnPreparacion => ("bg-primary",     "👨‍🍳"),
                                                    EstadoDetalleVenta.Confirmado    => ("bg-secondary",   "✔️"),
                                                    EstadoDetalleVenta.Cancelado     => ("bg-danger",      "❌"),
                                                    _                                => ("bg-warning text-dark", "⏳")
                                                };
                                                <div class="d-flex align-items-center gap-1 mb-1">
                                                    <span class="badge @badgeClass" style="font-size:.68rem;">
                                                        @icono @det.Estado
                                                    </span>
                                                    <span class="text-muted" style="font-size:.68rem;">
                                                        @(det.Torta?.Nombre ?? $"#{det.TortaId}")
                                                    </span>
                                                </div>
                                            }
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (todosEntregados)
                                        {
                                            <form asp-action="ConfirmarEntrega" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="ventaId" value="@v.Id" />
                                                <button type="submit" class="btn btn-sm btn-warning fw-semibold"
                                                        onclick="return confirm('¿Confirmar que la orden #@v.NumeroOrden fue entregada al comprador?')">
                                                    <i class="fas fa-check me-1"></i>Confirmar entrega
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-secondary fw-semibold" disabled
                                                    title="El vendedor aún no marcó todos los productos como Entregado">
                                                <i class="fas fa-clock me-1"></i>Esperando vendedor
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-check-circle text-success fa-2x mb-3 d-block"></i>
                    <p class="text-muted mb-0 small">No hay ventas esperando confirmación de entrega.</p>
                </div>
            }
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════
         PASO 4: LIBERAR FONDOS
         Liberaciones listas para transferir al vendedor
    ═══════════════════════════════════════════════ -->
    <div class="step-card card mb-4">
        <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
            <div class="d-flex align-items-center gap-2">
                <div class="flujo-circle bg-success text-white" style="width:26px;height:26px;font-size:.75rem;">4</div>
                <h6 class="fw-bold mb-0">
                    Liberar fondos a vendedores
                    <span class="badge bg-success ms-2">@liberacionesListas.Count()</span>
                </h6>
            </div>
            <p class="text-muted small mb-0 mt-1 ms-1">
                Transferí el monto neto a cada vendedor y adjuntá el comprobante.
            </p>
        </div>
        <div class="card-body px-4 pb-4 pt-2">
            @if (liberacionesListas.Any())
            {
                <div class="table-responsive">
                    <table class="table lib-table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Vendedor</th>
                                <th>Orden</th>
                                <th class="text-end">Venta bruta</th>
                                <th class="text-end">Comisión</th>
                                <th class="text-end text-success fw-bold">A transferir</th>
                                <th class="text-center">Datos bancarios</th>
                                <th class="text-center">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lib in liberacionesListas)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="fw-semibold small">@(lib.Vendedor?.NombreComercial ?? "—")</div>
                                        <div class="text-muted" style="font-size:.7rem;">@(lib.Vendedor?.Persona?.Email ?? "")</div>
                                    </td>
                                    <td>
                                        <div class="fw-semibold small">#@(lib.Venta?.NumeroOrden ?? "—")</div>
                                        <div class="text-muted" style="font-size:.7rem;">@lib.FechaListoParaLiberar?.ToString("dd/MM/yy")</div>
                                    </td>
                                    <td class="text-end small">$@lib.MontoBruto.ToString("N0")</td>
                                    <td class="text-end text-danger small">-$@lib.Comision.ToString("N0")</td>
                                    <td class="text-end fw-bold text-success fs-6">$@lib.MontoNeto.ToString("N0")</td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(lib.Vendedor?.AliasCBU))
                                        {
                                            <div style="font-size:.72rem;">
                                                <i class="fas fa-university me-1 text-muted"></i>
                                                <strong>@lib.Vendedor.AliasCBU</strong>
                                            </div>
                                            <div class="text-muted" style="font-size:.68rem;">@lib.Vendedor?.Banco</div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger" style="font-size:.68rem;">Sin datos</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="ProcesarLiberacion" asp-route-id="@lib.Id"
                                           class="btn btn-sm btn-success fw-semibold">
                                            <i class="fas fa-paper-plane me-1"></i>Transferir
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-hand-holding-usd text-muted fa-2x mb-3 d-block"></i>
                    <p class="text-muted mb-0 small">No hay liberaciones listas.</p>
                    <p class="text-muted" style="font-size:.78rem;">
                        Aparecerán acá después de confirmar la entrega de una orden.
                    </p>
                </div>
            }
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════
         HISTORIAL
    ═══════════════════════════════════════════════ -->
    <div class="step-card card">
        <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
            <h6 class="fw-bold mb-0">
                <i class="fas fa-history text-muted me-2"></i>Historial de liberaciones
            </h6>
        </div>
        <div class="card-body px-4 pb-4 pt-2">
            @if (historial.Any())
            {
                <div class="table-responsive">
                    <table class="table lib-table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Vendedor</th>
                                <th>Orden</th>
                                <th class="text-end">Monto transferido</th>
                                <th class="text-center">Fecha</th>
                                <th class="text-center">Comprobante</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lib in historial)
                            {
                                var comprobanteUrl = !string.IsNullOrEmpty(lib.ArchivoComprobante)
                                    ? FileService.GetFileUrl(lib.ArchivoComprobante) : null;
                                <tr>
                                    <td class="ps-3 fw-semibold small">@(lib.Vendedor?.Persona?.Nombre ?? lib.Vendedor?.NombreComercial ?? "—")</td>
                                    <td class="text-muted small">#@(lib.Venta?.NumeroOrden ?? "—")</td>
                                    <td class="text-end fw-bold text-success">$@lib.MontoNeto.ToString("N0")</td>
                                    <td class="text-center text-muted small">@((lib.FechaTransferencia ?? lib.FechaConfirmacion)?.ToString("dd/MM/yy") ?? "—")</td>
                                    <td class="text-center">
                                        @if (comprobanteUrl != null)
                                        {
                                            <a href="@comprobanteUrl" target="_blank"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-file-image"></i>
                                            </a>
                                        }
                                        else { <span class="text-muted small">—</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center small py-3 mb-0">No hay liberaciones procesadas aún.</p>
            }
        </div>
    </div>

</div>
