@model CasaDeLasTortas.Models.ViewModels.AdminConfiguracionViewModel
@{
    ViewData["Title"] = "Configuración - Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var cfg = Model?.Configuracion;
}

@section Styles {
<style>
    body { background-color: #f1f5f9; }
    .admin-main { margin-left: 260px; padding: 2rem; }
    .cfg-card   { border: none; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.07); }
    .cfg-section-title { font-size:.7rem; text-transform:uppercase; letter-spacing:.1em; color:#94a3b8; font-weight:700; margin-bottom:.75rem; }
    .preview-pago { border: 2px dashed #d1d5db; border-radius: 12px; padding: 1.5rem; background: #fff; }
    @@media (max-width:991px){ .admin-main{ margin-left:0; padding:1rem; } }
</style>
}

<partial name="_AdminSidebar" />

<div class="admin-main">

    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0" style="font-size:1.6rem;">
                <i class="fas fa-cog text-secondary me-2"></i>Configuración de la Plataforma
            </h1>
            <p class="text-muted mb-0 small">Datos bancarios y parámetros que se muestran a compradores y vendedores</p>
        </div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Dashboard
        </a>
    </div>

    <!-- Alertas -->
    @if (!string.IsNullOrEmpty(Model?.MensajeExito))
    {
        <div class="alert alert-success border-0 rounded-3 shadow-sm mb-4 alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@Model.MensajeExito
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model?.MensajeError))
    {
        <div class="alert alert-danger border-0 rounded-3 shadow-sm mb-4 alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@Model.MensajeError
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 rounded-3 shadow-sm mb-4 alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 rounded-3 shadow-sm mb-4 alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- Formulario -->
        <div class="col-lg-7">
            <form asp-action="GuardarConfiguracion" method="post">
                @Html.AntiForgeryToken()
                @if (cfg != null)
                {
                    <input type="hidden" name="Id" value="@cfg.Id" />
                }

                <!-- Datos de la plataforma -->
                <div class="cfg-card card p-4 mb-4">
                    <div class="cfg-section-title">
                        <i class="fas fa-store me-1"></i>Datos de la plataforma
                    </div>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold small">Nombre de la plataforma</label>
                            <input type="text" name="NombrePlataforma" class="form-control"
                                   value="@(cfg?.NombrePlataforma ?? "Casa de las Tortas")" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Estado</label>
                            <div class="form-check form-switch mt-2">
                                <input type="checkbox" class="form-check-input" name="PlataformaActiva" 
                                       id="chkActiva" @(cfg?.PlataformaActiva == true ? "checked" : "") />
                                <label class="form-check-label small" for="chkActiva">Activa</label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Datos bancarios -->
                <div class="cfg-card card p-4 mb-4">
                    <div class="cfg-section-title">
                        <i class="fas fa-university me-1"></i>Datos bancarios de la plataforma
                    </div>
                    <p class="text-muted small mb-3">
                        Estos datos se muestran al comprador al finalizar su compra.
                        El dinero debe llegar a esta cuenta para que el Admin pueda verificarlo.
                    </p>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small">
                                Alias <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="fas fa-at text-muted"></i>
                                </span>
                                <input type="text" name="AliasCBU" class="form-control"
                                       value="@(cfg?.AliasCBU ?? "")"
                                       placeholder="casadelastortas.pagos"
                                       required />
                            </div>
                            <div class="form-text">Lo que el comprador escribe en el campo "Alias" al hacer la transferencia.</div>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold small">CBU</label>
                            <input type="text" name="CBU" class="form-control font-monospace"
                                   value="@(cfg?.CBU ?? "")"
                                   placeholder="0000000000000000000000"
                                   maxlength="22" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Banco <span class="text-danger">*</span></label>
                            <select name="Banco" class="form-select">
                                @foreach (var banco in Model?.BancosDisponibles ?? new List<string>())
                                {
                                    <option value="@banco" selected="@(cfg?.Banco == banco)">@banco</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Titular de la cuenta <span class="text-danger">*</span></label>
                            <input type="text" name="TitularCuenta" class="form-control"
                                   value="@(cfg?.TitularCuenta ?? "")"
                                   placeholder="Ej: Casa de las Tortas SRL" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">CUIT</label>
                            <input type="text" name="CUIT" class="form-control"
                                   value="@(cfg?.CUIT ?? "")"
                                   placeholder="XX-XXXXXXXX-X" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Imagen QR (URL)</label>
                            <input type="text" name="ImagenQR" class="form-control"
                                   value="@(cfg?.ImagenQR ?? "")"
                                   placeholder="https://..." />
                        </div>
                    </div>
                </div>

                <!-- Parámetros del marketplace -->
                <div class="cfg-card card p-4 mb-4">
                    <div class="cfg-section-title">
                        <i class="fas fa-percentage me-1"></i>Parámetros del marketplace
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">
                                Comisión de la plataforma (%) <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input type="number" name="ComisionPorcentaje" class="form-control"
                                       value="@(cfg?.ComisionPorcentaje.ToString("N1") ?? "10")"
                                       min="0" max="50" step="0.5" required />
                                <span class="input-group-text bg-white">%</span>
                            </div>
                            <div class="form-text">Se descuenta del subtotal de cada vendedor al liberar fondos.</div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Días para liberar fondos</label>
                            <div class="input-group">
                                <input type="number" name="DiasParaLiberarFondos" class="form-control"
                                       value="@(cfg?.DiasParaLiberarFondos ?? 3)"
                                       min="1" max="30" />
                                <span class="input-group-text bg-white">días</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Días límite de pago</label>
                            <div class="input-group">
                                <input type="number" name="DiasLimitePago" class="form-control"
                                       value="@(cfg?.DiasLimitePago ?? 3)"
                                       min="1" max="10" />
                                <span class="input-group-text bg-white">días</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Máx. intentos rechazados</label>
                            <div class="input-group">
                                <input type="number" name="MaxIntentosRechazados" class="form-control"
                                       value="@(cfg?.MaxIntentosRechazados ?? 3)"
                                       min="1" max="10" />
                                <span class="input-group-text bg-white">intentos</span>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold small">Instrucciones de pago (checkout)</label>
                            <textarea name="InstruccionesPago" class="form-control" rows="2"
                                      placeholder="Ej: Una vez verificado su pago, recibirá confirmación en su email en 1 día hábil.">@(cfg?.InstruccionesPago ?? "")</textarea>
                        </div>
                    </div>
                </div>

                <!-- Contacto -->
                <div class="cfg-card card p-4 mb-4">
                    <div class="cfg-section-title">
                        <i class="fas fa-envelope me-1"></i>Contacto de soporte
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Email de notificaciones</label>
                            <input type="email" name="EmailNotificaciones" class="form-control"
                                   value="@(cfg?.EmailNotificaciones ?? "")"
                                   placeholder="soporte@casadelastortas.com" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Teléfono de contacto</label>
                            <input type="tel" name="TelefonoContacto" class="form-control"
                                   value="@(cfg?.TelefonoContacto ?? "")"
                                   placeholder="+54 9 11 0000-0000" />
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary fw-semibold px-4">
                        <i class="fas fa-save me-2"></i>Guardar configuración
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>

        <!-- Preview: cómo lo ve el comprador -->
        <div class="col-lg-5">
            <div class="cfg-card card p-4 position-sticky" style="top:1.5rem;">
                <div class="cfg-section-title">
                    <i class="fas fa-eye me-1"></i>Vista previa — lo que ve el comprador
                </div>

                <div class="preview-pago">
                    <div class="text-center mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success text-white mb-2"
                             style="width:52px;height:52px;font-size:1.4rem;">
                            <i class="fas fa-university"></i>
                        </div>
                        <h6 class="fw-bold mb-0">Datos de transferencia</h6>
                        <p class="text-muted small mb-0">Transferí el total a esta cuenta</p>
                    </div>

                    <div class="border-top pt-3 mt-2">
                        @{
                            var previewAlias   = cfg?.AliasCBU       ?? "casadelastortas.pagos";
                            var previewBanco   = cfg?.Banco          ?? "Banco Nación";
                            var previewTitular = cfg?.TitularCuenta  ?? "Casa de las Tortas SRL";
                            var previewCbu     = cfg?.CBU            ?? "0000000000000000000000";
                        }
                        <div class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted small">Alias</span>
                            <strong class="font-monospace small" id="prevAlias">@previewAlias</strong>
                        </div>
                        <div class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted small">Banco</span>
                            <strong class="small" id="prevBanco">@previewBanco</strong>
                        </div>
                        <div class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted small">Titular</span>
                            <strong class="small" id="prevTitular">@previewTitular</strong>
                        </div>
                        <div class="d-flex justify-content-between py-2">
                            <span class="text-muted small">CBU</span>
                            <strong class="font-monospace small" style="font-size:.7rem;" id="prevCbu">@previewCbu</strong>
                        </div>
                    </div>

                    <div class="mt-3 p-3 rounded-3 text-center" style="background:#f0fdf4;">
                        <div class="small text-muted mb-1">Monto a transferir (ejemplo)</div>
                        <div class="fs-4 fw-bold text-success">$150.000</div>
                    </div>
                    <p class="text-muted small text-center mt-2 mb-0" id="prevMensaje">
                        @(cfg?.InstruccionesPago ?? "Una vez verificado tu pago, recibirás confirmación en 1 día hábil.")
                    </p>
                </div>

                <!-- Comisión info para vendedores -->
                <div class="mt-4 p-3 rounded-3 border border-warning-subtle" style="background:#fef9c3;">
                    <div class="fw-semibold small mb-1">
                        <i class="fas fa-info-circle text-warning me-1"></i>Comisión plataforma
                    </div>
                    <div class="text-muted small">
                        Por cada venta, la plataforma retiene el 
                        <strong>@(cfg?.ComisionPorcentaje.ToString("N1") ?? "10")%</strong>
                        del subtotal del vendedor al momento de liberar los fondos.
                    </div>
                    @{
                        var comision = cfg?.ComisionPorcentaje ?? 10m;
                        var ejemploVenta = 100000m;
                        var ejemploComision = ejemploVenta * (comision / 100);
                        var ejemploNeto = ejemploVenta - ejemploComision;
                    }
                    <div class="mt-2 small">
                        Ejemplo: Venta $@ejemploVenta.ToString("N0") → Vendedor recibe 
                        <strong class="text-success">$@ejemploNeto.ToString("N0")</strong>
                        · Plataforma retiene 
                        <strong class="text-primary">$@ejemploComision.ToString("N0")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Preview en tiempo real
    const campos = {
        AliasCBU:          'prevAlias',
        Banco:             'prevBanco',
        TitularCuenta:     'prevTitular',
        CBU:               'prevCbu',
        InstruccionesPago: 'prevMensaje'
    };
    Object.entries(campos).forEach(([nombre, idPreview]) => {
        const input = document.querySelector(`[name="${nombre}"]`);
        if (input) {
            input.addEventListener('input', () => {
                const el = document.getElementById(idPreview);
                if (el) el.textContent = input.value || '—';
            });
        }
    });
</script>
}
