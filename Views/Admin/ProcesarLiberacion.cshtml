@model CasaDeLasTortas.Models.Entities.LiberacionFondos
@using CasaDeLasTortas.Models.Entities
@{
    ViewData["Title"] = "Procesar Transferencia";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    body { background-color: #f1f5f9; }
    .admin-main { margin-left: 260px; padding: 2rem; }
    .info-card  { border: none; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.07); }
    @@media (max-width:991px){ .admin-main{ margin-left:0; padding:1rem; } }
</style>
}

<partial name="_AdminSidebar" />

<div class="admin-main">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0" style="font-size:1.6rem;">
                <i class="fas fa-paper-plane text-success me-2"></i>Registrar Transferencia
            </h1>
            <p class="text-muted small mb-0">
                Orden <strong>#@Model.Venta?.NumeroOrden</strong> — vendedor: <strong>@(Model.Vendedor?.NombreComercial ?? "—")</strong>
            </p>
        </div>
        <a asp-action="Liberaciones" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Volver
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 rounded-3 shadow-sm mb-4 alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- Resumen de la liberación -->
        <div class="col-md-5">
            <div class="info-card card p-4 mb-4">
                <div class="fw-bold mb-3" style="font-size:.75rem; text-transform:uppercase; letter-spacing:.08em; color:#94a3b8;">
                    Detalle del monto
                </div>

                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted small">Venta bruta</span>
                    <strong>$@Model.MontoBruto.ToString("N0")</strong>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted small">Comisión (@Model.PorcentajeComision.ToString("N1")%)</span>
                    <strong class="text-danger">-$@Model.Comision.ToString("N0")</strong>
                </div>
                <div class="d-flex justify-content-between py-2 mt-1">
                    <span class="fw-bold">A transferir al vendedor</span>
                    <strong class="text-success fs-5">$@Model.MontoNeto.ToString("N0")</strong>
                </div>
            </div>

            <div class="info-card card p-4">
                <div class="fw-bold mb-3" style="font-size:.75rem; text-transform:uppercase; letter-spacing:.08em; color:#94a3b8;">
                    Datos bancarios del vendedor
                </div>

                @if (!string.IsNullOrEmpty(Model.Vendedor?.AliasCBU))
                {
                    <div class="d-flex justify-content-between py-1">
                        <span class="text-muted small">Alias</span>
                        <strong class="small">@Model.Vendedor.AliasCBU</strong>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Vendedor?.CBU))
                {
                    <div class="d-flex justify-content-between py-1">
                        <span class="text-muted small">CBU</span>
                        <code class="small">@Model.Vendedor.CBU</code>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Vendedor?.Banco))
                {
                    <div class="d-flex justify-content-between py-1">
                        <span class="text-muted small">Banco</span>
                        <span class="small">@Model.Vendedor.Banco</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Vendedor?.TitularCuenta))
                {
                    <div class="d-flex justify-content-between py-1">
                        <span class="text-muted small">Titular</span>
                        <span class="small">@Model.Vendedor.TitularCuenta</span>
                    </div>
                }

                @if (Model.Vendedor?.DatosPagoCompletos == false)
                {
                    <div class="alert alert-warning border-0 rounded-3 mt-3 small">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        El vendedor no tiene datos bancarios completos.
                    </div>
                }
            </div>
        </div>

        <!-- Formulario de transferencia -->
        <div class="col-md-7">
            <div class="info-card card p-4">
                <div class="fw-bold mb-4" style="font-size:.75rem; text-transform:uppercase; letter-spacing:.08em; color:#94a3b8;">
                    Datos de la transferencia realizada
                </div>

                <form asp-action="RegistrarTransferencia" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="liberacionId" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">
                            Número de operación / transacción <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="numeroOperacion" class="form-control" required
                               placeholder="Ej: TRF-20260328-001 o el número que te dio el banco" />
                        <div class="form-text">El código único que identifica la transferencia en tu banco.</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold small">
                            Comprobante de transferencia <span class="text-danger">*</span>
                        </label>
                        <input type="file" name="comprobante" class="form-control" accept="image/*,.pdf" required />
                        <div class="form-text">Foto del ticket o captura del home banking. Máximo 5MB.</div>
                    </div>

                    <!-- Preview del comprobante -->
                    <div id="previewComprobante" class="mb-4 d-none">
                        <div class="p-3 rounded-3 text-center" style="background:#f8fafc; border:2px dashed #e2e8f0;">
                            <img id="imgPreview" src="" alt="Preview" class="img-fluid rounded" style="max-height:200px;" />
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success fw-bold py-2">
                            <i class="fas fa-paper-plane me-2"></i>Confirmar transferencia a @(Model.Vendedor?.NombreComercial ?? "vendedor")
                        </button>
                        <a asp-action="Liberaciones" class="btn btn-outline-secondary">
                            Cancelar
                        </a>
                    </div>

                    <div class="mt-3 p-3 rounded-3 small text-muted" style="background:#f0fdf4;">
                        <i class="fas fa-info-circle text-success me-2"></i>
                        Al confirmar, el vendedor recibirá una notificación y podrá ver el comprobante en su panel.
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    // Preview del comprobante antes de subir
    document.querySelector('input[name="comprobante"]').addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (!file || !file.type.startsWith('image/')) {
            document.getElementById('previewComprobante').classList.add('d-none');
            return;
        }
        const reader = new FileReader();
        reader.onload = function (ev) {
            document.getElementById('imgPreview').src = ev.target.result;
            document.getElementById('previewComprobante').classList.remove('d-none');
        };
        reader.readAsDataURL(file);
    });
</script>
}
