@{
    ViewData["Title"] = "Gestión de Disputas - Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var disputas     = ViewBag.Disputas     as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var countAbiertas  = ViewBag.CountAbiertas  ?? 0;
    var countResueltas = ViewBag.CountResueltas ?? 0;
    var countCerradas  = ViewBag.CountCerradas  ?? 0;
}

@section Styles {
<style>
    body { background-color: #f1f5f9; }
    .admin-main { margin-left: 260px; padding: 2rem; }
    .kpi-card   { border: none; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.07); }
    .dis-table th { font-size:.75rem; text-transform:uppercase; letter-spacing:.07em; color:#94a3b8; font-weight:600; border:none; }
    .dis-table td { vertical-align:middle; border-color:#f1f5f9; }
    .dis-table tr:last-child td { border-bottom:none; }
    .dis-table tbody tr:hover { background:#f8fafc; }
    @@media (max-width:991px){ .admin-main{ margin-left:0; padding:1rem; } }
</style>
}

<partial name="_AdminSidebar" />

<div class="admin-main">

    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0" style="font-size:1.6rem;">
                <i class="fas fa-exclamation-triangle text-danger me-2"></i>Disputas y Reclamos
            </h1>
            <p class="text-muted mb-0 small">Mediá conflictos entre compradores y vendedores</p>
        </div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Dashboard
        </a>
    </div>

    <!-- Alertas -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 rounded-3 shadow-sm mb-4 alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 rounded-3 shadow-sm mb-4 alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-4">
            <div class="kpi-card card p-3">
                <div class="text-muted small mb-1">🔴 Abiertas</div>
                <div class="fs-2 fw-bold text-danger">@countAbiertas</div>
            </div>
        </div>
        <div class="col-4">
            <div class="kpi-card card p-3">
                <div class="text-muted small mb-1">🟡 En proceso</div>
                <div class="fs-2 fw-bold text-warning">@countResueltas</div>
            </div>
        </div>
        <div class="col-4">
            <div class="kpi-card card p-3">
                <div class="text-muted small mb-1">✅ Cerradas</div>
                <div class="fs-2 fw-bold text-success">@countCerradas</div>
            </div>
        </div>
    </div>

    <!-- Filtros rápidos -->
    <div class="d-flex gap-2 mb-4 flex-wrap">
        <a asp-action="Disputas" class="btn btn-sm @(ViewBag.FiltroEstado == null ? "btn-dark" : "btn-outline-secondary")">
            Todas
        </a>
        <a asp-action="Disputas" asp-route-estado="Abierta"
           class="btn btn-sm @(ViewBag.FiltroEstado == "Abierta" ? "btn-danger" : "btn-outline-danger")">
            <i class="fas fa-circle me-1" style="font-size:.5rem;"></i>Abiertas
        </a>
        <a asp-action="Disputas" asp-route-estado="EnProceso"
           class="btn btn-sm @(ViewBag.FiltroEstado == "EnProceso" ? "btn-warning" : "btn-outline-warning")">
            <i class="fas fa-circle me-1" style="font-size:.5rem;"></i>En proceso
        </a>
        <a asp-action="Disputas" asp-route-estado="Resuelta"
           class="btn btn-sm @(ViewBag.FiltroEstado == "Resuelta" ? "btn-success" : "btn-outline-success")">
            <i class="fas fa-circle me-1" style="font-size:.5rem;"></i>Resueltas
        </a>
    </div>

    <!-- Tabla de disputas -->
    <div class="card border-0 rounded-3 shadow-sm">
        @if (disputas.Any())
        {
            <div class="table-responsive">
                <table class="table dis-table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Disputa</th>
                            <th>Partes involucradas</th>
                            <th>Motivo</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Abierta</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in disputas)
                        {
                            var estadoCls = (string)(d.Estado ?? "Abierta") switch {
                                "Resuelta"  => "bg-success",
                                "EnProceso" => "bg-warning text-dark",
                                _           => "bg-danger"
                            };

                            <tr>
                                <td class="ps-4">
                                    <div class="fw-semibold small">#DIS-@d.Id</div>
                                    <div class="text-muted" style="font-size:.72rem;">Orden: #@d.NumeroOrden</div>
                                </td>
                                <td>
                                    <div class="small">
                                        <span class="text-muted">Comprador:</span>
                                        <span class="fw-semibold"> @d.NombreComprador</span>
                                    </div>
                                    <div class="small">
                                        <span class="text-muted">Vendedor:</span>
                                        <span class="fw-semibold"> @d.NombreVendedor</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="small">@(d.Motivo?.Length > 60 ? d.Motivo.Substring(0, 60) + "…" : d.Motivo ?? "—")</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @estadoCls rounded-pill">@d.Estado</span>
                                </td>
                                <td class="text-center text-muted small">@d.FechaCreacion?.ToString("dd/MM/yy")</td>
                                <td class="text-center">
                                    @{
                                        bool esResuelta = d.Estado == "Resuelta" || d.Estado == "Cerrada";
                                    }
                                    <button type="button"
                                            class="btn btn-sm @(esResuelta ? "btn-outline-secondary" : "btn-primary")"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalDisputa"
                                            data-readonly="@esResuelta.ToString().ToLower()"
                                            data-disputa-id="@d.Id"
                                            data-comprador="@d.NombreComprador"
                                            data-email-comprador="@d.EmailComprador"
                                            data-telefono-comprador="@d.TelefonoComprador"
                                            data-vendedor="@d.NombreVendedor"
                                            data-motivo="@d.Motivo"
                                            data-descripcion="@d.Descripcion"
                                            data-estado="@d.Estado"
                                            data-orden="@d.NumeroOrden"
                                            data-fecha-venta="@d.FechaVenta?.ToString("dd/MM/yyyy HH:mm")"
                                            data-total-venta="@d.TotalVenta.ToString("N0")"
                                            data-estado-venta="@d.EstadoVenta"
                                            data-estado-pago="@d.EstadoPago"
                                            data-monto-pagado="@d.MontoPagado.ToString("N0")"
                                            data-tiene-comprobante="@d.TieneComprobante.ToString().ToLower()"
                                            data-fecha-pago="@d.FechaPago?.ToString("dd/MM/yyyy")"
                                            data-productos="@System.Text.Json.JsonSerializer.Serialize(d.Productos)"
                                            data-resolucion="@d.Resolucion"
                                            data-detalle-resolucion="@d.DetalleResolucion"
                                            data-fecha-resolucion="@d.FechaResolucion?.ToString("dd/MM/yyyy")">
                                        @if (esResuelta)
                                        {
                                            <i class="fas fa-eye me-1"></i><text>Ver detalle</text>
                                        }
                                        else
                                        {
                                            <i class="fas fa-gavel me-1"></i><text>Gestionar</text>
                                        }
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-handshake fa-3x text-muted mb-3 d-block"></i>
                <h6 class="fw-semibold text-muted">No hay disputas en este estado</h6>
                <p class="text-muted small">¡Buenas noticias! Todo marcha bien.</p>
            </div>
        }
    </div>

</div><!-- /admin-main -->

<!-- ── Modal: Gestionar disputa ── -->
<div class="modal fade" id="modalDisputa" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">
                    <i class="fas fa-gavel text-primary me-2"></i>
                    Disputa — Orden <span id="dOrden"></span>
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">

                    <!-- Columna izquierda: datos + productos -->
                    <div class="col-lg-7">

                        <!-- Partes -->
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div class="p-3 rounded-3 h-100" style="background:#eff6ff;">
                                    <div class="text-muted fw-semibold mb-1" style="font-size:.7rem;">COMPRADOR</div>
                                    <div id="dComprador" class="fw-semibold small"></div>
                                    <div id="dEmailComprador" class="text-muted" style="font-size:.72rem;"></div>
                                    <div id="dTelefonoComprador" class="text-muted" style="font-size:.72rem;"></div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 rounded-3 h-100" style="background:#f0fdf4;">
                                    <div class="text-muted fw-semibold mb-1" style="font-size:.7rem;">VENDEDOR</div>
                                    <div id="dVendedor" class="fw-semibold small"></div>
                                    <div class="text-muted" style="font-size:.72rem;">
                                        Fecha compra: <span id="dFechaVenta"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Motivo -->
                        <div class="mb-3">
                            <div class="text-muted fw-semibold mb-1" style="font-size:.7rem;">MOTIVO DEL RECLAMO</div>
                            <div id="dMotivo" class="p-3 rounded-3 small fw-semibold" style="background:#fef9c3; border-left:3px solid #f59e0b;"></div>
                            <div id="dDescripcion" class="small text-muted mt-1 px-1"></div>
                        </div>

                        <!-- Productos involucrados -->
                        <div class="mb-2">
                            <div class="text-muted fw-semibold mb-2" style="font-size:.7rem;">PRODUCTOS EN ESTA VENTA</div>
                            <div id="dProductos" class="table-responsive">
                                <table class="table table-sm mb-0" style="font-size:.8rem;">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Producto</th>
                                            <th>Vendedor</th>
                                            <th class="text-center">Cant.</th>
                                            <th class="text-end">Subtotal</th>
                                            <th class="text-center">Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody id="dProductosTbody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Columna derecha: estado pago + acción -->
                    <div class="col-lg-5">

                        <!-- Resumen financiero -->
                        <div class="p-3 rounded-3 mb-3" style="background:#f8fafc; border:1px solid #e2e8f0;">
                            <div class="text-muted fw-semibold mb-2" style="font-size:.7rem;">ESTADO DEL PAGO</div>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="small text-muted">Total venta</span>
                                <span class="fw-bold small">$<span id="dTotalVenta"></span></span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="small text-muted">Monto pagado</span>
                                <span class="fw-semibold small">$<span id="dMontoPagado"></span></span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="small text-muted">Estado pago</span>
                                <span id="dEstadoPagoBadge" class="badge rounded-pill"></span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="small text-muted">Comprobante</span>
                                <span id="dComprobanteInfo" class="small fw-semibold"></span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="small text-muted">Fecha pago</span>
                                <span id="dFechaPago" class="small"></span>
                            </div>
                        </div>

                        <!-- Estado de la venta -->
                        <div class="p-3 rounded-3 mb-3" style="background:#f8fafc; border:1px solid #e2e8f0;">
                            <div class="text-muted fw-semibold mb-1" style="font-size:.7rem;">ESTADO DE LA VENTA</div>
                            <span id="dEstadoVentaBadge" class="badge rounded-pill"></span>
                        </div>

                        <!-- Panel resolución (solo lectura) -->
                        <div id="panelResolucion" class="d-none">
                            <div class="p-3 rounded-3 mb-3" style="background:#f0fdf4; border:1px solid #bbf7d0;">
                                <div class="text-muted fw-semibold mb-2" style="font-size:.7rem;">RESOLUCIÓN DE LA DISPUTA</div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small text-muted">Resultado</span>
                                    <span id="dResolucionBadge" class="badge rounded-pill"></span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small text-muted">Fecha resolución</span>
                                    <span id="dFechaResolucion" class="small fw-semibold"></span>
                                </div>
                                <div class="mt-2">
                                    <div class="text-muted fw-semibold mb-1" style="font-size:.7rem;">DETALLE</div>
                                    <div id="dDetalleResolucion" class="small p-2 rounded-2" style="background:#fff; border:1px solid #e2e8f0; white-space:pre-wrap;"></div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary w-100" data-bs-dismiss="modal">Cerrar</button>
                        </div>

                        <!-- Formulario acción (solo para disputas activas) -->
                        <form id="formGestionar" asp-action="GestionarDisputa" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="disputaId" id="dId" />

                            <div class="mb-3">
                                <label class="form-label fw-semibold small">
                                    Nueva acción <span class="text-danger">*</span>
                                </label>
                                <select name="nuevoEstado" class="form-select form-select-sm" id="dEstadoSelect" required>
                                    <option value="EnProceso">🟡 Tomar el caso</option>
                                    <option value="FavorComprador">✅ Resolver a favor del Comprador</option>
                                    <option value="FavorVendedor">✅ Resolver a favor del Vendedor</option>
                                    <option value="Resuelta">✅ Marcar como Resuelta</option>
                                    <option value="Cerrada">🔒 Cerrar sin resolución</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold small">
                                    Resolución / Comentario <span class="text-danger">*</span>
                                </label>
                                <textarea name="resolucion" class="form-control form-control-sm" rows="3"
                                          placeholder="Explicá tu decisión..."
                                          required></textarea>
                            </div>

                            <div id="panelReembolso" class="p-2 rounded-3 border border-danger-subtle mb-3 d-none" style="background:#fef2f2;">
                                <div class="form-check mb-1">
                                    <input type="checkbox" class="form-check-input" name="procesarReembolso" id="chkReembolso" value="true" />
                                    <label class="form-check-label small" for="chkReembolso">
                                        <i class="fas fa-undo text-danger me-1"></i>Iniciar devolución al comprador
                                    </label>
                                </div>
                                <div id="panelDatosReembolso" class="d-none border-top mt-2 pt-2">
                                    <div class="p-2 rounded-2 mb-2" style="background:#fff3cd;">
                                        <div class="text-muted fw-semibold mb-1" style="font-size:.68rem;">CONTACTAR AL COMPRADOR PARA OBTENER SU CBU/ALIAS</div>
                                        <div class="small"><i class="fas fa-user me-1 text-muted"></i><span id="dNombreReembolso"></span></div>
                                        <div class="small"><i class="fas fa-envelope me-1 text-muted"></i><span id="dEmailReembolso"></span></div>
                                        <div class="small"><i class="fas fa-phone me-1 text-muted"></i><span id="dTelefonoReembolso"></span></div>
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label fw-semibold small mb-1">Alias o CBU destino</label>
                                        <input type="text" name="aliasReembolso" class="form-control form-control-sm"
                                               placeholder="alias.ejemplo o CBU 22 dígitos">
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label fw-semibold small mb-1">Número de transacción</label>
                                        <input type="text" name="numTransaccionReembolso" class="form-control form-control-sm"
                                               placeholder="Nº operación / referencia">
                                    </div>
                                    <div>
                                        <label class="form-label fw-semibold small mb-1">Comprobante de transferencia</label>
                                        <input type="file" name="comprobanteReembolso" class="form-control form-control-sm"
                                               accept="image/*,.pdf">
                                        <div class="text-muted mt-1" style="font-size:.68rem;">Podés completar esto ahora o hacerlo después desde Reembolsos Pendientes.</div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-secondary flex-fill" data-bs-dismiss="modal">Cancelar</button>
                                <button type="submit" class="btn btn-sm btn-primary fw-semibold flex-fill">
                                    <i class="fas fa-gavel me-1"></i>Aplicar
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const estadoPagoBadge = {
        'Pendiente':  ['bg-secondary', 'Sin pagar'],
        'EnRevision': ['bg-warning text-dark', 'En revisión'],
        'Verificado': ['bg-info', 'Verificado'],
        'Completado': ['bg-success', 'Completado'],
        'Rechazado':  ['bg-danger', 'Rechazado'],
        'Cancelado':  ['bg-danger', 'Cancelado'],
        'SinPago':    ['bg-light text-muted', 'Sin pago'],
    };
    const estadoVentaBadge = {
        'Pendiente':       ['bg-warning text-dark', 'Pendiente'],
        'Pagada':          ['bg-info', 'Pagada'],
        'EnPreparacion':   ['bg-primary', 'En preparación'],
        'ListaParaRetiro': ['bg-secondary', 'Lista para retirar'],
        'Entregada':       ['bg-success', 'Entregada'],
        'EnDisputa':       ['bg-danger', 'En disputa'],
        'Cancelada':       ['bg-dark', 'Cancelada'],
    };
    const estadoDetalleBadge = {
        'Pendiente':     ['bg-warning text-dark', 'Pendiente'],
        'Confirmado':    ['bg-info', 'Confirmado'],
        'EnPreparacion': ['bg-primary', 'En prep.'],
        'Listo':         ['bg-success', 'Listo'],
        'Entregado':     ['bg-success', 'Entregado ✓'],
        'Cancelado':     ['bg-danger', 'Cancelado'],
    };

    function setBadge(el, map, key) {
        const [cls, txt] = map[key] ?? ['bg-secondary', key];
        el.className = 'badge rounded-pill ' + cls;
        el.textContent = txt;
    }

    const resolucionLabel = {
        'SinResolucion':      ['bg-secondary', 'Sin resolución'],
        'ReembolsoTotal':     ['bg-success',   'Reembolso total'],
        'ReembolsoParcial':   ['bg-warning text-dark', 'Reembolso parcial'],
        'ReenvioProducto':    ['bg-info',      'Reenvío del producto'],
        'SinAccion':          ['bg-secondary', 'Sin acción'],
        'Credito':            ['bg-primary',   'Crédito'],
        'OtroAcuerdo':        ['bg-dark',      'Otro acuerdo'],
        'FavorComprador':     ['bg-success',   'A favor del comprador'],
        'FavorVendedor':      ['bg-primary',   'A favor del vendedor'],
        'Resuelta':           ['bg-success',   'Resuelta'],
        'Cerrada':            ['bg-secondary', 'Cerrada'],
    };

    document.getElementById('modalDisputa').addEventListener('show.bs.modal', e => {
        const btn = e.relatedTarget;
        const soloLectura = btn.dataset.readonly === 'true';

        // Mostrar/ocultar paneles según modo
        document.getElementById('panelResolucion').classList.toggle('d-none', !soloLectura);
        document.getElementById('formGestionar').classList.toggle('d-none', soloLectura);

        document.getElementById('dOrden').textContent     = btn.dataset.orden;
        document.getElementById('dComprador').textContent = btn.dataset.comprador;
        document.getElementById('dEmailComprador').textContent    = btn.dataset.emailComprador;
        document.getElementById('dTelefonoComprador').textContent = btn.dataset.telefonoComprador || '—';
        document.getElementById('dVendedor').textContent  = btn.dataset.vendedor;
        document.getElementById('dMotivo').textContent    = btn.dataset.motivo;
        document.getElementById('dDescripcion').textContent = btn.dataset.descripcion !== btn.dataset.motivo
            ? btn.dataset.descripcion : '';
        document.getElementById('dFechaVenta').textContent   = btn.dataset.fechaVenta || '—';
        document.getElementById('dTotalVenta').textContent   = btn.dataset.totalVenta || '0';
        document.getElementById('dMontoPagado').textContent  = btn.dataset.montoPagado || '0';
        document.getElementById('dFechaPago').textContent    = btn.dataset.fechaPago || '—';

        // Comprobante
        const compEl = document.getElementById('dComprobanteInfo');
        compEl.textContent = btn.dataset.tieneComprobante === 'true' ? '✅ Enviado' : '❌ No enviado';
        compEl.className = 'small fw-semibold ' + (btn.dataset.tieneComprobante === 'true' ? 'text-success' : 'text-danger');

        // Badges
        setBadge(document.getElementById('dEstadoPagoBadge'),   estadoPagoBadge,  btn.dataset.estadoPago);
        setBadge(document.getElementById('dEstadoVentaBadge'),  estadoVentaBadge, btn.dataset.estadoVenta);

        // Productos
        const tbody = document.getElementById('dProductosTbody');
        tbody.innerHTML = '';
        try {
            const prods = JSON.parse(btn.dataset.productos || '[]');
            prods.forEach(p => {
                const [cls, txt] = estadoDetalleBadge[p.Estado] ?? ['bg-secondary', p.Estado];
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="fw-semibold">${p.Nombre}</td>
                    <td class="text-muted">${p.Vendedor}</td>
                    <td class="text-center">${p.Cantidad}</td>
                    <td class="text-end">$${Number(p.Subtotal).toLocaleString('es-AR')}</td>
                    <td class="text-center"><span class="badge ${cls} rounded-pill" style="font-size:.65rem;">${txt}</span></td>
                `;
                tbody.appendChild(tr);
            });
        } catch {}

        if (soloLectura) {
            // Panel resolución
            const [resCls, resTxt] = resolucionLabel[btn.dataset.resolucion] ?? ['bg-secondary', btn.dataset.resolucion];
            const resBadge = document.getElementById('dResolucionBadge');
            resBadge.className = 'badge rounded-pill ' + resCls;
            resBadge.textContent = resTxt;
            document.getElementById('dFechaResolucion').textContent  = btn.dataset.fechaResolucion || '—';
            document.getElementById('dDetalleResolucion').textContent = btn.dataset.detalleResolucion || '—';
        } else {
            // Reset form
            document.getElementById('dId').value = btn.dataset.disputaId;
            document.getElementById('dNombreReembolso').textContent   = btn.dataset.comprador;
            document.getElementById('dEmailReembolso').textContent    = btn.dataset.emailComprador;
            document.getElementById('dTelefonoReembolso').textContent = btn.dataset.telefonoComprador || '—';
            document.getElementById('chkReembolso').checked = false;
            document.getElementById('panelDatosReembolso').classList.add('d-none');
            document.getElementById('panelReembolso').classList.add('d-none');
        }
    });

    document.getElementById('dEstadoSelect').addEventListener('change', function() {
        const esFavor = this.value === 'FavorComprador';
        document.getElementById('panelReembolso').classList.toggle('d-none', !esFavor);
        if (!esFavor) {
            document.getElementById('chkReembolso').checked = false;
            document.getElementById('panelDatosReembolso').classList.add('d-none');
        }
    });

    document.getElementById('chkReembolso').addEventListener('change', function() {
        document.getElementById('panelDatosReembolso').classList.toggle('d-none', !this.checked);
    });
</script>
}
