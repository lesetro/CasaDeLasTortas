@model CasaDeLasTortas.Models.Entities.Pago
@using CasaDeLasTortas.Models.Entities
@{
    ViewData["Title"] = "Verificar Pago - Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var urlComprobante = ViewBag.UrlComprobante as string;
    var esImagen = !string.IsNullOrEmpty(urlComprobante) &&
                   (urlComprobante.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
                    urlComprobante.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) ||
                    urlComprobante.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
                    urlComprobante.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

@section Styles {
<style>
    body { background-color: #f1f5f9; }
    .admin-main { margin-left: 260px; padding: 2rem; }
    @@media (max-width:991px){ .admin-main { margin-left: 0; padding: 1rem; } }
    .info-card { border: none; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.07); }
    .section-label { font-size:.68rem; text-transform:uppercase; letter-spacing:.1em; color:#94a3b8; font-weight:700; margin-bottom:.5rem; }
    .comprobante-frame { border: 2px dashed #d1d5db; border-radius: 12px; overflow: hidden; background: #f8fafc; min-height: 300px; display:flex; align-items:center; justify-content:center; }
    .btn-aprobar { background: #16a34a; color: white; border: none; padding: .6rem 2rem; border-radius: 8px; font-weight: 700; font-size: 1rem; transition: all .15s; }
    .btn-aprobar:hover { background: #15803d; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(22,163,74,.35); }
    .btn-rechazar { background: #dc2626; color: white; border: none; padding: .6rem 2rem; border-radius: 8px; font-weight: 700; font-size: 1rem; transition: all .15s; }
    .btn-rechazar:hover { background: #b91c1c; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(220,38,38,.35); }
</style>
}

<partial name="_AdminSidebar" />

<div class="admin-main">

    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="fw-bold mb-0" style="font-size:1.6rem;">
                <i class="fas fa-search-dollar text-success me-2"></i>Verificar Pago
            </h1>
            <p class="text-muted mb-0 small">
                Orden <strong>#@(Model?.Venta?.NumeroOrden ?? "—")</strong> —
                Comprador: <strong>@(Model?.Comprador?.Persona?.Nombre ?? "—")</strong>
            </p>
        </div>
        <a asp-action="Pagos" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Volver a Pagos
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 shadow-sm mb-4">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- Columna izquierda: comprobante -->
        <div class="col-lg-6">
            <div class="info-card card p-4 h-100">
                <div class="section-label"><i class="fas fa-file-image me-1"></i>Comprobante subido por el comprador</div>

                @if (string.IsNullOrEmpty(urlComprobante))
                {
                    <div class="comprobante-frame">
                        <div class="text-center text-muted">
                            <i class="fas fa-file-slash fa-3x mb-3 d-block"></i>
                            <p class="mb-0">El comprador no subió comprobante todavía</p>
                        </div>
                    </div>
                }
                else if (esImagen)
                {
                    <div class="comprobante-frame">
                        <img src="@urlComprobante" alt="Comprobante"
                             class="img-fluid" style="max-height:500px; object-fit:contain; cursor:zoom-in;"
                             onclick="document.getElementById('modalImg').src=this.src; new bootstrap.Modal(document.getElementById('modalComprobante')).show()" />
                    </div>
                    <div class="text-center mt-2">
                        <a href="@urlComprobante" target="_blank" class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-external-link-alt me-1"></i>Abrir en nueva pestaña
                        </a>
                    </div>
                }
                else
                {
                    <div class="comprobante-frame flex-column gap-3">
                        <i class="fas fa-file-pdf fa-4x text-danger"></i>
                        <a href="@urlComprobante" target="_blank" class="btn btn-outline-danger">
                            <i class="fas fa-download me-1"></i>Ver / Descargar comprobante
                        </a>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model?.NumeroTransaccion))
                {
                    <div class="mt-3 p-3 rounded-3" style="background:#f0f9ff;">
                        <div class="section-label mb-1">Número de transacción declarado</div>
                        <span class="font-monospace fw-bold">@Model.NumeroTransaccion</span>
                    </div>
                }
            </div>
        </div>

        <!-- Columna derecha: info + acciones -->
        <div class="col-lg-6">

            <!-- Datos del pago -->
            <div class="info-card card p-4 mb-4">
                <div class="section-label"><i class="fas fa-receipt me-1"></i>Datos del pago</div>
                <div class="row g-0">
                    <div class="col-6 py-2 border-bottom">
                        <div class="text-muted small">Orden</div>
                        <div class="fw-bold text-primary">#@(Model?.Venta?.NumeroOrden ?? "—")</div>
                    </div>
                    <div class="col-6 py-2 border-bottom">
                        <div class="text-muted small">Monto a verificar</div>
                        <div class="fw-bold text-success fs-5">$@(Model?.Monto.ToString("N0") ?? "0")</div>
                    </div>
                    <div class="col-6 py-2 border-bottom">
                        <div class="text-muted small">Comisión plataforma</div>
                        <div class="fw-semibold">$@(Model?.ComisionPlataforma.ToString("N0") ?? "0")</div>
                    </div>
                    <div class="col-6 py-2 border-bottom">
                        <div class="text-muted small">Para vendedores</div>
                        <div class="fw-semibold text-primary">$@(Model?.MontoVendedores.ToString("N0") ?? "0")</div>
                    </div>
                    <div class="col-6 py-2 border-bottom">
                        <div class="text-muted small">Método de pago</div>
                        <div class="fw-semibold">@(Model?.MetodoPago?.ToString() ?? "Transferencia")</div>
                    </div>
                    <div class="col-6 py-2 border-bottom">
                        <div class="text-muted small">Estado actual</div>
                        <div>
                            @{
                                var badgeColor = Model?.Estado switch
                                {
                                    EstadoPago.EnRevision  => "info text-dark",
                                    EstadoPago.Pendiente   => "warning text-dark",
                                    EstadoPago.Verificado  => "success",
                                    EstadoPago.Rechazado   => "danger",
                                    _                      => "secondary"
                                };
                            }
                            <span class="badge bg-@badgeColor">@(Model?.Estado.ToString() ?? "—")</span>
                        </div>
                    </div>
                    <div class="col-6 py-2 border-bottom">
                        <div class="text-muted small">Fecha comprobante</div>
                        <div class="small">@(Model?.FechaComprobante?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
                    </div>
                    <div class="col-6 py-2 border-bottom">
                        <div class="text-muted small">Intentos rechazados</div>
                        <div class="fw-semibold @(Model?.IntentosRechazados > 0 ? "text-danger" : "")">
                            @(Model?.IntentosRechazados ?? 0)
                        </div>
                    </div>
                </div>
            </div>

            <!-- Datos del comprador -->
            <div class="info-card card p-4 mb-4">
                <div class="section-label"><i class="fas fa-user me-1"></i>Comprador</div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold"
                         style="width:44px;height:44px;font-size:1.1rem;flex-shrink:0;">
                        @(Model?.Comprador?.Persona?.Nombre?.Substring(0,1).ToUpper() ?? "?")
                    </div>
                    <div>
                        <div class="fw-bold">@(Model?.Comprador?.Persona?.Nombre ?? "—")</div>
                        <div class="text-muted small">@(Model?.Comprador?.Persona?.Email ?? "—")</div>
                        @if (Model?.Venta?.Detalles?.Any() == true)
                        {
                            <div class="text-muted small">
                                @Model.Venta.Detalles.Count producto@(Model.Venta.Detalles.Count != 1 ? "s" : "")
                                · @Model.Venta.Detalles.Sum(d => d.Cantidad) unidad@(Model.Venta.Detalles.Sum(d => d.Cantidad) != 1 ? "es" : "")
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Acciones -->
            @if (Model?.Estado == EstadoPago.EnRevision)
            {
                <div class="info-card card p-4">
                    <div class="section-label"><i class="fas fa-gavel me-1"></i>Decisión del admin</div>
                    <p class="text-muted small mb-4">
                        Verificá que la transferencia llegó a la cuenta de la plataforma
                        por el monto de <strong class="text-success">$@(Model?.Monto.ToString("N0"))</strong>
                        antes de aprobar.
                    </p>

                    <!-- Formulario aprobar -->
                    <form asp-action="ProcesarVerificacion" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="pagoId" value="@Model?.Id" />
                        <input type="hidden" name="aprobado" value="true" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Observaciones (opcional)</label>
                            <input type="text" name="observaciones" class="form-control"
                                   placeholder="Ej: Transferencia recibida correctamente..." />
                        </div>
                        <button type="submit" class="btn-aprobar w-100"
                                onclick="return confirm('¿Confirmar APROBACIÓN del pago de $@(Model?.Monto.ToString("N0"))?')">
                            <i class="fas fa-check-circle me-2"></i>✅ Aprobar pago
                        </button>
                    </form>

                    <hr class="my-3" />

                    <!-- Formulario rechazar -->
                    <form asp-action="ProcesarVerificacion" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="pagoId" value="@Model?.Id" />
                        <input type="hidden" name="aprobado" value="false" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">
                                Motivo del rechazo <span class="text-danger">*</span>
                            </label>
                            <textarea name="motivoRechazo" class="form-control" rows="2" required
                                      placeholder="Ej: Comprobante ilegible, monto no coincide, transferencia no recibida..."></textarea>
                        </div>
                        <button type="submit" class="btn-rechazar w-100"
                                onclick="return confirm('¿Confirmar RECHAZO del comprobante?')">
                            <i class="fas fa-times-circle me-2"></i>❌ Rechazar comprobante
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="info-card card p-4">
                    <div class="section-label">Estado del pago</div>
                    @if (Model?.Estado == EstadoPago.Verificado || Model?.Estado == EstadoPago.Completado)
                    {
                        <div class="alert alert-success border-0 rounded-3 mb-0">
                            <i class="fas fa-check-circle me-2"></i>
                            Este pago ya fue <strong>aprobado</strong>.
                            @if (Model?.FechaVerificacion.HasValue == true)
                            {
                                <div class="small mt-1 opacity-75">@Model.FechaVerificacion.Value.ToString("dd/MM/yyyy HH:mm")</div>
                            }
                            @if (!string.IsNullOrEmpty(Model?.ObservacionesAdmin))
                            {
                                <div class="small mt-1">Obs: @Model.ObservacionesAdmin</div>
                            }
                        </div>
                    }
                    else if (Model?.Estado == EstadoPago.Rechazado)
                    {
                        <div class="alert alert-danger border-0 rounded-3 mb-3">
                            <i class="fas fa-times-circle me-2"></i>
                            Este pago fue <strong>rechazado</strong>.
                            @if (!string.IsNullOrEmpty(Model?.MotivoRechazo))
                            {
                                <div class="small mt-1">Motivo: @Model.MotivoRechazo</div>
                            }
                        </div>
                        <div class="border-top pt-3">
                            <p class="text-muted small mb-2">
                                Si el comprador ya realizó la transferencia y necesitás devolverle el dinero,
                                marcalo para reembolso. Aparecerá en la sección <strong>Reembolsos</strong>.
                            </p>
                            <form asp-action="MarcarParaReembolso" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="pagoId" value="@Model?.Id" />
                                <div class="mb-2">
                                    <label class="form-label small fw-semibold">Motivo del reembolso <span class="text-danger">*</span></label>
                                    <textarea name="motivoReembolso" class="form-control form-control-sm" rows="2" required
                                              placeholder="Ej: El comprador ya transfirió pero el comprobante era ilegible. Se devuelve el dinero."></textarea>
                                </div>
                                <button type="submit" class="btn btn-warning w-100 fw-semibold"
                                        onclick="return confirm('¿Marcar este pago para reembolso al comprador?')">
                                    <i class="fas fa-undo me-2"></i>Marcar para Reembolso
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning border-0 rounded-3 mb-0">
                            <i class="fas fa-clock me-2"></i>
                            Estado: <strong>@(Model?.Estado.ToString() ?? "—")</strong> — no requiere acción en este momento.
                        </div>
                    }
                </div>
            }

        </div>
    </div>

    <!-- Productos de la orden -->
    @if (Model?.Venta?.Detalles?.Any() == true)
    {
        <div class="info-card card mt-4">
            <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                <h6 class="fw-bold mb-0">
                    <i class="fas fa-birthday-cake text-primary me-2"></i>Productos de la orden
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Producto</th>
                                <th>Vendedor</th>
                                <th class="text-center">Cant.</th>
                                <th class="text-end">P. Unit.</th>
                                <th class="text-end pe-4">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detalle in Model.Venta.Detalles)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold">@(detalle.Torta?.Nombre ?? "—")</td>
                                    <td class="text-muted small">@(detalle.Vendedor?.NombreComercial ?? "—")</td>
                                    <td class="text-center">@detalle.Cantidad</td>
                                    <td class="text-end">$@detalle.PrecioUnitario.ToString("N0")</td>
                                    <td class="text-end pe-4 fw-bold text-success">$@detalle.Subtotal.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="4" class="text-end fw-bold ps-4">Total</td>
                                <td class="text-end pe-4 fw-bold text-success fs-6">
                                    $@(Model.Venta.Detalles.Sum(d => d.Subtotal).ToString("N0"))
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }

</div>

<!-- Modal zoom comprobante -->
<div class="modal fade" id="modalComprobante" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0 bg-transparent">
            <div class="modal-body text-center p-0">
                <img id="modalImg" src="" class="img-fluid rounded-3" style="max-height:90vh;" />
                <button type="button" class="btn btn-light mt-2" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
