@model TortaEditViewModel
@{
    ViewData["Title"] = "Editar Torta";
}

<div class="container py-4" style="max-width: 900px;">
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Tortas</a></li>
                <li class="breadcrumb-item active" style="color: #ea580c;">Editar: @Model.Nombre</li>
            </ol>
        </nav>
        <h1 class="fw-bold text-dark">
            <i class="fas fa-edit me-2" style="color: #ea580c;"></i>Editar Torta
        </h1>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="VendedorId" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Nombre" class="form-label fw-semibold">Nombre *</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Categoria" class="form-label fw-semibold">Categoría</label>
                        <select asp-for="Categoria" class="form-select">
                            <option value="">Selecciona una categoría</option>
                            @foreach (var cat in ViewBag.Categorias)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Precio" class="form-label fw-semibold">Precio *</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Precio" type="number" step="0.01" min="0" class="form-control" />
                        </div>
                        <span asp-validation-for="Precio" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Stock" class="form-label fw-semibold">Stock *</label>
                        <input asp-for="Stock" type="number" min="0" class="form-control" />
                        <span asp-validation-for="Stock" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Tamanio" class="form-label fw-semibold">Tamaño</label>
                        <select asp-for="Tamanio" class="form-select">
                            @foreach (var tam in ViewBag.Tamanios)
                            {
                                <option value="@tam">@tam</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TiempoPreparacion" class="form-label fw-semibold">Tiempo preparación (días)</label>
                        <input asp-for="TiempoPreparacion" type="number" min="0" max="30" class="form-control" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input asp-for="Personalizable" type="checkbox" class="form-check-input" />
                            <label asp-for="Personalizable" class="form-check-label">Personalizable</label>
                        </div>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input asp-for="Disponible" type="checkbox" class="form-check-input" />
                            <label asp-for="Disponible" class="form-check-label">Disponible</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label asp-for="Descripcion" class="form-label fw-semibold">Descripción *</label>
                        <textarea asp-for="Descripcion" rows="3" class="form-control"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Ingredientes" class="form-label fw-semibold">Ingredientes</label>
                        <textarea asp-for="Ingredientes" rows="2" class="form-control"></textarea>
                    </div>
                </div>

                <!-- Imágenes actuales -->
                @if (Model.ImagenesActuales != null && Model.ImagenesActuales.Any())
                {
                    <h6 class="fw-semibold mt-4 mb-3"><i class="fas fa-images me-2"></i>Imágenes actuales</h6>
                    <div class="row g-2">
                        @for (int i = 0; i < Model.ImagenesActuales.Count; i++)
                        {
                            var img = Model.ImagenesActuales[i];
                            <div class="col-3" id="img-container-@img.Id">
                                <div class="card @(img.EsPrincipal ? "border-success border-2" : "")">
                                    <img src="@img.UrlImagen" class="card-img-top" style="height:100px;object-fit:cover" />
                                    @if (img.EsPrincipal)
                                    {
                                        <span class="position-absolute top-0 start-0 m-1 badge bg-success" style="font-size:.6rem;">
                                            <i class="fas fa-star me-1"></i>Principal
                                        </span>
                                    }
                                    <div class="card-body p-1 text-center">
                                        <div class="btn-group btn-group-sm w-100">
                                            @if (!img.EsPrincipal)
                                            {
                                                <button type="button" class="btn btn-outline-success btn-sm" onclick="setPrincipal(@img.Id)" title="Principal">
                                                    <i class="fas fa-star"></i>
                                                </button>
                                            }
                                            <button type="button" class="btn btn-outline-danger btn-sm" onclick="eliminarImagen(@img.Id)" title="Eliminar">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Nuevas imágenes -->
                <div class="mt-4">
                    <label asp-for="NuevasImagenes" class="form-label fw-semibold">Agregar nuevas imágenes</label>
                    <input asp-for="NuevasImagenes" type="file" multiple accept="image/*" class="form-control" />
                </div>

                <div id="imagenesAEliminar"></div>

                <div class="d-flex justify-content-end gap-3 mt-4">
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn text-white fw-semibold" style="background-color: #ea580c;">
                        <i class="fas fa-save me-2"></i>Guardar cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var imagenesAEliminar = [];

        function eliminarImagen(id) {
            if (confirm('¿Eliminar esta imagen?')) {
                imagenesAEliminar.push(id);
                document.getElementById('imagenesAEliminar').innerHTML =
                    imagenesAEliminar.map(function(i) { return '<input type="hidden" name="ImagenesAEliminar" value="' + i + '" />'; }).join('');
                var container = document.getElementById('img-container-' + id);
                if (container) container.style.display = 'none';
            }
        }

        function setPrincipal(id) {
            fetch('/Torta/CambiarImagenPrincipal', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: 'imagenId=' + id
            }).then(function(r) { return r.json(); })
              .then(function(data) { if (data.success) location.reload(); else alert('Error'); });
        }
    </script>
}
