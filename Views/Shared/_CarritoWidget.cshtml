@using CasaDeLasTortas.Interfaces
@inject ICarritoService CarritoService

@{
    var totalItems = CarritoService.GetTotalItems();
}

<div class="dropdown">
    <button class="btn btn-outline-light position-relative" type="button" 
            data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fas fa-shopping-cart"></i>
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
            @totalItems
            <span class="visually-hidden">items en el carrito</span>
        </span>
    </button>
    <ul class="dropdown-menu dropdown-menu-end" style="min-width: 300px;">
        <li class="dropdown-header d-flex justify-content-between align-items-center">
            <span>Carrito de Compras</span>
            <a asp-controller="Carrito" asp-action="Index" class="small text-decoration-none">Ver todo</a>
        </li>
        <li><hr class="dropdown-divider"></li>
        
        @if (totalItems > 0)
        {
            var carrito = await CarritoService.ObtenerCarritoConDetalles();
            foreach (var item in carrito.Items.Take(3))
            {
                <li>
                    <a class="dropdown-item" asp-controller="Carrito" asp-action="Index">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-secondary me-2">@item.Cantidad</span>
                                <span>@item.Nombre</span>
                            </div>
                            <small class="text-success">@item.Total.ToString("C")</small>
                        </div>
                    </a>
                </li>
            }
            
            @if (carrito.Items.Count > 3)
            {
                <li>
                    <div class="dropdown-item text-muted small text-center">
                        + @(carrito.Items.Count - 3) productos más
                    </div>
                </li>
            }
            
            <li><hr class="dropdown-divider"></li>
            <li>
                <div class="dropdown-item">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-bold">Total:</span>
                        <span class="fw-bold text-primary">@carrito.Total.ToString("C")</span>
                    </div>
                    <a asp-controller="Carrito" asp-action="Checkout" class="btn btn-success btn-sm w-100">
                        <i class="fas fa-lock me-2"></i>Finalizar Compra
                    </a>
                </div>
            </li>
        }
        else
        {
            <li>
                <div class="dropdown-item text-center py-3 text-muted">
                    <i class="fas fa-shopping-cart fa-2x mb-2"></i>
                    <p class="mb-0">Tu carrito está vacío</p>
                </div>
            </li>
        }
    </ul>
</div>

<script>
    // Actualizar contador cada vez que se agrega algo al carrito
    document.addEventListener('carritoActualizado', function() {
        fetch('/Carrito/Contador')
            .then(res => res.json())
            .then(data => {
                const badge = document.querySelector('.badge.rounded-pill.bg-danger');
                if (badge) {
                    badge.textContent = data.total;
                }
            });
    });
</script>