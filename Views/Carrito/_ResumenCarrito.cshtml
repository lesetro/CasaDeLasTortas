@model CarritoSession

<div class="resumen-carrito">
    <div class="d-flex justify-content-between mb-3">
        <span class="text-muted">Productos (@Model.TotalItems):</span>
        <strong>@Model.Subtotal.ToString("C")</strong>
    </div>

    @if (Model.DescuentoTotal > 0)
    {
        <div class="d-flex justify-content-between mb-3 text-success">
            <span>Descuentos aplicados:</span>
            <strong>-@Model.DescuentoTotal.ToString("C")</strong>
        </div>
    }

    <div class="d-flex justify-content-between mb-3">
        <span class="text-muted">Envío:</span>
        <strong class="text-success">GRATIS</strong>
    </div>

    <hr class="my-3">

    <div class="d-flex justify-content-between mb-3">
        <span class="h5">Total:</span>
        <span class="h5 text-primary fw-bold">@Model.Total.ToString("C")</span>
    </div>

    <div class="mt-3">
        <a asp-controller="Carrito" asp-action="Checkout" class="btn btn-success w-100">
            <i class="fas fa-lock me-2"></i>Proceder al Pago
        </a>
    </div>

    @if (Model.Items.Any())
    {
        <div class="mt-3">
            <h6 class="mb-2">Productos:</h6>
            @foreach (var item in Model.Items.Take(3))
            {
                <div class="d-flex justify-content-between align-items-center mb-2 small">
                    <div>
                        <span class="badge bg-secondary me-1">@item.Cantidad</span>
                        <span>@item.Nombre</span>
                    </div>
                    <span>@item.Total.ToString("C")</span>
                </div>
            }
            @if (Model.Items.Count > 3)
            {
                <p class="text-muted small mb-0 text-center">
                    + @(Model.Items.Count - 3) productos más
                </p>
            }
        </div>
    }
</div>