@using CasaDeLasTortas.Models.ViewModels
@model PagoListViewModel
@{
    ViewData["Title"] = "Gestión de Pagos";
}

<div class="container py-4">
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index" class="text-decoration-none">Admin</a></li>
                <li class="breadcrumb-item active text-success">Pagos</li>
            </ol>
        </nav>
        <h1 class="fw-bold"><i class="fas fa-credit-card text-success me-2"></i>Gestión de Pagos</h1>
    </div>

    <!-- Estadísticas -->
    <div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
        <div class="col">
            <div class="card shadow-sm h-100 border-start border-4 border-primary">
                <div class="card-body text-center">
                    <div class="fs-3 fw-bold text-primary">@Model.TotalPagos</div>
                    <small class="text-muted">Total de pagos</small>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow-sm h-100 border-start border-4 border-success">
                <div class="card-body text-center">
                    <div class="fs-4 fw-bold text-success">$@Model.TotalMonto.ToString("N2")</div>
                    <small class="text-muted">Monto total</small>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow-sm h-100 border-start border-4 border-warning">
                <div class="card-body text-center">
                    <div class="fs-3 fw-bold text-warning">@(Model.PagosPorEstado?.GetValueOrDefault(EstadoPago.Pendiente) ?? 0)</div>
                    <small class="text-muted">Pendientes</small>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow-sm h-100 border-start border-4 border-success">
                <div class="card-body text-center">
                    <div class="fs-3 fw-bold text-success">@(Model.PagosPorEstado?.GetValueOrDefault(EstadoPago.Completado) ?? 0)</div>
                    <small class="text-muted">Completados</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-medium">Buscar</label>
                    <input type="text" name="busqueda" value="@Model.Busqueda" class="form-control" placeholder="Orden, transacción..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-medium">Estado</label>
                    <select name="filtroEstado" class="form-select">
                        <option value="">Todos</option>
                        <option value="Pendiente" selected="@(Model.FiltroEstado == EstadoPago.Pendiente)">Pendiente</option>
                        <option value="Completado" selected="@(Model.FiltroEstado == EstadoPago.Completado)">Completado</option>
                        <option value="Cancelado" selected="@(Model.FiltroEstado == EstadoPago.Cancelado)">Cancelado</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-medium">Desde</label>
                    <input type="date" name="fechaDesde" value="@(Model.FechaDesde?.ToString("yyyy-MM-dd"))" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-medium">Hasta</label>
                    <input type="date" name="fechaHasta" value="@(Model.FechaHasta?.ToString("yyyy-MM-dd"))" class="form-control" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-success"><i class="fas fa-filter me-1"></i>Filtrar</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-times"></i></a>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card shadow-sm">
        @if (Model.Pagos.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Orden</th>
                            <th>Comprador</th>
                            <th>Producto</th>
                            <th class="text-center">Monto</th>
                            <th class="text-center">Fecha</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Método</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pago in Model.Pagos)
                        {
                            <tr>
                                <td class="fw-semibold">#@pago.Id</td>
                                <td>
                                    <a asp-controller="Venta" asp-action="Details" asp-route-id="@pago.VentaId" class="text-decoration-none">
                                        @pago.NumeroOrden
                                    </a>
                                </td>
                                <td>@pago.NombreComprador</td>
                                <td>@pago.NombreTorta</td>
                                <td class="text-center fw-bold text-success">$@pago.Monto.ToString("N2")</td>
                                <td class="text-center">@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">
                                    <span class="badge @(pago.Estado == EstadoPago.Completado ? "bg-success" : pago.Estado == EstadoPago.Pendiente ? "bg-warning text-dark" : "bg-danger")">
                                        @pago.Estado
                                    </span>
                                </td>
                                <td class="text-center">@(pago.MetodoPago?.ToString() ?? "-")</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Details" asp-route-id="@pago.Id" class="btn btn-sm btn-outline-primary" title="Ver detalle">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        @if (pago.Estado == EstadoPago.Pendiente && (User.IsInRole("Vendedor") || User.IsInRole("Admin")))
                                        {
                                            <a asp-action="ConfirmarPago" asp-route-id="@pago.Id" class="btn btn-sm btn-outline-success" title="Confirmar">
                                                <i class="fas fa-check-circle"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer">
                <partial name="_Paginacion" model="Model.Paginacion" />
            </div>
        }
        else
        {
            <div class="card-body text-center py-5 text-muted">
                <i class="fas fa-credit-card fa-3x mb-3 opacity-50"></i>
                <h5>No hay pagos registrados</h5>
                <p>Los pagos aparecerán aquí cuando los compradores realicen compras.</p>
            </div>
        }
    </div>
</div>
