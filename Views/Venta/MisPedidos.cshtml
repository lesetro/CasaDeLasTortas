@model CasaDeLasTortas.Models.ViewModels.MisPedidosViewModel
@using CasaDeLasTortas.Models.Entities
@{
    ViewData["Title"] = "Mis Pedidos";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-0"><i class="bi bi-bag-check me-2 text-primary"></i>Mis Pedidos</h2>
            <small class="text-muted">Administrá los pedidos de tus tortas</small>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Estadísticas rápidas *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="MisPedidos" asp-route-filtroEstado=""
               class="card text-center text-decoration-none h-100 @(string.IsNullOrEmpty(Model.FiltroEstado) ? "border-primary shadow" : "border-0 shadow-sm")">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4">@(Model.PendientesCount + Model.EnPreparacionCount + Model.ListosCount + Model.EntregadosCount + Model.CanceladosCount)</div>
                    <small class="text-muted">Todos</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="MisPedidos" asp-route-filtroEstado="Pendiente"
               class="card text-center text-decoration-none h-100 border-warning @(Model.FiltroEstado == "Pendiente" ? "shadow" : "shadow-sm")">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-warning">@Model.PendientesCount</div>
                    <small class="text-muted">Pendientes</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="MisPedidos" asp-route-filtroEstado="EnPreparacion"
               class="card text-center text-decoration-none h-100 border-primary @(Model.FiltroEstado == "EnPreparacion" ? "shadow" : "shadow-sm")">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-primary">@Model.EnPreparacionCount</div>
                    <small class="text-muted">En preparación</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="MisPedidos" asp-route-filtroEstado="Listo"
               class="card text-center text-decoration-none h-100 border-secondary @(Model.FiltroEstado == "Listo" ? "shadow" : "shadow-sm")">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-secondary">@Model.ListosCount</div>
                    <small class="text-muted">Listos</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="MisPedidos" asp-route-filtroEstado="Entregado"
               class="card text-center text-decoration-none h-100 border-success @(Model.FiltroEstado == "Entregado" ? "shadow" : "shadow-sm")">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-success">@Model.EntregadosCount</div>
                    <small class="text-muted">Entregados</small>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="MisPedidos" asp-route-filtroEstado="Cancelado"
               class="card text-center text-decoration-none h-100 border-danger @(Model.FiltroEstado == "Cancelado" ? "shadow" : "shadow-sm")">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-danger">@Model.CanceladosCount</div>
                    <small class="text-muted">Cancelados</small>
                </div>
            </a>
        </div>
    </div>

    @* Lista de pedidos *@
    @if (!Model.Pedidos.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No hay pedidos
                @if (!string.IsNullOrEmpty(Model.FiltroEstado))
                {
                    <span>con estado "@Model.FiltroEstado"</span>
                }
            </h4>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            @foreach (var pedido in Model.Pedidos)
            {
                <div class="col-12 col-xl-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <div class="d-flex gap-3">
                                @* Imagen *@
                                <div class="flex-shrink-0">
                                    @if (!string.IsNullOrEmpty(pedido.ImagenTorta))
                                    {
                                        <img src="@pedido.ImagenTorta" alt="@pedido.NombreTorta"
                                             class="rounded" style="width:80px;height:80px;object-fit:cover;">
                                    }
                                    else
                                    {
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center"
                                             style="width:80px;height:80px;">
                                            <i class="bi bi-cake2 text-muted fs-3"></i>
                                        </div>
                                    }
                                </div>

                                @* Info principal *@
                                <div class="flex-grow-1 min-w-0">
                                    <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                        <div>
                                            <h6 class="mb-0 fw-bold">@pedido.NombreTorta</h6>
                                            <small class="text-muted">Orden #@pedido.NumeroOrden</small>
                                        </div>
                                        <span class="badge bg-@pedido.EstadoColor">@pedido.EstadoDisplay</span>
                                    </div>

                                    <div class="row g-1 mt-2 small text-muted">
                                        <div class="col-auto">
                                            <i class="bi bi-person me-1"></i>@pedido.NombreComprador
                                        </div>
                                        <div class="col-auto">
                                            <i class="bi bi-telephone me-1"></i>@pedido.TelefonoComprador
                                        </div>
                                        <div class="col-auto">
                                            <i class="bi bi-calendar3 me-1"></i>@pedido.FechaVenta.ToString("dd/MM/yyyy")
                                        </div>
                                        <div class="col-auto">
                                            <i class="bi bi-box-seam me-1"></i>x@pedido.Cantidad
                                        </div>
                                        <div class="col-auto fw-semibold text-dark">
                                            $@pedido.Subtotal.ToString("N2")
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(pedido.NotasPersonalizacion))
                                    {
                                        <div class="mt-1">
                                            <small class="text-muted"><i class="bi bi-chat-left-text me-1"></i>@pedido.NotasPersonalizacion</small>
                                        </div>
                                    }

                                    <div class="small text-muted mt-1">
                                        <i class="bi bi-geo-alt me-1"></i>@pedido.DireccionEntrega
                                    </div>

                                    @* Acciones de estado *@
                                    <div class="mt-3 d-flex flex-wrap gap-2 align-items-center">
                                        @if (pedido.Estado == EstadoDetalleVenta.Pendiente)
                                        {
                                            <button class="btn btn-sm btn-primary btn-cambiar-estado"
                                                    data-detalle-id="@pedido.DetalleId"
                                                    data-nuevo-estado="EnPreparacion">
                                                <i class="bi bi-fire me-1"></i>Iniciar preparación
                                            </button>
                                        }
                                        else if (pedido.Estado == EstadoDetalleVenta.EnPreparacion)
                                        {
                                            <button class="btn btn-sm btn-secondary btn-cambiar-estado"
                                                    data-detalle-id="@pedido.DetalleId"
                                                    data-nuevo-estado="Listo">
                                                <i class="bi bi-check-lg me-1"></i>Marcar como listo
                                            </button>
                                        }
                                        else if (pedido.Estado == EstadoDetalleVenta.Listo)
                                        {
                                            <button class="btn btn-sm btn-success btn-cambiar-estado"
                                                    data-detalle-id="@pedido.DetalleId"
                                                    data-nuevo-estado="Entregado">
                                                <i class="bi bi-truck me-1"></i>Confirmar entrega
                                            </button>
                                        }
                                        <a asp-action="Details" asp-route-id="@pedido.VentaId" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-eye me-1"></i>Ver orden
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* Paginación *@
        @if (Model.Paginacion.TotalPaginas > 1)
        {
            <nav>
                <ul class="pagination justify-content-center">
                    <li class="page-item @(!Model.Paginacion.TienePaginaAnterior ? "disabled" : "")">
                        <a class="page-link" asp-action="MisPedidos"
                           asp-route-pagina="@(Model.Paginacion.PaginaActual - 1)"
                           asp-route-filtroEstado="@Model.FiltroEstado">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @foreach (var num in Model.Paginacion.NumerosPagina)
                    {
                        <li class="page-item @(num == Model.Paginacion.PaginaActual ? "active" : "")">
                            <a class="page-link" asp-action="MisPedidos"
                               asp-route-pagina="@num"
                               asp-route-filtroEstado="@Model.FiltroEstado">@num</a>
                        </li>
                    }
                    <li class="page-item @(!Model.Paginacion.TienePaginaSiguiente ? "disabled" : "")">
                        <a class="page-link" asp-action="MisPedidos"
                           asp-route-pagina="@(Model.Paginacion.PaginaActual + 1)"
                           asp-route-filtroEstado="@Model.FiltroEstado">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        document.querySelectorAll('.btn-cambiar-estado').forEach(btn => {
            btn.addEventListener('click', function () {
                const detalleId = this.dataset.detalleId;
                const nuevoEstado = this.dataset.nuevoEstado;
                const originalHtml = this.innerHTML;
                this.disabled = true;
                this.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

                fetch('@Url.Action("ActualizarEstadoDetalle", "Venta")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                    },
                    body: new URLSearchParams({ detalleId, nuevoEstado })
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message || 'Error al actualizar');
                        this.disabled = false;
                        this.innerHTML = originalHtml;
                    }
                })
                .catch(() => {
                    alert('Error de conexión');
                    this.disabled = false;
                    this.innerHTML = originalHtml;
                });
            });
        });
    </script>
}
