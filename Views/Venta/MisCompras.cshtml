@model CasaDeLasTortas.Models.ViewModels.MisComprasViewModel
@{
    ViewData["Title"] = "Mis Compras";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="bi bi-bag-heart me-2 text-primary"></i>Mis Compras</h2>
            <small class="text-muted">Historial de todas tus órdenes</small>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-shop me-1"></i>Seguir comprando
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Ventas.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">Todavía no realizaste ninguna compra</h4>
            <p class="text-muted">Explorá nuestro catálogo y encontrá la torta perfecta.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">
                <i class="bi bi-shop me-2"></i>Explorar catálogo
            </a>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            @foreach (var venta in Model.Ventas)
            {
                <div class="col-12">
                    <div class="card shadow-sm h-100 border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                <div class="d-flex gap-3 align-items-center">
                                    @if (!string.IsNullOrEmpty(venta.ImagenPrincipal))
                                    {
                                        <img src="@venta.ImagenPrincipal" alt="Torta"
                                             class="rounded" style="width:70px;height:70px;object-fit:cover;">
                                    }
                                    else
                                    {
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center"
                                             style="width:70px;height:70px;">
                                            <i class="bi bi-cake2 text-muted fs-3"></i>
                                        </div>
                                    }
                                    <div>
                                        <h6 class="mb-0 fw-bold">Orden #@venta.NumeroOrden</h6>
                                        <small class="text-muted">
                                            <i class="bi bi-calendar3 me-1"></i>@venta.FechaVenta.ToString("dd/MM/yyyy")
                                        </small>
                                        <div class="mt-1">
                                            <small class="text-muted">
                                                <i class="bi bi-box-seam me-1"></i>@venta.TotalItems item@(venta.TotalItems != 1 ? "s" : "")
                                            </small>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-@venta.EstadoColor fs-6 px-3 py-2 d-block mb-2">@venta.EstadoDisplay</span>
                                    <div class="fs-5 fw-bold text-primary mb-2">$@venta.Total.ToString("N2")</div>
                                    <a asp-action="Details" asp-route-id="@venta.Id" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-eye me-1"></i>Ver detalle
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* Paginación *@
        @if (Model.Paginacion.TotalPaginas > 1)
        {
            <nav aria-label="Paginación de compras">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(!Model.Paginacion.TienePaginaAnterior ? "disabled" : "")">
                        <a class="page-link" asp-action="MisCompras"
                           asp-route-pagina="@(Model.Paginacion.PaginaActual - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @foreach (var num in Model.Paginacion.NumerosPagina)
                    {
                        <li class="page-item @(num == Model.Paginacion.PaginaActual ? "active" : "")">
                            <a class="page-link" asp-action="MisCompras" asp-route-pagina="@num">@num</a>
                        </li>
                    }
                    <li class="page-item @(!Model.Paginacion.TienePaginaSiguiente ? "disabled" : "")">
                        <a class="page-link" asp-action="MisCompras"
                           asp-route-pagina="@(Model.Paginacion.PaginaActual + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
                <p class="text-center text-muted small">
                    Mostrando @Model.Paginacion.ItemsDesde–@Model.Paginacion.ItemsHasta de @Model.Paginacion.TotalItems órdenes
                </p>
            </nav>
        }
    }
</div>
