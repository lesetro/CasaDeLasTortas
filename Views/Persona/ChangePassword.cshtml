@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Cambiar Contraseña";
    var personaNombre = ViewBag.PersonaNombre as string;
    var personaId = ViewBag.PersonaId as int?;
}

<div class="container mt-5" style="max-width: 500px;">
    <!-- Header -->
    <div class="text-center mb-4">
        <div class="display-1 mb-3">🔐</div>
        <h1 class="display-5 fw-bold text-dark">Cambiar Contraseña</h1>
        <p class="text-secondary">@personaNombre</p>
    </div>

    <!-- Formulario -->
    <div class="card shadow">
        <div class="card-body p-4">
            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@personaId" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Contraseña actual -->
                <div class="mb-3">
                    <label asp-for="CurrentPassword" class="form-label fw-medium">
                        Contraseña actual <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input asp-for="CurrentPassword" type="password" class="form-control" />
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('CurrentPassword')">
                            <i class="fas fa-eye" id="eye-CurrentPassword"></i>
                        </button>
                    </div>
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>

                <!-- Nueva contraseña -->
                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-medium">
                        Nueva contraseña <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input asp-for="NewPassword" type="password" class="form-control" />
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('NewPassword')">
                            <i class="fas fa-eye" id="eye-NewPassword"></i>
                        </button>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    <div class="form-text">Mínimo 6 caracteres</div>
                </div>

                <!-- Confirmar nueva contraseña -->
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-medium">
                        Confirmar nueva contraseña <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('ConfirmPassword')">
                            <i class="fas fa-eye" id="eye-ConfirmPassword"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <!-- Requisitos de contraseña -->
                <div class="alert alert-info small p-3 mb-4">
                    <p class="fw-semibold mb-2">Requisitos:</p>
                    <ul class="mb-0 ps-3">
                        <li>Mínimo 6 caracteres</li>
                        <li>Al menos una letra mayúscula</li>
                        <li>Al menos un número</li>
                    </ul>
                </div>

                <!-- Botones -->
                <div class="d-flex gap-3">
                    <button type="submit" class="flex-fill btn btn-warning text-white fw-semibold py-2">
                        <i class="fas fa-save me-2"></i>Cambiar contraseña
                    </button>
                    <a asp-action="Details" asp-route-id="@personaId" 
                       class="flex-fill btn btn-light border fw-semibold py-2">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        function togglePassword(fieldId) {
            const field = document.querySelector(`[name="${fieldId}"]`);
            const eyeIcon = document.getElementById(`eye-${fieldId}`);
            
            if (field.type === 'password') {
                field.type = 'text';
                eyeIcon.classList.remove('fa-eye');
                eyeIcon.classList.add('fa-eye-slash');
            } else {
                field.type = 'password';
                eyeIcon.classList.remove('fa-eye-slash');
                eyeIcon.classList.add('fa-eye');
            }
        }
    </script>
}