@model PersonaViewModel
@{
    ViewData["Title"] = $"Detalle de {Model.Nombre}";
}

<div class="container mt-5">
    <!-- Navegación -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Personas</a></li>
            <li class="breadcrumb-item active text-warning" aria-current="page">@Model.Nombre @Model.Apellido</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Columna izquierda: Información básica -->
        <div class="col-lg-4">
            <div class="card shadow">
                <div class="bg-primary bg-gradient" style="height: 100px;"></div>
                <div class="card-body text-center" style="margin-top: -60px;">
                    <div class="rounded-circle border border-4 border-white mx-auto overflow-hidden bg-white shadow-sm" 
                         style="width: 100px; height: 100px;">
                        @if (!string.IsNullOrEmpty(Model.Avatar))
                        {
                            <img src="@Model.Avatar" class="w-100 h-100 object-fit-cover" />
                        }
                        else
                        {
                            <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                                <i class="fas fa-user fa-2x text-primary"></i>
                            </div>
                        }
                    </div>
                    <h5 class="fw-bold mt-3">@Model.Nombre @Model.Apellido</h5>
                    <p class="text-secondary">@@@Model.Email</p>
                    
                    <div class="d-flex justify-content-center gap-2">
                        <span class="badge @(Model.Rol == "Admin" ? "bg-danger" : Model.Rol == "Vendedor" ? "bg-success" : "bg-purple")">
                            @Model.Rol
                        </span>
                        @if (Model.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </div>
                </div>
                
                <div class="card-body border-top">
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex text-secondary">
                            <i class="fas fa-id-card me-3" style="width: 20px;"></i>
                            <span>DNI: @(Model.Dni ?? "No especificado")</span>
                        </div>
                        <div class="d-flex text-secondary">
                            <i class="fas fa-phone me-3" style="width: 20px;"></i>
                            <span>@(Model.Telefono ?? "No especificado")</span>
                        </div>
                        <div class="d-flex text-secondary">
                            <i class="fas fa-map-marker-alt me-3" style="width: 20px;"></i>
                            <span>@(Model.Direccion ?? "No especificada")</span>
                        </div>
                        <div class="d-flex text-secondary">
                            <i class="fas fa-calendar me-3" style="width: 20px;"></i>
                            <span>Registro: @Model.FechaRegistro.ToString("dd/MM/yyyy")</span>
                        </div>
                        @if (Model.UltimoAcceso.HasValue)
                        {
                            <div class="d-flex text-secondary">
                                <i class="fas fa-clock me-3" style="width: 20px;"></i>
                                <span>Último acceso: @Model.UltimoAcceso.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        }
                    </div>
                </div>
                
                <div class="card-footer bg-white d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" 
                       class="flex-fill btn btn-warning text-white">
                        <i class="fas fa-edit me-2"></i>Editar
                    </a>
                    <a asp-action="Index" class="flex-fill btn btn-light border">
                        <i class="fas fa-arrow-left me-2"></i>Volver
                    </a>
                </div>
            </div>
        </div>

        <!-- Columna derecha: Información específica según rol -->
        <div class="col-lg-8">
            <div class="d-flex flex-column gap-4">
                @if (Model.Rol == "Vendedor" && Model.Vendedor != null)
                {
                    <div class="card shadow">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">
                                <i class="fas fa-store text-success me-2"></i>
                                Información de Vendedor
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="small text-secondary">Nombre Comercial</div>
                                    <div class="fw-medium">@Model.Vendedor.NombreComercial</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Especialidad</div>
                                    <div class="fw-medium">@(Model.Vendedor.Especialidad ?? "No especificada")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Calificación</div>
                                    <div class="fw-medium">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= Math.Floor(Model.Vendedor.Calificacion))
                                            {
                                                <i class="fas fa-star text-warning"></i>
                                            }
                                            else if (i - 1/2 <= Model.Vendedor.Calificacion)
                                            {
                                                <i class="fas fa-star-half-alt text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="far fa-star text-warning"></i>
                                            }
                                        }
                                        (@Model.Vendedor.Calificacion.ToString("F1"))
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Total Ventas</div>
                                    <div class="fw-medium">@Model.Vendedor.TotalVentas ventas</div>
                                </div>
                                <div class="col-12">
                                    <div class="small text-secondary">Descripción</div>
                                    <div class="fw-medium">@(Model.Vendedor.Descripcion ?? "Sin descripción")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Horario</div>
                                    <div class="fw-medium">@(Model.Vendedor.Horario ?? "No especificado")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Verificado</div>
                                    <div class="fw-medium">
                                        @if (Model.Vendedor.Verificado)
                                        {
                                            <span class="text-success"><i class="fas fa-check-circle"></i> Verificado</span>
                                        }
                                        else
                                        {
                                            <span class="text-secondary">No verificado</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.Rol == "Comprador" && Model.Comprador != null)
                {
                    <div class="card shadow">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">
                                <i class="fas fa-shopping-bag text-purple me-2"></i>
                                Información de Comprador
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="small text-secondary">Dirección</div>
                                    <div class="fw-medium">@Model.Comprador.Direccion</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Teléfono</div>
                                    <div class="fw-medium">@Model.Comprador.Telefono</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Ciudad</div>
                                    <div class="fw-medium">@(Model.Comprador.Ciudad ?? "No especificada")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Provincia</div>
                                    <div class="fw-medium">@(Model.Comprador.Provincia ?? "No especificada")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Código Postal</div>
                                    <div class="fw-medium">@(Model.Comprador.CodigoPostal ?? "No especificado")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Total Compras</div>
                                    <div class="fw-medium">@Model.Comprador.TotalCompras compras</div>
                                </div>
                                @if (Model.Comprador.FechaNacimiento.HasValue)
                                {
                                    <div class="col-md-6">
                                        <div class="small text-secondary">Fecha Nacimiento</div>
                                        <div class="fw-medium">@Model.Comprador.FechaNacimiento.Value.ToString("dd/MM/yyyy")</div>
                                    </div>
                                }
                                <div class="col-12">
                                    <div class="small text-secondary">Preferencias</div>
                                    <div class="fw-medium">@(Model.Comprador.Preferencias ?? "Sin preferencias")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Acciones adicionales -->
                <div class="card shadow">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">
                            <i class="fas fa-cog text-secondary me-2"></i>
                            Acciones
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-action="ChangePassword" asp-route-id="@Model.Id" 
                               class="btn btn-warning text-white">
                                <i class="fas fa-key me-2"></i>Cambiar Contraseña
                            </a>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@Model.Id" 
                                   class="btn btn-danger">
                                    <i class="fas fa-trash me-2"></i>Eliminar Persona
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>