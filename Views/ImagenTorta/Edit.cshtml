@model ImagenTortaEditViewModel
@{
    ViewData["Title"] = "Editar Imagen";
}

<div class="container mt-5" style="max-width: 600px;">
    <!-- Header -->
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Torta" asp-action="Index" class="text-decoration-none">Tortas</a></li>
                <li class="breadcrumb-item"><a asp-action="Index" asp-route-tortaId="@ViewBag.TortaId" class="text-decoration-none">Imágenes</a></li>
                <li class="breadcrumb-item active text-warning" aria-current="page">Editar imagen</li>
            </ol>
        </nav>
        <h1 class="display-5 fw-bold text-dark">
            <i class="fas fa-edit text-warning me-3"></i>Editar Imagen
        </h1>
        <p class="text-secondary">Torta: <strong>@ViewBag.NombreTorta</strong></p>
    </div>

    <!-- Imagen actual -->
    <div class="card shadow mb-4">
        <div class="card-header bg-light">
            <h6 class="mb-0 fw-semibold">Imagen actual</h6>
        </div>
        <div class="card-body text-center">
            <img src="@ViewBag.UrlImagen" 
                 alt="Imagen actual" 
                 class="img-fluid rounded shadow-sm" style="max-height: 300px;" />
        </div>
    </div>

    <!-- Formulario de edición -->
    <div class="card shadow">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Es Principal -->
                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="EsPrincipal" type="checkbox" class="form-check-input" />
                        <label asp-for="EsPrincipal" class="form-check-label fw-medium">
                            Establecer como imagen principal
                        </label>
                    </div>
                    <div class="small text-secondary mt-2 ms-4">
                        <i class="fas fa-info-circle me-1"></i>
                        La imagen principal se muestra en el catálogo y en las vistas previas.
                    </div>
                </div>

                <!-- Orden -->
                <div class="mb-4">
                    <label asp-for="Orden" class="form-label fw-medium">
                        Orden de visualización
                    </label>
                    <input asp-for="Orden" 
                           type="number" 
                           min="0" 
                           max="100"
                           class="form-control" />
                    <span asp-validation-for="Orden" class="text-danger small"></span>
                    <div class="small text-secondary mt-2">
                        <i class="fas fa-info-circle me-1"></i>
                        Las imágenes se ordenan de menor a mayor número. 0 = primera.
                    </div>
                </div>

                <!-- Botones -->
                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="Index" asp-route-tortaId="@ViewBag.TortaId" 
                       class="btn btn-light border px-4 py-2 fw-semibold">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-warning text-white px-4 py-2 fw-semibold">
                        <i class="fas fa-save me-2"></i>Guardar cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}