@model ImagenTortaListViewModel
@{
    ViewData["Title"] = $"Galería - {Model.NombreTorta}";
}

<div class="container mt-5">
    <!-- Header -->
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Torta" asp-action="Index" class="text-decoration-none">Tortas</a></li>
                <li class="breadcrumb-item"><a asp-controller="Torta" asp-action="Details" asp-route-id="@Model.TortaId" 
                   class="text-decoration-none">@Model.NombreTorta</a></li>
                <li class="breadcrumb-item active text-primary" aria-current="page">Galería</li>
            </ol>
        </nav>
        
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
            <h1 class="display-5 fw-bold text-dark">
                <i class="fas fa-images text-primary me-3"></i>Galería de @Model.NombreTorta
            </h1>
            
            @if (Model.PuedeEditar)
            {
                <a asp-action="Create" asp-route-tortaId="@Model.TortaId" 
                   class="btn btn-primary btn-lg fw-semibold">
                    <i class="fas fa-plus-circle me-2"></i>Agregar imágenes
                </a>
            }
        </div>
    </div>

    @if (Model.Imagenes.Any())
    {
        <!-- Grid de la galería -->
        <div class="row g-4">
            @foreach (var imagen in Model.Imagenes)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm gallery-card" 
                         style="cursor: pointer;" 
                         onclick="abrirModal('@imagen.UrlImagen', '@imagen.NombreArchivo')">
                        <div class="position-relative" style="padding-top: 100%;">
                            <img src="@imagen.UrlImagen" 
                                 alt="@imagen.NombreArchivo" 
                                 class="position-absolute top-0 start-0 w-100 h-100 object-fit-cover card-img-top" 
                                 style="object-fit: cover;" />
                            
                            <!-- Overlay con información -->
                            <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-0 hover-overlay d-flex align-items-end p-2">
                                @if (imagen.EsPrincipal)
                                {
                                    <span class="badge bg-warning">
                                        <i class="fas fa-star me-1"></i>Principal
                                    </span>
                                }
                            </div>
                            
                            <!-- Orden badge -->
                            <div class="position-absolute top-0 end-0 m-2 badge bg-primary rounded-circle p-2" 
                                 style="width: 30px; height: 30px;">
                                @imagen.Orden
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card shadow p-5 text-center">
            <i class="fas fa-images fa-4x text-secondary opacity-50 mb-3"></i>
            <h4 class="fw-semibold mb-2">No hay imágenes</h4>
            <p class="text-secondary mb-4">Esta torta aún no tiene imágenes cargadas.</p>
            
            @if (Model.PuedeEditar)
            {
                <div>
                    <a asp-action="Create" asp-route-tortaId="@Model.TortaId" 
                       class="btn btn-primary btn-lg fw-semibold">
                        <i class="fas fa-plus-circle me-2"></i>Agregar primera imagen
                    </a>
                </div>
            }
        </div>
    }

    <!-- Modal de imagen ampliada -->
    <div class="modal fade" id="galleryModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content bg-transparent border-0">
                <div class="modal-body p-0 text-center">
                    <img id="galleryImage" src="" alt="" class="img-fluid rounded shadow" />
                    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" 
                            data-bs-dismiss="modal" aria-label="Cerrar"></button>
                    <div id="galleryCaption" class="position-absolute bottom-0 start-0 w-100 text-white text-center p-2 bg-dark bg-opacity-50 rounded-bottom">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function abrirModal(url, titulo) {
            document.getElementById('galleryImage').src = url;
            document.getElementById('galleryCaption').textContent = titulo || '';
            
            const modal = new bootstrap.Modal(document.getElementById('galleryModal'));
            modal.show();
        }

        // Navegación con teclas (Bootstrap maneja ESC automáticamente)
    </script>
}