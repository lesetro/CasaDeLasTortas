@model ImagenTortaListViewModel
@{
    ViewData["Title"] = "Gestión de Imágenes";
}

<div class="container mt-5">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Torta" asp-action="Index" class="text-decoration-none">Tortas</a></li>
                    <li class="breadcrumb-item active text-primary" aria-current="page">Imágenes</li>
                </ol>
            </nav>
            <h1 class="display-5 fw-bold text-dark">
                <i class="fas fa-images text-primary me-3"></i>Gestión de Imágenes
            </h1>
            @if (Model.TortaId > 0)
            {
                <p class="text-secondary">
                    Mostrando imágenes de: <strong class="text-primary">@Model.NombreTorta</strong>
                </p>
            }
        </div>

        @if (Model.TortaId > 0 && Model.PuedeEditar)
        {
            <a asp-action="Create" asp-route-tortaId="@Model.TortaId" 
               class="btn btn-primary btn-lg fw-semibold shadow">
                <i class="fas fa-plus-circle me-2"></i>Agregar Imágenes
            </a>
        }
    </div>

    <!-- Filtro por torta -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-8 col-lg-9">
                    <label class="form-label fw-medium">Filtrar por torta</label>
                    <select name="tortaId" class="form-select" onchange="this.form.submit()">
                        <option value="">Todas las tortas</option>
                        @* Aquí irían las opciones de tortas (necesitarías cargarlas en el controller) *@
                    </select>
                </div>
                <div class="col-md-4 col-lg-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter me-2"></i>Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Grid de imágenes -->
    @if (Model.Imagenes.Any())
    {
        <div class="row g-4">
            @foreach (var imagen in Model.Imagenes)
            {
                <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                    <div class="card h-100 shadow-sm">
                        <!-- Imagen -->
                        <div class="position-relative" style="padding-top: 100%;">
                            <img src="@imagen.UrlImagen" 
                                 alt="@imagen.NombreArchivo" 
                                 class="position-absolute top-0 start-0 w-100 h-100 object-fit-cover card-img-top" 
                                 style="object-fit: cover;" />
                            
                            <!-- Overlay con acciones -->
                            <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex align-items-center justify-content-center opacity-0 hover-overlay">
                                <div class="d-flex gap-2">
                                    @if (Model.PuedeEditar)
                                    {
                                        <a asp-action="Edit" asp-route-id="@imagen.Id" 
                                           class="btn btn-warning btn-sm rounded-circle" style="width: 40px; height: 40px;">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@imagen.Id" 
                                           class="btn btn-danger btn-sm rounded-circle" style="width: 40px; height: 40px;">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    }
                                    <button onclick="verImagen('@imagen.UrlImagen', '@imagen.NombreTorta')" 
                                            class="btn btn-primary btn-sm rounded-circle" style="width: 40px; height: 40px;">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Badge de principal -->
                            @if (imagen.EsPrincipal)
                            {
                                <div class="position-absolute top-0 start-0 m-2 badge bg-warning">
                                    <i class="fas fa-star me-1"></i>Principal
                                </div>
                            }
                        </div>

                        <!-- Información de la imagen -->
                        <div class="card-body p-2">
                            <div class="small fw-medium text-truncate" title="@imagen.NombreArchivo">
                                @imagen.NombreArchivo
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-1">
                                <span class="small text-secondary">
                                    <i class="fas fa-calendar me-1"></i>
                                    @imagen.FechaSubida.ToString("dd/MM/yyyy")
                                </span>
                                @if (!string.IsNullOrEmpty(imagen.NombreTorta))
                                {
                                    <span class="badge bg-light text-dark small">
                                        @imagen.NombreTorta
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Paginación -->
        <div class="mt-4">
            <partial name="_Paginacion" model="ViewBag.Paginacion" />
        </div>
    }
    else
    {
        <div class="card shadow p-5 text-center">
            <i class="fas fa-images fa-4x text-secondary opacity-50 mb-3"></i>
            <h4 class="fw-semibold mb-2">No hay imágenes</h4>
            <p class="text-secondary mb-4">
                @if (Model.TortaId > 0)
                {
                    <span>Esta torta no tiene imágenes cargadas.</span>
                }
                else
                {
                    <span>No hay imágenes registradas en el sistema.</span>
                }
            </p>
            
            @if (Model.TortaId > 0 && Model.PuedeEditar)
            {
                <div>
                    <a asp-action="Create" asp-route-tortaId="@Model.TortaId" 
                       class="btn btn-primary btn-lg fw-semibold">
                        <i class="fas fa-plus-circle me-2"></i>Agregar primera imagen
                    </a>
                </div>
            }
        </div>
    }

    <!-- Modal para ver imagen ampliada -->
    <div class="modal fade" id="imageModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content bg-transparent border-0">
                <div class="modal-body p-0 text-center">
                    <img id="modalImage" src="" alt="" class="img-fluid rounded shadow" />
                    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" 
                            data-bs-dismiss="modal" aria-label="Cerrar"></button>
                    <div id="modalCaption" class="position-absolute bottom-0 start-0 w-100 text-white text-center p-2 bg-dark bg-opacity-50 rounded-bottom">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function verImagen(url, titulo) {
            document.getElementById('modalImage').src = url;
            document.getElementById('modalCaption').textContent = titulo || '';
            
            const modal = new bootstrap.Modal(document.getElementById('imageModal'));
            modal.show();
        }
    </script>
}