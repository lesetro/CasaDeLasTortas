@{
    ViewData["Title"] = "Dashboard Vendedor";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Casa de las Tortas</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
</head>

<body>
    <div id="app">
        <div class="loading-screen d-flex justify-content-center align-items-center vh-100 bg-light">
            <div class="text-center">
                <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;"></div>
                <h5 class="text-muted">Inicializando Dashboard Vendedor...</h5>
                <p class="text-muted small" id="debug-info"></p>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>

    <!-- IMPORTANTE: Asegúrate de que la ruta sea correcta -->
    <script src="~/js/Vendedor/vendedor-dashboard.js"></script>

    <script>
        // Configurar toastr
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "5000"
        };

        // Debug inicial
        document.addEventListener('DOMContentLoaded', function () {
            const debugEl = document.getElementById('debug-info');
            const token = localStorage.getItem('authToken');

            console.log('🔍 Debug info:');
            console.log('Token presente:', token ? 'SÍ' : 'NO');
            console.log('Vue cargado:', typeof Vue !== 'undefined');
            console.log('URL actual:', window.location.href);

            if (debugEl) {
                debugEl.innerHTML = `
                Token: ${token ? '✅ PRESENTE' : '❌ AUSENTE'}<br>
                Vue: ${typeof Vue !== 'undefined' ? '✅ CARGADO' : '❌ NO CARGADO'}<br>
                URL: ${window.location.pathname}
            `;
            }

            // Si no hay token, redirigir a login después de 2 segundos
            if (!token) {
                console.warn('⚠️ No hay token - Redirigiendo a login...');
                setTimeout(() => {
                    window.location.href = '/Account/Login';
                }, 2000);
            }
        });
    </script>
</body>

</html>