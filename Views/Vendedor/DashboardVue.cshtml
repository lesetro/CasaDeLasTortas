@{
    ViewData["Title"] = "Dashboard Vendedor";
    Layout = null;
    var cookieToken = Context.Request.Cookies["authToken"] ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Casa de las Tortas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
</head>
<body>
    <div id="app">
        <div class="d-flex justify-content-center align-items-center vh-100 bg-light">
            <div class="text-center">
                <div class="spinner-border text-success mb-3" style="width:3rem;height:3rem"></div>
                <h5 class="text-muted">Iniciando Panel del Vendedor...</h5>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        toastr.options = { closeButton: true, progressBar: true, positionClass: "toast-top-right", timeOut: "5000" };

        // Si el servidor reconoció el token por cookie pero localStorage está vacío, restaurarlo.
        // Esto evita el bucle: DashboardVue → Login → DashboardVue cuando se limpia localStorage.
        (function() {
            var serverToken = '@cookieToken';
            if (serverToken && !localStorage.getItem('authToken')) {
                localStorage.setItem('authToken', serverToken);
            }
            if (!localStorage.getItem('authToken')) {
                window.location.href = '/Account/Login';
            }
        })();
    </script>

    <!-- Bundle compilado por Vite -->
    <script type="module" src="~/js/dist/vendedor.bundle.js"></script>
</body>
</html>
