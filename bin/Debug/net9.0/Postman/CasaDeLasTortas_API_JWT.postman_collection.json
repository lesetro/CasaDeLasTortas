    {
      "name": "5. Pagos (PagoApi)",
      "description": "Gestion de pagos y comprobantes. Ruta base: /api/PagoApi",
      "item": [
        {
          "name": "5.1 [Comprador] Mis pagos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/PagoApi/mis-pagos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "PagoApi", "mis-pagos"]
            },
            "description": "Lista todos los pagos del comprador autenticado."
          },
          "response": []
        },
        {
          "name": "5.2 [Comprador] Datos bancarios de plataforma",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/PagoApi/datos-plataforma",
              "host": ["{{baseUrl}}"],
              "path": ["api", "PagoApi", "datos-plataforma"]
            },
            "description": "Obtiene los datos bancarios para hacer la transferencia."
          },
          "response": []
        },
        {
          "name": "5.3 [Comprador] Subir comprobante (IFormFile)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "ComprobanteFile", "type": "file", "src": [], "description": "Imagen/PDF del comprobante (max 10MB)" },
                { "key": "Notas", "value": "Transferencia realizada el 06/04/2026", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/PagoApi/subir-comprobante",
              "host": ["{{baseUrl}}"],
              "path": ["api", "PagoApi", "subir-comprobante"]
            },
            "description": "Sube el comprobante de transferencia. Usa IFormFile. Dispara notificacion SignalR al admin."
          },
          "response": []
