{
  "info": {
    "_postman_id": "casa-tortas-api-jwt",
    "name": "Casa de las Tortas - API JWT",
    "description": "Colección completa de endpoints para el API de Casa de las Tortas con autenticación JWT.\n\n**Flujo recomendado:**\n1. Ejecutar '1.1 Login' → el token se guarda automáticamente\n2. Todos los demás requests lo usan via {{token}}\n\n**Credenciales de prueba:**\n- Vendedor: vendedor@test.com / Vendedor123!\n- Comprador: comprador@test.com / Comprador123!\n- Admin: admin@casadelastortas.com / Admin123!",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "console.log('Request a:', pm.request.url.toString());"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "console.log('Response status:', pm.response.code);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Autenticacion (AuthApi)",
      "description": "Endpoints de autenticación. Ruta base: /api/AuthApi",
      "item": [
        {
          "name": "1.1 Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene token', () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.token).to.exist;",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token guardado. Usuario:', json.user.nombre, '| Rol:', json.user.rol);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendedor@test.com\",\n  \"password\": \"Vendedor123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/AuthApi/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "AuthApi", "login"]
            },
            "description": "Autentica al usuario y retorna JWT token.\nEl script de test guarda el token automáticamente en la variable {{token}}."
          },
          "response": []
        },
        {
          "name": "1.2 Register - Vendedor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.success && json.token) {",
                  "        pm.collectionVariables.set('token', json.token);",
                  "        console.log('Registro exitoso. Token guardado.');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "Nombre", "value": "Pasteleria La Delicia", "type": "text" },
                { "key": "Apellido", "value": "Tortas", "type": "text" },
                { "key": "Email", "value": "ladelicia@example.com", "type": "text" },
                { "key": "Password", "value": "Password123!", "type": "text" },
                { "key": "ConfirmPassword", "value": "Password123!", "type": "text" },
                { "key": "Telefono", "value": "2664123456", "type": "text" },
                { "key": "Rol", "value": "Vendedor", "type": "text", "description": "Vendedor o Comprador" },
                { "key": "NombreComercial", "value": "La Delicia", "type": "text", "description": "Requerido para Vendedor" },
                { "key": "Descripcion", "value": "Las mejores tortas artesanales de Villa Mercedes", "type": "text" },
                { "key": "AvatarFile", "type": "file", "src": [], "description": "Imagen opcional (jpg, png - max 5MB)" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/AuthApi/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "AuthApi", "register"]
            },
            "description": "Registro de nuevo vendedor con nombre comercial. Usa multipart/form-data para poder subir avatar."
          },
          "response": []
        },
        {
          "name": "1.3 Register - Comprador",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.success && json.token) {",
                  "        pm.collectionVariables.set('token', json.token);",
                  "        console.log('Registro exitoso. Token guardado.');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "Nombre", "value": "Maria", "type": "text" },
                { "key": "Apellido", "value": "Gonzalez", "type": "text" },
                { "key": "Email", "value": "maria.gonzalez@example.com", "type": "text" },
                { "key": "Password", "value": "Password123!", "type": "text" },
                { "key": "ConfirmPassword", "value": "Password123!", "type": "text" },
                { "key": "Telefono", "value": "2664789012", "type": "text" },
                { "key": "Rol", "value": "Comprador", "type": "text" },
                { "key": "Direccion", "value": "Av. Mitre 456, Villa Mercedes", "type": "text", "description": "Requerido para Comprador" },
                { "key": "AvatarFile", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/AuthApi/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "AuthApi", "register"]
            },
            "description": "Registro de nuevo comprador con direccion de entrega."
          },
          "response": []
        },
        {
          "name": "1.4 Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/AuthApi/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "AuthApi", "me"]
            },
            "description": "Retorna datos basicos del usuario autenticado segun el token JWT."
          },
          "response": []
        },
        {
          "name": "1.5 Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.success && json.token) {",
                  "        pm.collectionVariables.set('token', json.token);",
                  "        console.log('Token renovado exitosamente');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/AuthApi/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "AuthApi", "refresh"]
            },
            "description": "Renueva el JWT sin volver a hacer login. Requiere token valido en el header."
          },
          "response": []
        },
        {
          "name": "1.6 Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendedor@test.com\",\n  \"newPassword\": \"NuevoPassword123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/AuthApi/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "AuthApi", "reset-password"]
            },
            "description": "Resetea la contrasena directamente. No requiere token."
          },
          "response": []
        },
        {
          "name": "1.7 Check Email Disponible",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/AuthApi/check-email?email=nuevo@example.com",
              "host": ["{{baseUrl}}"],
              "path": ["api", "AuthApi", "check-email"],
              "query": [{ "key": "email", "value": "nuevo@example.com" }]
            },
            "description": "Verifica si un email ya esta registrado. No requiere autenticacion."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Tortas (TortaApi)",
      "description": "CRUD de tortas. Ruta base: /api/TortaApi\nGET publico | POST/PUT/DELETE requieren JWT de Vendedor",
      "item": [
        {
          "name": "2.1 Catalogo publico (paginado)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/TortaApi/catalogo?pagina=1&registrosPorPagina=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "TortaApi", "catalogo"],
              "query": [
                { "key": "pagina", "value": "1" },
                { "key": "registrosPorPagina", "value": "10" }
              ]
            },
            "description": "Catalogo publico paginado. No requiere autenticacion."
          },
          "response": []
        },
        {
          "name": "2.2 Buscar tortas - AJAX search",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/TortaApi/search?termino=chocolate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "TortaApi", "search"],
              "query": [{ "key": "termino", "value": "chocolate", "description": "Minimo 2 caracteres" }]
            },
            "description": "Busqueda AJAX. Este es el endpoint que usa el debounce en Vue.js (400ms, min 2 chars).\nHace WHERE LIKE en la base de datos (no en memoria)."
          },
          "response": []
        },
        {
          "name": "2.3 Detalle de torta",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/TortaApi/catalogo/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "TortaApi", "catalogo", "1"]
            },
            "description": "Detalle publico de una torta por ID."
          },
          "response": []
        },
        {
          "name": "2.4 Tortas disponibles",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/TortaApi/disponibles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "TortaApi", "disponibles"]
            },
            "description": "Lista solo tortas marcadas como disponibles."
          },
          "response": []
        },
        {
          "name": "2.5 Categorias",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/TortaApi/categorias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "TortaApi", "categorias"]
            },
            "description": "Lista de categorias existentes para usar en filtros del catalogo."
          },
          "response": []
        },
        {
          "name": "2.6 [Vendedor] Crear torta",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "Nombre", "value": "Torta de Chocolate", "type": "text" },
                { "key": "Descripcion", "value": "Deliciosa torta de chocolate artesanal", "type": "text" },
                { "key": "Precio", "value": "2500", "type": "text" },
                { "key": "Categoria", "value": "Tortas de Cumpleanos", "type": "text" },
                { "key": "Disponible", "value": "true", "type": "text" },
                { "key": "ImagenFile", "type": "file", "src": [], "description": "Imagen principal (jpg, png - max 5MB)" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/TortaApi",
              "host": ["{{baseUrl}}"],
              "path": ["api", "TortaApi"]
            },
            "description": "Crea una nueva torta. Requiere JWT de Vendedor. Usa IFormFile para la imagen."
          },
          "response": []
        },
        {
          "name": "2.7 [Vendedor] Editar torta",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "Nombre", "value": "Torta de Chocolate Actualizada", "type": "text" },
                { "key": "Descripcion", "value": "Nueva descripcion", "type": "text" },
                { "key": "Precio", "value": "2800", "type": "text" },
                { "key": "Categoria", "value": "Tortas de Cumpleanos", "type": "text" },
                { "key": "Disponible", "value": "true", "type": "text" },
                { "key": "ImagenFile", "type": "file", "src": [], "description": "Opcional: nueva imagen" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/TortaApi/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "TortaApi", "1"]
            },
            "description": "Actualiza una torta por ID. Solo el vendedor dueno puede editarla."
          },
          "response": []
        },
        {
          "name": "2.8 [Vendedor] Cambiar disponibilidad (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"disponible\": false }",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/TortaApi/1/disponibilidad",
              "host": ["{{baseUrl}}"],
              "path": ["api", "TortaApi", "1", "disponibilidad"]
            },
            "description": "Activa o desactiva la disponibilidad sin editar toda la torta."
          },
          "response": []
        },
        {
          "name": "2.9 [Vendedor] Eliminar torta",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/TortaApi/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "TortaApi", "1"]
            },
            "description": "Elimina una torta por ID. Solo el vendedor dueno puede eliminarla."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Carrito (CarritoApi)",
      "description": "Gestion del carrito de compras. Ruta base: /api/CarritoApi\nTodos los endpoints requieren JWT de Comprador.",
      "item": [
        {
          "name": "3.1 Ver carrito",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/CarritoApi",
              "host": ["{{baseUrl}}"],
              "path": ["api", "CarritoApi"]
            },
            "description": "Retorna el carrito completo del comprador autenticado con todos sus items."
          },
          "response": []
        },
        {
          "name": "3.2 Contador de items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/CarritoApi/contador",
              "host": ["{{baseUrl}}"],
              "path": ["api", "CarritoApi", "contador"]
            },
            "description": "Retorna solo la cantidad de items (para el badge del navbar)."
          },
          "response": []
        },
        {
          "name": "3.3 Agregar item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tortaId\": 1,\n  \"cantidad\": 2,\n  \"notas\": \"Sin gluten si es posible\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/CarritoApi/agregar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "CarritoApi", "agregar"]
            },
            "description": "Agrega una torta al carrito. Si ya existe, suma la cantidad."
          },
          "response": []
        },
        {
          "name": "3.4 Actualizar cantidad",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tortaId\": 1,\n  \"cantidad\": 3\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/CarritoApi/actualizar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "CarritoApi", "actualizar"]
            },
            "description": "Cambia la cantidad de un item existente en el carrito."
          },
          "response": []
        },
        {
          "name": "3.5 Quitar item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tortaId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/CarritoApi/quitar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "CarritoApi", "quitar"]
            },
            "description": "Elimina un item del carrito."
          },
          "response": []
        },
        {
          "name": "3.6 Vaciar carrito",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/CarritoApi/vaciar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "CarritoApi", "vaciar"]
            },
            "description": "Elimina todos los items del carrito."
          },
          "response": []
        }
      ]
    },
