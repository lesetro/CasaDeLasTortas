    {
      "name": "8. Tests JWT",
      "description": "Casos de prueba para verificar el comportamiento del sistema JWT.",
      "item": [
        {
          "name": "TEST - Login exitoso (guarda token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success=true y tiene token', () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.user.rol).to.eql('Vendedor');",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('OK - Token guardado para siguientes tests');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendedor@test.com\",\n  \"password\": \"Vendedor123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/AuthApi/login"
          },
          "response": []
        },
        {
          "name": "TEST - Credenciales incorrectas → 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('success=false con mensaje', () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.be.false;",
                  "    pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noexiste@test.com\",\n  \"password\": \"ClaveIncorrecta123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/AuthApi/login"
          },
          "response": []
        },
        {
          "name": "TEST - Sin token → 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 sin token', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/AuthApi/me",
            "description": "Acceder a endpoint protegido sin token debe retornar 401."
          },
          "response": []
        },
        {
          "name": "TEST - Con token valido → 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 con token', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna datos del usuario', () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.persona).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/AuthApi/me",
            "description": "Con el token del test anterior, debe retornar 200 con datos del usuario."
          },
          "response": []
        }
      ]
